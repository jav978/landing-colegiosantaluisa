---
const programas = [
  {
    nivel: 'Educación Inicial',
    grados: '3 a 5 años',
    descripcion: 'Formación temprana enfocada en el desarrollo integral, psicomotricidad, socialización y valores fundamentales.',
    color: 'from-sky-400 to-blue-500',
    icon: '🧸',
    bg: 'bg-sky-50',
    border: 'border-sky-200',
  },
  {
    nivel: 'Educación Primaria',
    grados: '1° a 6° grado',
    descripcion: 'Bases académicas sólidas en todas las áreas del conocimiento, con énfasis en valores cristianos y formación del carácter.',
    color: 'from-primary to-primary-light',
    icon: '📚',
    bg: 'bg-blue-50',
    border: 'border-blue-200',
  },
  {
    nivel: 'Educación Secundaria',
    grados: '1° a 5° año (Ciclo Básico desde 1957)',
    descripcion: 'Preparación integral para la educación superior, desarrollando pensamiento crítico, liderazgo y compromiso social.',
    color: 'from-amber-400 to-amber-600',
    icon: '🎓',
    bg: 'bg-amber-50',
    border: 'border-amber-200',
  },
];
---

<section id="programas" class="section-padding bg-white">
  <div class="container-custom">
    <div class="mb-16 text-center">
      <span class="mb-3 inline-block rounded-full bg-accent/10 px-4 py-1.5 text-xs font-semibold uppercase tracking-wider text-accent">
        Oferta Académica
      </span>
      <h2 class="text-3xl font-bold text-gray-900 sm:text-4xl">
        Nuestros <span class="text-accent">Programas</span> Educativos
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-gray-600">
        Desde 1950 formando generaciones con excelencia académica y valores vicencianos
      </p>
      <div class="mx-auto mt-4 h-1 w-20 rounded-full bg-accent"></div>
    </div>

    <div class="grid gap-8 md:grid-cols-3">
      {programas.map((p) => (
        <div class={`group relative overflow-hidden rounded-2xl border ${p.border} ${p.bg} p-8 shadow-sm transition hover:shadow-xl`}>
          <div class={`absolute top-0 right-0 h-32 w-32 -translate-y-8 translate-x-8 rounded-full bg-gradient-to-br ${p.color} opacity-10`}></div>
          
          <div class="relative">
            <span class="mb-4 inline-block text-4xl">{p.icon}</span>
            <h3 class="mb-1 text-xl font-bold text-gray-900">{p.nivel}</h3>
            <span class={`mb-4 inline-block rounded-full ${p.bg} bg-opacity-50 px-3 py-0.5 text-xs font-semibold text-gray-600`}>
              {p.grados}
            </span>
            <p class="text-sm leading-relaxed text-gray-600">{p.descripcion}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

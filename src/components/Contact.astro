---
const contactoInfo = [
  { icon: '📍', label: 'Dirección', value: 'Calle Real del Prado de María, junto a la Iglesia La Milagrosa, Caracas' },
  { icon: '📞', label: 'Teléfono', value: '+58 (212) 555-1234' },
  { icon: '✉️', label: 'Email', value: 'info@colegiosantaluisa.edu.ve' },
  { icon: '🕐', label: 'Horario', value: 'Lunes a Viernes · 7:00 AM - 1:00 PM' },
];
---

<section id="contacto" class="section-padding bg-gradient-to-b from-white to-stone-50 dark:from-[#0e072c] dark:to-[#140b37]">
  <div class="container-custom">
    <div class="mb-16 text-center">
      <span class="mb-3 inline-block rounded-full bg-primary/10 dark:bg-primary-light/20 px-4 py-1.5 text-xs font-semibold uppercase tracking-wider text-primary dark:text-primary-light">
        Contacto
      </span>
      <h2 class="text-3xl font-bold text-gray-900 dark:text-white sm:text-4xl">
        Estemos en <span class="text-primary dark:text-accent">contacto</span>
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-gray-600 dark:text-slate-300">
        ¿Tienes preguntas? Escríbenos y con gusto te atenderemos
      </p>
      <div class="mx-auto mt-4 h-1 w-20 rounded-full bg-accent"></div>
    </div>

    <div class="grid gap-12 lg:grid-cols-5">
      <div class="lg:col-span-3">
        <form class="space-y-6" id="contact-form" method="POST">
          <div class="grid gap-6 sm:grid-cols-2">
            <div>
              <label for="nombre" class="mb-1.5 block text-sm font-medium text-gray-700 dark:text-slate-300">Nombre completo</label>
              <input
                type="text"
                id="nombre"
                name="nombre"
                required
                class="w-full rounded-xl border border-gray-200 dark:border-slate-800 bg-white dark:bg-[#1b1145] text-gray-800 dark:text-slate-100 px-4 py-3 text-sm outline-none transition focus:border-primary dark:focus:border-accent focus:ring-2 focus:ring-primary/20 dark:focus:ring-accent/20"
                placeholder="Tu nombre"
              />
            </div>
            <div>
              <label for="email" class="mb-1.5 block text-sm font-medium text-gray-700 dark:text-slate-300">Correo electrónico</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full rounded-xl border border-gray-200 dark:border-slate-800 bg-white dark:bg-[#1b1145] text-gray-800 dark:text-slate-100 px-4 py-3 text-sm outline-none transition focus:border-primary dark:focus:border-accent focus:ring-2 focus:ring-primary/20 dark:focus:ring-accent/20"
                placeholder="tu@correo.com"
              />
            </div>
          </div>
          <div>
            <label for="telefono" class="mb-1.5 block text-sm font-medium text-gray-700 dark:text-slate-300">Teléfono</label>
            <input
              type="tel"
              id="telefono"
              name="telefono"
              class="w-full rounded-xl border border-gray-200 dark:border-slate-800 bg-white dark:bg-[#1b1145] text-gray-800 dark:text-slate-100 px-4 py-3 text-sm outline-none transition focus:border-primary dark:focus:border-accent focus:ring-2 focus:ring-primary/20 dark:focus:ring-accent/20"
              placeholder="+58 412-..."
            />
          </div>
          <div>
            <label for="mensaje" class="mb-1.5 block text-sm font-medium text-gray-700 dark:text-slate-300">Mensaje</label>
            <textarea
              id="mensaje"
              name="mensaje"
              rows="4"
              required
              class="w-full rounded-xl border border-gray-200 dark:border-slate-800 bg-white dark:bg-[#1b1145] text-gray-800 dark:text-slate-100 px-4 py-3 text-sm outline-none transition focus:border-primary dark:focus:border-accent focus:ring-2 focus:ring-primary/20 dark:focus:ring-accent/20"
              placeholder="Escribe tu mensaje..."
            ></textarea>
          </div>

          <div id="form-alert" class="hidden rounded-xl p-4 text-sm font-medium"></div>

          <button
            type="submit"
            id="submit-btn"
            class="inline-flex w-full items-center justify-center gap-2 rounded-xl bg-primary px-8 py-3.5 text-sm font-bold text-white shadow-lg transition hover:bg-primary-light dark:bg-accent dark:text-primary dark:hover:bg-accent-light hover:shadow-xl sm:w-auto"
          >
            <span id="btn-text">Enviar mensaje</span>
            <svg id="btn-icon" class="h-4 w-4 animate-spin hidden" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
            <svg id="btn-arrow" class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
            </svg>
          </button>
        </form>
      </div>

<script>
  const contactForm = document.getElementById('contact-form') as HTMLFormElement | null;
  const formAlert = document.getElementById('form-alert') as HTMLDivElement | null;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;
  const btnText = document.getElementById('btn-text') as HTMLSpanElement | null;
  const btnIcon = document.getElementById('btn-icon') as SVGElement | null;
  const btnArrow = document.getElementById('btn-arrow') as SVGElement | null;

  if (contactForm) {
    contactForm.addEventListener('submit', async (event) => {
      event.preventDefault();

      if (!formAlert || !submitBtn || !btnText || !btnIcon || !btnArrow) return;

      // Reset alert state
      formAlert.className = 'hidden rounded-xl p-4 text-sm font-medium';
      formAlert.textContent = '';

      // Disable button and show spinner
      submitBtn.disabled = true;
      btnText.textContent = 'Enviando...';
      btnIcon.classList.remove('hidden');
      btnArrow.classList.add('hidden');

      const formData = new FormData(contactForm);
      const payload = {
        name: formData.get('nombre'),
        email: formData.get('email'),
        phone: formData.get('telefono'),
        message: formData.get('mensaje'),
      };

      try {
        const response = await fetch('/api/contacto', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify(payload),
        });

        const data = await response.json();

        if (response.ok && data.success) {
          formAlert.classList.remove('hidden');
          formAlert.classList.add('bg-green-50', 'text-green-800', 'dark:bg-green-950/30', 'dark:text-green-400');
          formAlert.textContent = 'Mensaje enviado correctamente';
          contactForm.reset();

          setTimeout(() => {
            formAlert.classList.add('hidden');
            formAlert.className = 'hidden rounded-xl p-4 text-sm font-medium';
            formAlert.textContent = '';
          }, 2000);
        } else {
          throw new Error(data.error || 'Error al enviar el mensaje');
        }
      } catch (error: any) {
        console.error('Error submitting contact form:', error);
        formAlert.classList.remove('hidden');
        formAlert.classList.add('bg-red-50', 'text-red-800', 'dark:bg-red-950/30', 'dark:text-red-400');
        formAlert.textContent = error.message || 'Ocurrió un error inesperado al enviar el mensaje. Inténtalo de nuevo.';
      } finally {
        submitBtn.disabled = false;
        btnText.textContent = 'Enviar mensaje';
        btnIcon.classList.add('hidden');
        btnArrow.classList.remove('hidden');
      }
    });
  }
</script>

      <div class="lg:col-span-2">
        <div class="rounded-2xl bg-primary dark:bg-[#1b1145] border border-transparent dark:border-slate-800/80 p-8 text-white shadow-lg">
          <h3 class="mb-6 text-lg font-bold">Información de contacto</h3>
          <div class="space-y-6">
            {contactoInfo.map((item) => (
              <div class="flex items-start gap-4">
                <span class="mt-0.5 text-xl">{item.icon}</span>
                <div>
                  <p class="text-xs font-medium uppercase tracking-wider text-white/70 dark:text-slate-400">{item.label}</p>
                  <p class="text-sm font-medium">{item.value}</p>
                </div>
              </div>
            ))}
          </div>
          <div class="mt-8 flex gap-3">
            <a href="#" class="flex h-10 w-10 items-center justify-center rounded-full bg-white/15 dark:bg-slate-800/80 text-sm transition hover:bg-white/25 dark:hover:bg-slate-700/80">📘</a>
            <a href="#" class="flex h-10 w-10 items-center justify-center rounded-full bg-white/15 dark:bg-slate-800/80 text-sm transition hover:bg-white/25 dark:hover:bg-slate-700/80">📸</a>
            <a href="#" class="flex h-10 w-10 items-center justify-center rounded-full bg-white/15 dark:bg-slate-800/80 text-sm transition hover:bg-white/25 dark:hover:bg-slate-700/80">🐦</a>
            <a href="#" class="flex h-10 w-10 items-center justify-center rounded-full bg-white/15 dark:bg-slate-800/80 text-sm transition hover:bg-white/25 dark:hover:bg-slate-700/80">▶️</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

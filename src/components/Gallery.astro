---
const imagenes = [
  { src: '/images/hero/hero1.jpg', alt: 'Patio principal con decoraciones escolares', label: 'Nuestras Instalaciones' },
  { src: '/images/hero/hero2.jpg', alt: 'Estudiantes alineados en el patio cívico', label: 'Vida Estudiantil' },
  { src: '/images/hero/hero3.jpg', alt: 'Formación de estudiantes en actividades recreativas', label: 'Deportes y Recreación' },
  { src: '/images/hero/hero4.jpg', alt: 'Niños participando en proyectos y dinámicas escolares', label: 'Actividades Pedagógicas' },
  { src: '/images/hero/hero5.jpg', alt: 'Estudiantes en la capilla en actividades de fe', label: 'Formación en Valores' },
  { src: '/images/hero/hero6.jpg', alt: 'Estudiantes realizando actividades de escritura en el aula', label: 'Aulas y Aprendizaje' },
];
---

<section id="galeria" class="reveal-on-scroll section-padding bg-stone-50 dark:bg-[#140b37]">
  <div class="container-custom">
    <div class="mb-16 text-center">
      <span class="mb-3 inline-block rounded-full bg-primary/10 dark:bg-primary-light/20 px-4 py-1.5 text-xs font-semibold uppercase tracking-wider text-primary dark:text-primary-light">
        Galería
      </span>
      <h2 class="text-3xl font-bold text-gray-900 dark:text-white sm:text-4xl">
        Conoce <span class="text-primary dark:text-accent">nuestro</span> Colegio
      </h2>
      <div class="mx-auto mt-4 h-1 w-20 rounded-full bg-accent"></div>
    </div>

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {imagenes.map((img) => (
        <div class="group relative overflow-hidden rounded-2xl shadow-sm">
          <img
            src={img.src}
            alt={img.alt}
            class="h-72 w-full object-cover transition duration-500 group-hover:scale-110"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 transition group-hover:opacity-100">
            <div class="absolute bottom-0 left-0 right-0 p-6">
              <span class="text-sm font-semibold text-white">{img.label}</span>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

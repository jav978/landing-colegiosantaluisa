---
interface Props {
  currentPath: string;
  userNombre: string;
  userEmail: string;
  userRol: string;
}

const { currentPath, userNombre, userEmail, userRol } = Astro.props;

const links = [
  { href: '/admin/dashboard', label: 'Dashboard', icon: '📊' },
  { href: '/admin/posts', label: 'Posts', icon: '📝' },
  { href: '/admin/testimonios', label: 'Testimonios', icon: '💬' },
  { href: '/admin/mensajes', label: 'Mensajes', icon: '📥' },
  { href: '/admin/pre-inscripciones', label: 'Pre-inscripciones', icon: '📋' },
  { href: '/admin/usuarios', label: 'Usuarios', icon: '👥' },
  { href: '/admin/sesiones', label: 'Sesiones', icon: '🔐' },
];

function isActive(href: string) {
  return currentPath === href || currentPath.startsWith(href + '/');
}
---

<aside id="admin-sidebar" class="fixed inset-y-0 left-0 z-40 flex w-64 flex-col bg-gray-900 text-white max-md:-translate-x-full max-md:transition-transform">
  <div class="flex items-center gap-3 border-b border-gray-800 px-6 py-5">
    <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-accent text-sm font-bold">
      SL
    </div>
    <div>
      <p class="text-sm font-bold">Colegio Santa Luisa</p>
      <p class="text-xs text-gray-400">Panel Admin</p>
    </div>
  </div>

  <nav class="flex-1 space-y-1 px-3 py-4">
    {links.map((link) => (
      <a
        href={link.href}
        data-astro-prefetch
        class={`flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-medium transition ${
          isActive(link.href)
            ? 'bg-primary/20 text-primary-light'
            : 'text-gray-300 hover:bg-gray-800 hover:text-white'
        }`}
      >
        <span>{link.icon}</span>
        {link.label}
      </a>
    ))}
  </nav>

  <div class="border-t border-gray-800 px-6 py-4">
    <div class="flex items-center gap-3">
      <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-primary text-xs font-bold text-white">
        {userNombre.charAt(0).toUpperCase()}
      </div>
      <div class="min-w-0 flex-1">
        <p class="truncate text-sm font-medium text-white" title={userNombre}>{userNombre}</p>
        <p class="truncate text-xs text-gray-400" title={userEmail}>{userEmail}</p>
      </div>
      <form method="POST" action="/api/logout" class="shrink-0">
        <button type="submit" class="text-xs text-gray-400 transition hover:text-red-400" title="Cerrar sesión">
          ✕
        </button>
      </form>
    </div>
  </div>
</aside>

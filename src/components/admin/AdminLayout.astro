---
import '../../styles/global.css';
import Sidebar from './Sidebar.astro';

interface Props {
  title: string;
  userNombre: string;
  userEmail: string;
  userRol: string;
  currentPath: string;
}

const { title, userNombre, userEmail, userRol, currentPath } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <title>{title} — Admin Santa Luisa</title>
    <script is:inline>
      (() => {
        const theme = localStorage.getItem('theme') || 
          (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        if (theme === 'dark') {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.remove('dark');
        }
      })();
    </script>
  </head>
  <body class="flex min-h-screen bg-stone-100 font-sans antialiased transition-colors duration-300 dark:bg-gray-950 dark:text-gray-100">
    <div id="sidebar-backdrop" class="fixed inset-0 z-30 hidden bg-black/50 md:hidden"></div>

    <Sidebar {userNombre} {userEmail} {userRol} {currentPath} />

    <div class="flex flex-1 flex-col md:ml-64">
      <header class="sticky top-0 z-20 flex items-center justify-between border-b bg-white px-6 py-3 shadow-sm dark:bg-gray-900 dark:border-gray-800 transition-colors duration-300">
        <div class="flex items-center gap-3">
          <button id="mobile-sidebar-toggle" class="rounded-lg p-1.5 text-xl hover:bg-gray-100 md:hidden dark:text-gray-300 dark:hover:bg-gray-800">
            <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
          </button>
          <h1 class="text-lg font-semibold text-gray-900 dark:text-white">{title}</h1>
        </div>
        <div class="flex items-center gap-3">
          <button id="dark-mode-toggle" class="rounded-lg p-1.5 text-gray-500 hover:bg-gray-100 hover:text-gray-700 dark:text-gray-400 dark:hover:bg-gray-800 dark:hover:text-gray-200 transition cursor-pointer" title="Modo Oscuro">
            <!-- Sun icon -->
            <svg id="dark-mode-sun" class="h-5 w-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707m12.728 0l-.707-.707M6.343 6.343l-.707-.707M14 12a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
            <!-- Moon icon -->
            <svg id="dark-mode-moon" class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
            </svg>
          </button>
          <span class="rounded-full bg-primary/10 px-3 py-1 text-xs font-medium text-primary capitalize dark:bg-primary/20 dark:text-primary-light">{userRol}</span>
        </div>
      </header>

      <main class="flex-1 p-6">
        <slot />
      </main>
    </div>
  </body>
</html>

<script>
  const sidebar = document.getElementById('admin-sidebar');
  const toggleBtn = document.getElementById('mobile-sidebar-toggle');
  const backdrop = document.getElementById('sidebar-backdrop');
  
  // Dark mode elements
  const darkModeToggle = document.getElementById('dark-mode-toggle');
  const sunIcon = document.getElementById('dark-mode-sun');
  const moonIcon = document.getElementById('dark-mode-moon');

  function openSidebar() {
    if (!sidebar || !backdrop) return;
    sidebar.classList.remove('max-md:-translate-x-full');
    backdrop.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }

  function closeSidebar() {
    if (!sidebar || !backdrop) return;
    sidebar.classList.add('max-md:-translate-x-full');
    backdrop.classList.add('hidden');
    document.body.style.overflow = '';
  }

  function updateDarkModeToggle() {
    if (!sunIcon || !moonIcon) return;
    const isDark = document.documentElement.classList.contains('dark');
    if (isDark) {
      sunIcon.classList.remove('hidden');
      moonIcon.classList.add('hidden');
    } else {
      sunIcon.classList.add('hidden');
      moonIcon.classList.remove('hidden');
    }
  }

  // Initial UI state setup
  updateDarkModeToggle();

  if (darkModeToggle) {
    darkModeToggle.addEventListener('click', () => {
      const isDark = document.documentElement.classList.toggle('dark');
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
      updateDarkModeToggle();
    });
  }

  if (toggleBtn) {
    toggleBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      if (sidebar?.classList.contains('max-md:-translate-x-full')) {
        openSidebar();
      } else {
        closeSidebar();
      }
    });
  }

  if (backdrop) {
    backdrop.addEventListener('click', closeSidebar);
  }

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeSidebar();
  });

  sidebar?.addEventListener('click', (e) => {
    if (window.innerWidth < 768 && e.target?.tagName === 'A') {
      closeSidebar();
    }
  });

  // Re-run dark mode button check on view transition page loads
  document.addEventListener('astro:page-load', updateDarkModeToggle);
</script>

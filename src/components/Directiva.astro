                  <span class="inline-block rounded-full bg-primary/10 dark:bg-secondary/15 px-2.5 py-0.5 text-[10px] font-semibold text-primary dark:text-secondary mb-2">
                    {c.role}
                  </span>
                  <p class="text-xs text-gray-600 dark:text-slate-300 leading-relaxed">
                    {c.details}
                  </p>
                </div>
              </div>
            ))}
          </div>

          <div class="w-full h-px bg-slate-200 dark:bg-white/10 max-w-3xl my-2"></div>

          <!-- Academic Structure (Primaria, Media, Control Estudio) -->
          <div class="grid md:grid-cols-3 gap-6 w-full max-w-4xl">
            <!-- Educación Primaria -->
            <div class="bg-white dark:bg-[#1b1145] rounded-3xl border border-slate-100 dark:border-slate-800/80 p-6 shadow-sm">
              <h4 class="font-bold text-gray-900 dark:text-white mb-3 text-sm border-b border-slate-100 dark:border-white/10 pb-2">🎒 Nivel Primaria</h4>
              <ul class="space-y-2 text-xs text-gray-600 dark:text-gray-300">
                {primaryTeachers.map((t) => (
                  <li class="flex justify-between py-1 border-b border-slate-100 dark:border-white/5">
                    <span class="text-slate-500 dark:text-gray-400">{t.grade}:</span> 
                    <span class="font-semibold text-slate-900 dark:text-white">{t.names}</span>
                  </li>
                ))}
              </ul>
            </div>

            <!-- Control de Estudios -->
            <div class="bg-white dark:bg-[#1b1145] rounded-3xl border border-slate-100 dark:border-slate-800/80 p-6 shadow-sm flex flex-col justify-between">
              <div>
                <h4 class="font-bold text-gray-900 dark:text-white mb-3 text-sm border-b border-slate-100 dark:border-white/10 pb-2">📊 Control de Estudio</h4>
                <p class="text-xs text-gray-600 dark:text-gray-300 leading-relaxed mb-4">
                  Departamento encargado de la planificación, registro académico, expedientes estudiantiles, emisión de notas, títulos y enlace con el Ministerio de Educación.
                </p>
              </div>
              <div class="p-3 bg-primary/5 dark:bg-white/5 border border-primary/10 dark:border-white/5 rounded-2xl text-[10px] text-center text-primary dark:text-accent uppercase font-bold tracking-wider">
                Control e Historial Pedagógico
              </div>
            </div>

            <!-- Educación Media General -->
            <div class="bg-white dark:bg-[#1b1145] rounded-3xl border border-slate-100 dark:border-slate-800/80 p-6 shadow-sm">
              <h4 class="font-bold text-gray-900 dark:text-white mb-3 text-sm border-b border-slate-100 dark:border-white/10 pb-2">📚 Media General</h4>
              <ul class="space-y-2 text-xs text-gray-600 dark:text-gray-300">
                {mediaTeachers.map((t) => (
                  <li class="flex justify-between py-1 border-b border-slate-100 dark:border-white/5">
                    <span class="text-slate-500 dark:text-gray-400">{t.year}:</span> 
                    <span class="font-semibold text-slate-900 dark:text-white">{t.name}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>

        <!-- PANEL 3: Secretaría y Obreros -->
        <div id="panel-servicios" class="organigrama-panel hidden opacity-0 scale-95 transition-all duration-500 flex flex-col gap-8">
          <!-- Administración / Secretaría -->
          <div>
            <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-4 border-l-4 border-primary dark:border-secondary pl-3">💼 Administración y Secretaría</h3>
            <div class="grid sm:grid-cols-3 gap-6">
              {secretaries.map((s) => (
                <div class="bg-white dark:bg-[#1b1145] p-5 rounded-2xl border border-slate-100 dark:border-primary/10 shadow-sm flex items-center gap-3">
                  <span class="text-xl">📂</span>
                  <div>
                    <h4 class="font-bold text-gray-900 dark:text-slate-100 text-xs">{s.name}</h4>
                    <span class="text-[10px] font-semibold text-primary dark:text-secondary uppercase tracking-wider">{s.role}</span>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <!-- Recursos Humanos / Obreros -->
          <div>
            <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-4 border-l-4 border-primary dark:border-accent pl-3">🧹 Recursos Humanos y Obreros</h3>
            <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-4">
              {staffObreros.map((o) => (
                <div class="bg-white dark:bg-[#1b1145] p-4 rounded-xl border border-slate-100 dark:border-white/5 flex justify-between items-center shadow-sm">
                  <div>
                    <h4 class="font-semibold text-gray-900 dark:text-white text-xs">{o.name}</h4>
                    <p class="text-[10px] text-gray-500 dark:text-gray-400 italic mt-0.5">{o.role}</p>
                  </div>
                  <span class="text-xs px-2 py-0.5 rounded-full bg-primary/5 dark:bg-accent/10 text-primary dark:text-accent font-semibold">
                    {o.role === 'Mantenimiento' ? '🔧' : o.role === 'Portera' ? '🔑' : '✨'}
                  </span>
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- PANEL 4: Consejo Educativo -->
        <div id="panel-consejo" class="organigrama-panel hidden opacity-0 scale-95 transition-all duration-500 flex flex-col gap-6">
          <div class="text-center max-w-2xl mx-auto mb-4">
            <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-2">👥 Comités del Consejo Educativo</h3>
            <p class="text-xs text-gray-500 dark:text-gray-400">
              Órganos participativos de la comunidad que garantizan el bienestar integral, la contraloría, los proyectos de aprendizaje y la vinculación social de la institución.
            </p>
          </div>
          
          <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-6">
            {educationalCommittees.map((c) => (
              <div class="group relative bg-white dark:bg-[#1b1145] border border-slate-100 dark:border-white/5 hover:border-primary/20 dark:hover:border-accent/20 p-5 rounded-2xl shadow-sm transition duration-300 hover:-translate-y-0.5 flex gap-3">
                <span class="text-2xl h-10 w-10 shrink-0 flex items-center justify-center rounded-xl bg-slate-50 dark:bg-white/5 border border-slate-100 dark:border-white/10">{c.icon}</span>
                <div>
                  <h4 class="font-bold text-gray-900 dark:text-white text-xs mb-1.5 leading-snug group-hover:text-primary dark:group-hover:text-accent transition">{c.title}</h4>
                  <p class="text-[11px] text-gray-500 dark:text-gray-400 leading-normal">{c.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- PANEL 5: Bienestar Estudiantil -->
        <div id="panel-bienestar" class="organigrama-panel hidden opacity-0 scale-95 transition-all duration-500 flex flex-col gap-6">
          <div class="text-center max-w-2xl mx-auto mb-4">
            <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-2">🌱 Bienestar Familiar y Estudiantil</h3>
            <p class="text-xs text-gray-500 dark:text-gray-400">
              Departamentos y programas dedicados a brindar soporte socio-emocional, psicopedagógico y pastoral tanto a estudiantes como a sus familias.
            </p>
          </div>

          <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-6 justify-center">
            {welfareDepartments.map((w) => (
              <div class="group bg-white dark:bg-[#1b1145] border border-slate-100 dark:border-primary/10 p-6 rounded-3xl shadow-sm transition hover:shadow-md hover:border-primary/20 dark:hover:border-secondary/20 flex flex-col justify-between min-h-[160px]">
                <div>
                  <div class="flex items-center gap-3 mb-3">
                    <span class="text-xl flex h-10 w-10 items-center justify-center rounded-2xl bg-primary/5 dark:bg-secondary/10 text-primary dark:text-secondary border border-primary/10 dark:border-secondary/20">{w.icon}</span>
                    <h4 class="font-bold text-gray-900 dark:text-slate-100 text-xs">{w.title}</h4>
                  </div>
                  <p class="text-[11px] text-gray-600 dark:text-slate-300 leading-normal">{w.desc}</p>
                </div>
                <div class="text-[9px] uppercase font-semibold text-gray-400 dark:text-slate-500 tracking-wider text-right mt-4">
                  Soporte Integral
                </div>
              </div>
            ))}
          </div>
        </div>

      </div>
    </div>

  </div>
</section>

<style is:global>
  @keyframes pulse-glow {
    0%, 100% {
      box-shadow: 0 0 0 2px rgba(247, 195, 1, 0.4);
      border-color: #f7c301;
    }
    50% {
      box-shadow: 0 0 0 8px rgba(247, 195, 1, 0.8);
      border-color: #f7c301;
      transform: scale(1.03);
    }
  }
  .search-highlight {
    animation: pulse-glow 1.5s infinite !important;
    border-color: #f7c301 !important;
    z-index: 50 !important;
    position: relative;
  }
  
  /* Canvas dragging styling */
  #org-canvas-wrapper.active {
    cursor: grabbing;
  }

  /* Figma-like Grid Background */
  .org-grid-pattern {
    background-image: radial-gradient(rgba(148, 163, 184, 0.15) 1px, transparent 1px);
    background-size: 20px 20px;
  }
  
  :global(.dark) .org-grid-pattern {
    background-image: radial-gradient(rgba(247, 195, 1, 0.08) 1.2px, transparent 1.2px);
    background-size: 20px 20px;
  }

  /* Fullscreen styles */
  #org-canvas-wrapper.fullscreen-active {
    position: fixed !important;
    top: 0 !important;
    left: 0 !important;
    width: 100vw !important;
    height: 100vh !important;
    max-height: none !important;
    z-index: 9999 !important;
    background-color: #0c0527 !important;
    border-radius: 0 !important;
    padding: 2rem !important;
  }

  /* Lock scrolling when fullscreen organigrama is active */
  body.org-fullscreen-lock {
    overflow: hidden !important;
  }
</style>

<script>
  function setupOrganigrama() {
    // 1. Toggle View Mode (Diagram vs Tabs)
    const btnToggleDiagram = document.getElementById('btn-toggle-diagram');
    const btnToggleTabs = document.getElementById('btn-toggle-tabs');
    const viewDiagram = document.getElementById('view-diagram');
    const viewTabs = document.getElementById('view-tabs');

    if (btnToggleDiagram && btnToggleTabs && viewDiagram && viewTabs) {
      const activeClasses = ['bg-primary', 'text-white', 'dark:bg-accent', 'dark:text-primary', 'shadow-sm'];
      const inactiveClasses = ['text-gray-600', 'dark:text-slate-400', 'hover:text-primary', 'dark:hover:text-accent'];

      btnToggleDiagram.addEventListener('click', () => {
        // Switch buttons styling
        btnToggleDiagram.classList.remove(...inactiveClasses);
        btnToggleDiagram.classList.add(...activeClasses);
        
        btnToggleTabs.classList.remove(...activeClasses);
        btnToggleTabs.classList.add(...inactiveClasses);
        
        // Show/hide views
        viewDiagram.classList.remove('hidden');
        viewTabs.classList.add('hidden');

        // Recenter diagram when shown
        setTimeout(centerDiagram, 100);
      });

      btnToggleTabs.addEventListener('click', () => {
        // Switch buttons styling
        btnToggleTabs.classList.remove(...inactiveClasses);
        btnToggleTabs.classList.add(...activeClasses);
        
        btnToggleDiagram.classList.remove(...activeClasses);
        btnToggleDiagram.classList.add(...inactiveClasses);
        
        // Show/hide views
        viewTabs.classList.remove('hidden');
        viewDiagram.classList.add('hidden');
      });
    }

    // 2. Traditional Tabs panel switching
    const tabs = document.querySelectorAll('.organigrama-tab-btn');
    const panels = document.querySelectorAll('.organigrama-panel');

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const target = tab.getAttribute('data-target');

        tabs.forEach((t) => {
          t.classList.remove('bg-primary', 'text-white', 'border-primary', 'dark:bg-accent', 'dark:text-primary', 'dark:border-accent');
          t.classList.add('text-gray-600', 'dark:text-slate-400', 'hover:bg-gray-100', 'dark:hover:bg-slate-800', 'hover:text-primary', 'dark:hover:text-accent');
        });
        tab.classList.add('bg-primary', 'text-white', 'border-primary', 'dark:bg-accent', 'dark:text-primary', 'dark:border-accent');
        tab.classList.remove('text-gray-600', 'dark:text-slate-400', 'hover:bg-gray-100', 'dark:hover:bg-slate-800', 'hover:text-primary', 'dark:hover:text-accent');

        panels.forEach((panel) => {
          const panelId = panel.getAttribute('id');
          if (panelId === `panel-${target}`) {
            panel.classList.remove('hidden');
            setTimeout(() => {
              panel.classList.remove('opacity-0', 'scale-95');
              panel.classList.add('opacity-100', 'scale-100');
            }, 50);
          } else {
            panel.classList.remove('opacity-100', 'scale-100');
            panel.classList.add('opacity-0', 'scale-95');
            setTimeout(() => {
              panel.classList.add('hidden');
            }, 300);
          }
        });
      });
    });

    // 3. Collapsible Tree Branches
    const toggleBtns = document.querySelectorAll('.org-toggle-btn');
    toggleBtns.forEach((btn) => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        const branchId = btn.getAttribute('data-toggle');
        const branchContainer = document.getElementById(branchId);
        
        if (branchContainer) {
          if (branchContainer.style.display === 'none' || branchContainer.classList.contains('hidden') || branchContainer.classList.contains('collapsed')) {
            // Expand
            branchContainer.style.display = 'flex';
            branchContainer.classList.remove('hidden', 'collapsed');
            btn.textContent = '➖';
          } else {
            // Collapse
            branchContainer.style.display = 'none';
            branchContainer.classList.add('collapsed');
            btn.textContent = '➕';
          }
          // Readjust layout / centering slightly when branch triggers
          setTimeout(centerDiagram, 100);
        }
      });
    });

    // 4. Zoom and Pan (Drag-to-scroll) Controls
    let currentScale = 0.95;
    const treeContent = document.getElementById('org-tree-content');
    const canvasWrapper = document.getElementById('org-canvas-wrapper');
    const zoomIndicator = document.getElementById('zoom-indicator');

    function updateZoom() {
      if (treeContent) {
        treeContent.style.transform = `scale(${currentScale})`;
      }
      if (zoomIndicator) {
        zoomIndicator.textContent = `${Math.round(currentScale * 100)}%`;
      }
    }

    document.getElementById('zoom-in')?.addEventListener('click', () => {
      currentScale = Math.min(2.0, currentScale + 0.1);
      updateZoom();
    });

    document.getElementById('zoom-out')?.addEventListener('click', () => {
      currentScale = Math.max(0.4, currentScale - 0.1);
      updateZoom();
    });

    document.getElementById('zoom-reset')?.addEventListener('click', () => {
      currentScale = 0.95;
      updateZoom();
      centerDiagram();
    });

    // Centering tree content function
    function centerDiagram() {
      if (treeContent && canvasWrapper) {
        // Find dimensions and scroll to center horizontal
        canvasWrapper.scrollLeft = (treeContent.scrollWidth - canvasWrapper.clientWidth) / 2;
        canvasWrapper.scrollTop = 0;
      }
    }

    // Fullscreen Toggler
    const fullscreenBtn = document.getElementById('fullscreen-btn');
    const fullscreenSvg = document.getElementById('fullscreen-svg');
    
    function toggleFullscreenMode() {
      if (!canvasWrapper) return;
      
      const isFullscreen = canvasWrapper.classList.contains('fullscreen-active');
      
      if (!isFullscreen) {
        // Enter fullscreen
        canvasWrapper.classList.add('fullscreen-active');
        document.body.classList.add('org-fullscreen-lock');
        if (fullscreenBtn) {
          fullscreenBtn.title = 'Salir de Pantalla Completa';
        }
        if (fullscreenSvg) {
          // Exit Fullscreen SVG icon path
          fullscreenSvg.innerHTML = `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 14h6v6m10-6h-6v6M4 20l6-6m10 6l-6-6" />`;
        }
        
        // Attempt browser native Fullscreen API for immersive experience
        try {
          if (canvasWrapper.requestFullscreen) {
            canvasWrapper.requestFullscreen();
          }
        } catch (err) {
          console.warn('Native fullscreen not supported or blocked:', err);
        }
      } else {
        // Exit fullscreen
        canvasWrapper.classList.remove('fullscreen-active');
        document.body.classList.remove('org-fullscreen-lock');
        if (fullscreenBtn) {
          fullscreenBtn.title = 'Pantalla Completa';
        }
        if (fullscreenSvg) {
          // Enter Fullscreen SVG icon path
          fullscreenSvg.innerHTML = `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7" />`;
        }
        
        try {
          if (document.exitFullscreen && document.fullscreenElement) {
            document.exitFullscreen();
          }
        } catch (err) {
          console.warn('Error exiting native fullscreen:', err);
        }
      }
      
      setTimeout(centerDiagram, 150);
    }

    fullscreenBtn?.addEventListener('click', toggleFullscreenMode);

    // Sync state if user exits native fullscreen via Esc key
    document.addEventListener('fullscreenchange', () => {
      if (canvasWrapper && !document.fullscreenElement && canvasWrapper.classList.contains('fullscreen-active')) {
        canvasWrapper.classList.remove('fullscreen-active');
        document.body.classList.remove('org-fullscreen-lock');
        if (fullscreenBtn) {
          fullscreenBtn.title = 'Pantalla Completa';
        }
        if (fullscreenSvg) {
          fullscreenSvg.innerHTML = `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7" />`;
        }
        setTimeout(centerDiagram, 150);
      }
    });

    // Panning & Drag-to-scroll implementation (Mouse)
    if (canvasWrapper) {
      let isDown = false;
      let startX = 0;
      let startY = 0;
      let scrollLeft = 0;
      let scrollTop = 0;

      canvasWrapper.addEventListener('mousedown', (e) => {
        const targetElement = e.target as HTMLElement;
        if (targetElement.closest('.org-card') || targetElement.closest('button') || targetElement.closest('input')) return;
        isDown = true;
        canvasWrapper.classList.add('active');
        startX = e.pageX - canvasWrapper.offsetLeft;
        startY = e.pageY - canvasWrapper.offsetTop;
        scrollLeft = canvasWrapper.scrollLeft;
        scrollTop = canvasWrapper.scrollTop;
      });

      canvasWrapper.addEventListener('mouseleave', () => {
        isDown = false;
        canvasWrapper.classList.remove('active');
      });

      canvasWrapper.addEventListener('mouseup', () => {
        isDown = false;
        canvasWrapper.classList.remove('active');
      });

      canvasWrapper.addEventListener('mousemove', (e) => {
        if (!isDown) return;
        e.preventDefault();
        const x = e.pageX - canvasWrapper.offsetLeft;
        const y = e.pageY - canvasWrapper.offsetTop;
        const walkX = (x - startX) * 1.5;
        const walkY = (y - startY) * 1.5;
        canvasWrapper.scrollLeft = scrollLeft - walkX;
        canvasWrapper.scrollTop = scrollTop - walkY;
      });

      // Panning & Drag-to-scroll implementation (Touch / Mobile)
      canvasWrapper.addEventListener('touchstart', (e) => {
        if (e.touches.length !== 1) return; // Only allow single-finger panning
        const targetElement = e.target as HTMLElement;
        if (targetElement.closest('.org-card') || targetElement.closest('button') || targetElement.closest('input')) return;
        isDown = true;
        canvasWrapper.classList.add('active');
        const touch = e.touches[0];
        startX = touch.pageX - canvasWrapper.offsetLeft;
        startY = touch.pageY - canvasWrapper.offsetTop;
        scrollLeft = canvasWrapper.scrollLeft;
        scrollTop = canvasWrapper.scrollTop;
      });

      canvasWrapper.addEventListener('touchend', () => {
        isDown = false;
        canvasWrapper.classList.remove('active');
      });

      canvasWrapper.addEventListener('touchmove', (e) => {
        if (!isDown || e.touches.length !== 1) return;
        const touch = e.touches[0];
        const x = touch.pageX - canvasWrapper.offsetLeft;
        const y = touch.pageY - canvasWrapper.offsetTop;
        const walkX = (x - startX) * 1.5;
        const walkY = (y - startY) * 1.5;
        canvasWrapper.scrollLeft = scrollLeft - walkX;
        canvasWrapper.scrollTop = scrollTop - walkY;
        
        // Prevent default touch dragging to stop window scroll
        e.preventDefault();
      }, { passive: false });

      // Figma-like Mouse Wheel Zoom (Ctrl + Wheel)
      canvasWrapper.addEventListener('wheel', (e) => {
        if (e.ctrlKey) {
          e.preventDefault();
          const zoomFactor = 0.05;
          if (e.deltaY < 0) {
            currentScale = Math.min(2.0, currentScale + zoomFactor);
          } else {
            currentScale = Math.max(0.4, currentScale - zoomFactor);
          }
          updateZoom();
        }
      }, { passive: false });
    }

    // Centering tree content initially & on Window Resize
    setTimeout(centerDiagram, 150);
    window.addEventListener('resize', centerDiagram);

    // 5. Search Bar Functionality
    const searchInput = document.getElementById('org-search-input') as HTMLInputElement;
    const searchClear = document.getElementById('org-search-clear');
    const searchResults = document.getElementById('org-search-results');

    if (searchInput && searchResults) {
      searchInput.addEventListener('input', () => {
        const query = searchInput.value.toLowerCase().trim();
        
        // Toggle Clear button visibility
        if (searchClear) {
          if (query.length > 0) {
            searchClear.classList.remove('hidden');
          } else {
            searchClear.classList.add('hidden');
          }
        }

        // Clear existing highlights
        document.querySelectorAll('.search-highlight').forEach((card) => {
          card.classList.remove('search-highlight');
        });

        if (query === '') {
          searchResults.classList.add('hidden');
          return;
        }

        const cards = document.querySelectorAll('.org-card');
        const matches: Element[] = [];

        cards.forEach((card) => {
          const name = card.getAttribute('data-name')?.toLowerCase() || '';
          const role = card.getAttribute('data-role')?.toLowerCase() || '';

          if (name.includes(query) || role.includes(query)) {
            card.classList.add('search-highlight');
            matches.push(card);

            // Traverse up and expand all collapsed parent branches
            let parent = card.parentElement;
            while (parent) {
              if (parent.classList.contains('org-branch-container')) {
                if (parent.classList.contains('collapsed') || parent.style.display === 'none') {
                  parent.style.display = 'flex';
                  parent.classList.remove('collapsed', 'hidden');
                  
                  const branchId = parent.id;
                  const toggleBtn = document.querySelector(`[data-toggle="${branchId}"]`);
                  if (toggleBtn) {
                    toggleBtn.textContent = '➖';
                  }
                }
              }
              parent = parent.parentElement;
            }
          }
        });

        // Show search results count
        searchResults.classList.remove('hidden');
        if (matches.length > 0) {
          searchResults.textContent = `${matches.length} coincidencia(s) encontrada(s)`;
          searchResults.className = 'text-xs font-semibold text-accent';
          
          // Scroll first match into view
          const firstMatch = matches[0] as HTMLElement;
          firstMatch.scrollIntoView({ behavior: 'smooth', block: 'center', inline: 'center' });
        } else {
          searchResults.textContent = 'No se encontraron coincidencias';
          searchResults.className = 'text-xs font-semibold text-red-500 dark:text-rose-400';
        }
      });

      // Clear search button behavior
      searchClear?.addEventListener('click', () => {
        searchInput.value = '';
        searchClear.classList.add('hidden');
        searchResults.classList.add('hidden');
        document.querySelectorAll('.search-highlight').forEach((card) => {
          card.classList.remove('search-highlight');
        });
      });
    }
  }

  // Initialize on Astro load
  document.addEventListener('astro:page-load', setupOrganigrama);
</script>



  { year: 'Inglés (1er a 5to Año)', name: 'Humberto Bisuela' },
  { year: 'Computación y Orientación (1er Año)', name: 'José Vásquez' },
  { year: 'Computación (1er a 5to Año)', name: 'José Vásquez' },

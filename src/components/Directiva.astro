---

<section id="directiva" class="reveal-on-scroll section-padding bg-gradient-to-b from-stone-50 to-white dark:from-[#140b37] dark:to-[#0e072c] overflow-hidden">
  <div class="container-custom">
    <!-- Header Title -->
    <div class="mb-12 text-center">
      <span class="mb-3 inline-block rounded-full bg-accent/10 px-4 py-1.5 text-xs font-semibold uppercase tracking-wider text-accent">
        Organización Oficial
      </span>
      <h2 class="text-3xl font-bold text-gray-900 dark:text-white sm:text-4xl">
        Organigrama y <span class="text-primary dark:text-accent">Estructura</span> Institucional
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-gray-600 dark:text-slate-300">
        Conoce la estructura organizativa de la U.E. Colegio Santa Luisa e interactúa con el diagrama oficial.
      </p>
      <div class="mx-auto mt-4 h-1 w-20 rounded-full bg-accent"></div>
      
      <!-- PDF Download and PDF View Button -->
      <div class="mt-6 flex flex-wrap justify-center gap-3">
        <a 
          href="/docs/Organigrama 2.pdf" 
          download="Organigrama_Colegio_Santa_Luisa.pdf"
          class="inline-flex items-center gap-2 rounded-full bg-primary hover:bg-primary-light text-white dark:bg-accent dark:hover:bg-accent-light dark:text-primary px-6 py-2.5 text-xs font-bold transition-all duration-300 hover:shadow-lg hover:-translate-y-0.5"
        >
          <span>📥</span> Descargar Organigrama Oficial (PDF)
        </a>
      </div>
    </div>

    <!-- Search Bar & Toggle View Mode -->
    <div class="mb-10 max-w-5xl mx-auto flex flex-col md:flex-row items-center justify-between gap-6 bg-white dark:bg-[#1b1145]/30 p-4 rounded-3xl border border-slate-200/60 dark:border-white/5 shadow-sm">
      <!-- Search Input -->
      <div class="relative w-full md:max-w-md">
        <span class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400">🔍</span>
        <input 
          type="text" 
          id="org-search-input"
          placeholder="Buscar por nombre o cargo..." 
          class="w-full pl-10 pr-10 py-2.5 bg-slate-50 dark:bg-[#0c0527] border border-slate-200/10 dark:border-white/10 rounded-2xl text-xs font-medium text-gray-955 dark:text-white placeholder-gray-400 focus:outline-none focus:border-accent dark:focus:border-accent transition duration-300"
        />
        <button 
          id="org-search-clear" 
          class="absolute right-4 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600 dark:hover:text-white hidden"
        >
          ✖
        </button>
      </div>
      
      <!-- Search Results Count -->
      <div id="org-search-results" class="text-xs font-semibold text-accent hidden"></div>

      <!-- Toggle View -->
      <div class="bg-slate-100 dark:bg-[#0c0527] border border-slate-200 dark:border-white/10 rounded-2xl p-1 flex gap-1 shadow-inner shrink-0">
        <button 
          id="btn-toggle-diagram" 
          class="px-2.5 py-1.5 sm:px-4 sm:py-2 rounded-xl text-[10px] sm:text-xs font-bold uppercase tracking-wider transition-all duration-300 bg-primary text-white dark:bg-accent dark:text-primary shadow-sm cursor-pointer"
          data-view="diagram"
        >
          🗺️ Mapa Organigrama
        </button>
        <button 
          id="btn-toggle-tabs" 
          class="px-2.5 py-1.5 sm:px-4 sm:py-2 rounded-xl text-[10px] sm:text-xs font-bold uppercase tracking-wider transition-all duration-300 text-gray-600 dark:text-slate-400 hover:text-primary dark:hover:text-accent cursor-pointer"
          data-view="tabs"
        >
          🗂️ Vista de Fichas
        </button>
      </div>
    </div>

    <!-- VIEW 1: Interactive Canvas Diagram -->
    <div id="view-diagram" class="w-full max-w-5xl mx-auto">
      <div 
        id="org-canvas-wrapper" 
        class="relative w-full overflow-auto border border-slate-200 dark:border-white/10 rounded-3xl bg-slate-50/50 dark:bg-[#0c0527] org-grid-pattern shadow-inner p-4 md:p-8 cursor-grab active:cursor-grabbing select-none h-[60vh] md:h-[70vh] min-h-[500px] max-h-[800px] scrollbar-thin transition-all duration-300"
      >
        <!-- Canvas Floating Controls -->
        <div class="absolute bottom-6 right-6 z-30 flex items-center gap-1.5 bg-white/90 dark:bg-[#1b1145]/90 border border-slate-200 dark:border-white/10 p-1.5 rounded-2xl shadow-xl backdrop-blur-md">
          <span 
            id="zoom-indicator" 
            class="px-2 text-[10px] font-extrabold text-gray-700 dark:text-slate-300 min-w-[42px] text-center select-none tracking-tight"
          >
            95%
          </span>
          <div class="h-4 w-px bg-slate-200 dark:bg-white/10 mx-0.5"></div>
          <button 
            id="zoom-out" 
            class="flex h-9 w-9 items-center justify-center rounded-xl text-gray-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-primary hover:text-primary dark:hover:text-accent transition duration-200 cursor-pointer" 
            title="Alejar"
          >
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M20 12H4" />
            </svg>
          </button>
          <button 
            id="zoom-in" 
            class="flex h-9 w-9 items-center justify-center rounded-xl text-gray-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-primary hover:text-primary dark:hover:text-accent transition duration-200 cursor-pointer" 
            title="Acercar"
          >
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4" />
            </svg>
          </button>
          <button 
            id="zoom-reset" 
            class="flex h-9 w-9 items-center justify-center rounded-xl text-gray-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-primary hover:text-primary dark:hover:text-accent transition duration-200 cursor-pointer" 
            title="Centrar y Ajustar"
          >
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 1121.21 7.89M9 11l3-3 3 3m-3-3v12" />
            </svg>
          </button>
          <button 
            id="fullscreen-btn" 
            class="flex h-9 w-9 items-center justify-center rounded-xl text-gray-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-primary hover:text-primary dark:hover:text-accent transition duration-200 cursor-pointer" 
            title="Pantalla Completa"
          >
            <svg id="fullscreen-svg" class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7" />
            </svg>
          </button>
        </div>

        <!-- Scroll instruction for mobile -->
        <div class="absolute top-4 left-4 z-20 pointer-events-none md:hidden bg-slate-900/60 text-white text-[10px] px-2.5 py-1 rounded-full backdrop-blur-xs">
          👈 Arrastra para explorar 👉
        </div>

        <!-- Diagram Content Tree -->
        <div id="org-tree-content" class="origin-top transition-transform duration-300 ease-out flex flex-col items-center pb-12" style="transform: scale(0.95);">
          
          <!-- Tree Level 0: Ministerio -->
          <div data-role="Ministerio del Poder Popular para la Educación" class="org-card select-none flex flex-col items-center justify-center p-3 rounded-2xl bg-white/95 dark:bg-[#1b1145]/90 border border-slate-200 dark:border-white/10 shadow-sm text-center text-[10px] font-extrabold text-gray-700 dark:text-slate-300 w-64 transition duration-300 hover:border-primary/40 dark:hover:border-accent/40">
            <span>MINISTERIO DEL PODER POPULAR PARA LA EDUCACIÓN</span>
            <div class="text-[9px] text-primary dark:text-accent font-semibold mt-0.5">Zona / Circuito</div>
          </div>
          
          <!-- Line 0 to 1 -->
          <div class="w-0.5 h-6 bg-slate-300 dark:bg-white/10"></div>
          
          <!-- Tree Level 1: AVEC -->
          <div data-role="AVEC" class="org-card select-none py-1.5 px-6 rounded-full bg-primary text-white dark:bg-accent dark:text-primary text-[10px] font-black tracking-widest shadow-md text-center transition duration-300 hover:scale-105">
            AVEC
          </div>
          
          <!-- Line 1 to 2 -->
          <div class="w-0.5 h-6 bg-slate-300 dark:bg-white/10"></div>
          
          <!-- Tree Level 2: Dirección & Hermanas -->
          <div class="relative flex items-center justify-center">
            <!-- Main Dirección Card -->
            <div data-name={leadershipLevel1.name} data-role={leadershipLevel1.role} class="org-card group relative bg-white/95 dark:bg-[#1b1145]/90 rounded-3xl border-2 border-primary dark:border-accent p-4 shadow-xl w-72 text-center transition duration-300 hover:-translate-y-0.5 hover:shadow-2xl z-10">
              <div class="mx-auto mb-2.5 h-16 w-16 overflow-hidden rounded-full border-2 border-primary dark:border-accent shadow-sm relative">
                <img src={leadershipLevel1.image} alt={leadershipLevel1.name} class="h-full w-full object-cover transition duration-300 group-hover:scale-105" />
              </div>
              <h3 class="text-sm font-bold text-gray-900 dark:text-slate-100">{leadershipLevel1.name}</h3>
              <span class="inline-block rounded-full bg-primary/10 dark:bg-accent/15 px-2.5 py-0.5 text-[10px] font-semibold text-primary dark:text-accent mb-1.5">
                {leadershipLevel1.role}
              </span>
              <p class="text-[10px] text-gray-600 dark:text-slate-300 leading-relaxed">
                {leadershipLevel1.details}
              </p>
            </div>
            
            <!-- Side Line to Hermanas de la Caridad -->
            <div class="w-8 h-0.5 bg-slate-300 dark:bg-white/10 z-0"></div>
            
            <!-- Side Card: Hermanas de la Caridad -->
            <div data-role="Hermanas de la Caridad" class="org-card select-none px-4 py-3 bg-pink-500/10 border border-pink-500/20 dark:border-pink-500/30 rounded-2xl text-[10px] text-pink-600 dark:text-pink-400 font-bold shadow-md w-40 text-center transition duration-300 hover:scale-102">
              ⛪ Hermanas de la Caridad
            </div>
          </div>
          
          <!-- Central Line 2 to 3 -->
          <div class="w-0.5 h-8 bg-slate-300 dark:bg-white/10"></div>
          
          <!-- Tree Level 3: Horizontal Branching (Obreros, Consejo Directivo, Secretaria) -->
          <div class="relative flex justify-center items-start gap-12 pt-8 w-full">
            <!-- Horizontal connector line -->
            <div class="absolute top-0 h-0.5 bg-slate-300 dark:bg-white/10" style="left: 16.6%; right: 16.6%;"></div>
            
            <!-- BRANCH 1: Recursos Humanos & Obreros (Left) -->
            <div class="relative flex flex-col items-center w-60">
              <div class="w-0.5 h-8 bg-slate-300 dark:bg-white/10 absolute -top-8"></div>
              
              <!-- Recursos Humanos label -->
              <div data-role="Recursos Humanos" class="org-card px-4 py-1.5 bg-slate-100 dark:bg-white/5 border border-slate-200 dark:border-white/10 rounded-xl text-[10px] font-bold text-gray-600 dark:text-gray-300 tracking-wider shadow-xs w-44 text-center">
                👥 Recursos Humanos
              </div>
              <div class="w-0.5 h-6 bg-slate-300 dark:bg-white/10"></div>
              
              <!-- Obreros Node -->
              <div data-role="Obreros" class="org-card relative group bg-white/95 dark:bg-[#1b1145]/90 rounded-2xl border border-slate-200 dark:border-slate-800 p-3 shadow-md w-44 text-center z-10">
                <h4 class="text-xs font-bold text-gray-900 dark:text-slate-100">🧹 Obreros</h4>
                <button data-toggle="obreros-branch" class="org-toggle-btn absolute -bottom-3 left-1/2 -translate-x-1/2 bg-white dark:bg-[#1c1247] border border-slate-200 dark:border-white/10 rounded-full w-6 h-6 flex items-center justify-center text-[10px] font-bold shadow-md hover:bg-slate-100 dark:hover:bg-primary z-20 cursor-pointer">➖</button>
              </div>
              
              <!-- Obreros Collapsible Branch -->
              <div id="obreros-branch" class="org-branch-container flex flex-col items-center w-full transition-all duration-300">
                <div class="w-0.5 h-6 bg-slate-300 dark:bg-white/10"></div>
                <div class="flex flex-col gap-1.5 bg-slate-100/50 dark:bg-white/5 p-2 rounded-2xl border border-slate-200/50 dark:border-white/5 w-48 shadow-inner">
                  {staffObreros.map((o) => (
                    <div data-name={o.name} data-role={o.role} class="org-card bg-white dark:bg-[#1b1145] p-2 rounded-xl border border-slate-200/50 dark:border-white/5 shadow-xs text-left transition duration-200 hover:-translate-y-0.5">
                      <div class="font-bold text-gray-900 dark:text-white text-[10px] leading-tight">{o.name}</div>
                      <div class="text-[8px] text-slate-500 dark:text-slate-400 font-semibold leading-normal flex items-center justify-between">
                        <span>{o.role}</span>
                        <span>{o.role === 'Mantenimiento' ? '🔧' : o.role === 'Portera' ? '🔑' : '✨'}</span>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            </div>
            
            <!-- BRANCH 2: Consejo Directivo (Center) -->
            <div class="relative flex flex-col items-center">
              <div class="w-0.5 h-8 bg-slate-300 dark:bg-white/10 absolute -top-8"></div>
              
              <!-- Consejo Directivo Node -->
              <div data-name="Consejo Directivo" data-role="Consejo Directivo" class="org-card bg-white/95 dark:bg-[#1b1145]/90 rounded-2xl border border-primary-light/50 dark:border-secondary/50 p-4 shadow-lg w-72 text-center transition duration-300 hover:shadow-xl">
                <h4 class="text-xs font-bold text-primary dark:text-secondary uppercase tracking-widest mb-1 flex items-center justify-center gap-1.5">🤝 Consejo Directivo</h4>
                <p class="text-[9px] text-gray-500 dark:text-slate-300 leading-normal">
                  Órgano de co-dirección colegiada para las decisiones académicas, organizativas y de valores.
                </p>
              </div>
              
              <!-- Line from CD down -->
              <div class="w-0.5 h-8 bg-slate-300 dark:bg-white/10"></div>
              
              <!-- Sub-Branching under Consejo Directivo (Sustanciación, Academics & Formación, Consejo Educativo) -->
              <div class="relative flex justify-center items-start gap-8 pt-8 w-full">
                <!-- CD Horizontal line -->
                <div class="absolute top-0 h-0.5 bg-slate-300 dark:bg-white/10" style="left: 16.6%; right: 16.6%;"></div>
                
                <!-- CD Sub-branch 1: Sustanciación (Left) -->
                <div class="relative flex flex-col items-center">
                  <div class="w-0.5 h-8 bg-slate-300 dark:bg-white/10 absolute -top-8"></div>
                  <div data-role="Sustanciación y Registro" class="org-card px-4 py-2 bg-slate-100 dark:bg-white/5 border border-slate-200 dark:border-white/10 rounded-xl text-[10px] font-bold text-slate-700 dark:text-slate-300 shadow-xs w-44 text-center">
                    📝 Sustanciación y Registro
                  </div>
                </div>
                
                <!-- CD Sub-branch 2: Academics, Formación & Bienestar (Center) -->
                <div class="relative flex flex-col items-center">
                  <div class="w-0.5 h-8 bg-slate-300 dark:bg-white/10 absolute -top-8"></div>
                  
                  <!-- Coordinación Academia and Coordinación Formación side-by-side -->
                  <div class="relative flex justify-center items-start gap-8">
                    
                    <!-- Academics (Left) -->
                    <div class="relative flex flex-col items-center">
                      <div data-role="Coordinación Academia" class="org-card relative group bg-white/95 dark:bg-[#1b1145]/90 rounded-2xl border border-slate-200 dark:border-slate-800 p-3 shadow-md w-56 text-center z-10">
                        <h4 class="text-xs font-bold text-gray-900 dark:text-slate-100 flex items-center justify-center gap-1.5">📖 Coordinación Academia</h4>
                        <button data-toggle="academia-branch" class="org-toggle-btn absolute -bottom-3 left-1/2 -translate-x-1/2 bg-white dark:bg-[#1c1247] border border-slate-200 dark:border-white/10 rounded-full w-6 h-6 flex items-center justify-center text-[10px] font-bold shadow-md hover:bg-slate-100 dark:hover:bg-primary z-20 cursor-pointer">➖</button>
                      </div>
                      

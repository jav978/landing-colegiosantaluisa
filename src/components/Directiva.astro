  { year: 'Matemáticas y Física (4to y 5to Año)', name: 'Kelvin Tábata' },
  { year: 'GHC y Soberanía (4to y 5to Año)', name: 'Anele Palacios' },
  { year: 'Coordinador y Educ. Física (4to y 5to Año)', name: 'Jorge Hernández' },
  { year: 'GHC y Arte y Patrimonio (1er a 3er Año)', name: 'Geydis Freira' },
  { year: 'Castellano (1er a 3er Año)', name: 'Ilenia Pasero' },

---
interface BoardMember {
  name: string;
  role: string;
  image?: string;
  details?: string;
}

const leadershipLevel1: BoardMember = {
  name: 'Sor Rosario Daza',
  role: 'Directora General',
  image: '/images/staff/director.png',
  details: 'Representante de la Congregación de las Hijas de la Caridad y responsable de la gestión general y pastoral del plantel.'
};

const leadershipLevel2: BoardMember = {
  name: 'Prof. Carmen Silva',
  role: 'Subdirectora Académica',
  image: '/images/staff/teacher_2.png',
  details: 'Supervisora de la planificación pedagógica, calidad académica y desarrollo docente del colegio.'
};

const coordinators: BoardMember[] = [
  {
    name: 'Prof. María Bompart',
    role: 'Coordinadora de Primaria',
    image: '/images/staff/teacher_1.png',
    details: 'Responsable del acompañamiento pedagógico e institucional de Educación Inicial y Primaria.'
  },
  {
    name: 'Prof. Ivonne Palacios',
    role: 'Coordinadora de Media General',
    image: '/images/staff/teacher_1.png',
    details: 'Responsable del acompañamiento académico, conductual y pastoral de Educación Media General (1° a 5° Año).'
  }
];

const secretaries: BoardMember[] = [
  { name: 'Mariángel Gómez', role: 'Secretaria' },
  { name: 'Karla Gómez', role: 'Secretaria' },
  { name: 'Dayana Isarra', role: 'Secretaria' }
];

const staffObreros = [
  { name: 'Ramon Martínez', role: 'Mantenimiento' },
  { name: 'Mirbelys Guerrero', role: 'Portera' },
  { name: 'Maryoris Ávila', role: 'Obrera' },
  { name: 'Margarita Gudiño', role: 'Obrera' },
  { name: 'Jenifer Jiménez', role: 'Obrera' },
  { name: 'Virginia Olivero', role: 'Obrera' },
  { name: 'Yeidi Izarra', role: 'Obrera' },
  { name: 'Anibeth Suarez', role: 'Obrera' },
  { name: 'Yasmira Mondragon', role: 'Obrera' }
];

const educationalCommittees = [
  { title: 'Movimiento Bolivariano de Familia (MBF)', icon: '👨‍👩‍👧‍👦', desc: 'Promueve la participación protagónica de las familias en la gestión escolar.' },
  { title: 'Comité de Deporte y Educación Física', icon: '⚽', desc: 'Fomenta las actividades recreativas, deportivas y la salud física de los alumnos.' },
  { title: 'Comité de Cultura', icon: '🎭', desc: 'Impulsa las expresiones artísticas, tradiciones folclóricas y celebraciones escolares.' },
  { title: 'Comité de Infraestructura', icon: '🏗️', desc: 'Supervisa y apoya en el mantenimiento y mejoras físicas de la planta del colegio.' },
  { title: 'Comité de Comunicación e Información', icon: '📢', desc: 'Gestiona la difusión de actividades, carteleras y la información interna/externa.' },
  { title: 'Comité de Ambiente y Salud', icon: '🌱', desc: 'Desarrolla proyectos de ecología, reciclaje, higiene y prevención médica.' },
  { title: 'Comité Académico', icon: '📖', desc: 'Apoya el rendimiento escolar, la planificación pedagógica y proyectos formativos.' },
  { title: 'Comité de Finanzas', icon: '💳', desc: 'Colabora en la administración, transparencia y presupuesto de recursos escolares.' },
  { title: 'Comité de Contraloría', icon: '🔍', desc: 'Vela por el correcto uso de los bienes, materiales y recursos institucionales.' },
  { title: 'Comité de Pastoral', icon: '⛪', desc: 'Coordina acciones litúrgicas, misiones de caridad y formación vicenciana familiar.' }
];

const welfareDepartments = [
  { title: 'Psicóloga', icon: '🧠', desc: 'Atención psicoeducativa y acompañamiento emocional para estudiantes y representantes.' },
  { title: 'Escuela para Padres', icon: '👪', desc: 'Espacio de formación, talleres y orientación para el núcleo familiar.' },
  { title: 'Biblioteca', icon: '📚', desc: 'Fomento a la lectura, investigación y apoyo bibliográfico escolar.' },
  { title: 'Orientación', icon: '🧭', desc: 'Guía vocacional, conductual y de desarrollo personal para adolescentes.' },
  { title: 'Inclusión', icon: '🤝', desc: 'Adecuaciones y programas de apoyo para alumnos con necesidades especiales.' }
];
---

<section id="directiva" class="reveal-on-scroll section-padding bg-gradient-to-b from-stone-50 to-white dark:from-[#140b37] dark:to-[#0e072c] overflow-hidden">
  <div class="container-custom">
    <div class="mb-16 text-center">
      <span class="mb-3 inline-block rounded-full bg-accent/10 px-4 py-1.5 text-xs font-semibold uppercase tracking-wider text-accent">
        Organización Oficial
      </span>
      <h2 class="text-3xl font-bold text-gray-900 dark:text-white sm:text-4xl">
        Organigrama e <span class="text-primary dark:text-accent">Estructura</span> Institucional
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-gray-600 dark:text-slate-300">
        Conoce la estructura organizativa de la U.E. Colegio Santa Luisa y descarga el documento oficial.
      </p>
      <div class="mx-auto mt-4 h-1 w-20 rounded-full bg-accent"></div>
      
      <!-- PDF Download Button -->
      <div class="mt-6">
        <a 
          href="/docs/Organigrama 2.pdf" 
          download="Organigrama_Colegio_Santa_Luisa.pdf"
          class="inline-flex items-center gap-2 rounded-full bg-primary hover:bg-primary-light text-white dark:bg-accent dark:hover:bg-accent-light dark:text-primary px-6 py-2.5 text-xs font-bold transition-all duration-300 hover:shadow-lg hover:-translate-y-0.5"
        >
          <span>📥</span> Descargar Organigrama Oficial (PDF)
        </a>
      </div>
    </div>

    <!-- Interactive Organigrama Tabs Selector -->
    <div class="mb-12 flex justify-center flex-wrap gap-2 max-w-5xl mx-auto">
      <button
        class="organigrama-tab-btn px-4 py-2.5 rounded-xl text-xs font-semibold uppercase tracking-wider border border-primary dark:border-accent transition-all duration-300 bg-primary text-white dark:bg-accent dark:text-primary"
        data-target="leadership"
      >
        👑 Dirección y Consejo
      </button>
      <button
        class="organigrama-tab-btn px-4 py-2.5 rounded-xl text-xs font-semibold uppercase tracking-wider border border-gray-200 dark:border-slate-800 transition-all duration-300 text-gray-600 dark:text-slate-400 hover:bg-gray-100 dark:hover:bg-slate-800 hover:text-primary dark:hover:text-accent"
        data-target="academia"
      >
        📖 Coordinación y Academia
      </button>
      <button
        class="organigrama-tab-btn px-4 py-2.5 rounded-xl text-xs font-semibold uppercase tracking-wider border border-gray-200 dark:border-slate-800 transition-all duration-300 text-gray-600 dark:text-slate-400 hover:bg-gray-100 dark:hover:bg-slate-800 hover:text-primary dark:hover:text-accent"
        data-target="servicios"
      >
        💼 Secretaría y Obreros
      </button>
      <button
        class="organigrama-tab-btn px-4 py-2.5 rounded-xl text-xs font-semibold uppercase tracking-wider border border-gray-200 dark:border-slate-800 transition-all duration-300 text-gray-600 dark:text-slate-400 hover:bg-gray-100 dark:hover:bg-slate-800 hover:text-primary dark:hover:text-accent"
        data-target="consejo"
      >
        👥 Consejo Educativo
      </button>
      <button
        class="organigrama-tab-btn px-4 py-2.5 rounded-xl text-xs font-semibold uppercase tracking-wider border border-gray-200 dark:border-slate-800 transition-all duration-300 text-gray-600 dark:text-slate-400 hover:bg-gray-100 dark:hover:bg-slate-800 hover:text-primary dark:hover:text-accent"
        data-target="bienestar"
      >
        🌱 Bienestar Estudiantil
      </button>
    </div>

    <!-- Organigrama Panels Wrapper -->
    <div class="relative max-w-5xl mx-auto min-h-[500px]">
      
      <!-- PANEL 1: Dirección y Consejo -->
      <div id="panel-leadership" class="organigrama-panel opacity-100 scale-100 transition-all duration-500 flex flex-col items-center gap-8">
        
        <!-- Ente Superior (MPPE, Zona, AVEC) -->
        <div class="flex flex-col items-center w-full max-w-lg mb-4 text-center">
          <div class="px-5 py-2.5 bg-white dark:bg-[#1b1145]/30 border border-slate-200 dark:border-white/10 rounded-2xl text-[11px] font-bold text-gray-700 dark:text-gray-300 tracking-wider shadow-sm">
            MINISTERIO DEL PODER POPULAR PARA LA EDUCACIÓN
            <div class="text-[10px] text-primary dark:text-accent mt-0.5">Zona / Circuito</div>
          </div>
          <div class="h-6 w-0.5 bg-slate-300 dark:bg-white/10"></div>
          <div class="px-6 py-2 bg-primary dark:bg-[#281470]/80 border border-primary-light/30 dark:border-secondary/30 rounded-full text-xs font-bold text-white dark:text-secondary tracking-widest uppercase shadow-sm">
            AVEC
          </div>
          <div class="h-8 w-0.5 bg-primary/20 dark:bg-accent/40"></div>
        </div>

        <!-- Dirección Principal -->
        <div class="relative flex flex-col items-center">
          <!-- Hermanas de la Caridad (Side tag) -->
          <div class="absolute -right-24 md:-right-48 top-12 md:top-8 px-4 py-2 bg-pink-500/10 border border-pink-500/20 dark:border-pink-500/30 rounded-2xl text-xs text-pink-600 dark:text-pink-400 font-semibold shadow-md">
            ⛪ Hermanas de la Caridad
          </div>

          <div class="group relative bg-white dark:bg-[#1b1145] rounded-3xl border-2 border-primary dark:border-accent p-6 shadow-xl max-w-sm text-center transition-all duration-300 hover:-translate-y-1 hover:shadow-2xl">
            <div class="mx-auto mb-4 h-24 w-24 overflow-hidden rounded-full border-4 border-primary dark:border-accent shadow-md relative">
              <img src={leadershipLevel1.image} alt={leadershipLevel1.name} class="h-full w-full object-cover transition duration-300 group-hover:scale-105" />
            </div>
            <h3 class="text-lg font-bold text-gray-900 dark:text-slate-100">{leadershipLevel1.name}</h3>
            <span class="inline-block rounded-full bg-primary/10 dark:bg-accent/15 px-3 py-0.5 text-xs font-semibold text-primary dark:text-accent mb-2">
              {leadershipLevel1.role}
            </span>
            <p class="text-xs text-gray-600 dark:text-slate-300 leading-relaxed">
              {leadershipLevel1.details}
            </p>
          </div>
          
          <div class="h-8 w-0.5 bg-gradient-to-b from-primary to-secondary dark:from-accent dark:to-primary"></div>
        </div>

        <!-- Consejo Directivo & Subdirección -->
        <div class="grid md:grid-cols-2 gap-8 w-full max-w-3xl">
          <!-- Consejo Directivo (with Sustanciación inside) -->
          <div class="group relative bg-white dark:bg-[#1b1145] rounded-3xl border border-slate-200 dark:border-slate-800 p-6 shadow-md transition-all duration-300 hover:-translate-y-1">
            <div class="flex items-center gap-3 mb-2">
              <span class="text-xl">🤝</span>
              <h3 class="text-md font-bold text-gray-900 dark:text-slate-100">Consejo Directivo</h3>
            </div>
            <p class="text-xs text-gray-600 dark:text-slate-300 leading-relaxed mb-4">
              Órgano de co-dirección colegiada para las decisiones académicas, organizativas y de valores.
            </p>
            <div class="inline-block px-3 py-1 bg-secondary/10 dark:bg-secondary/15 border border-secondary/20 rounded-xl text-[10px] font-bold text-secondary uppercase">
              Sustanciación y Registro
            </div>
          </div>

          <!-- Subdirección Académica -->
          <div class="group relative bg-white dark:bg-[#1b1145] rounded-3xl border border-slate-200 dark:border-slate-800 p-6 shadow-md transition-all duration-300 hover:-translate-y-1">
            <div class="flex gap-4 items-start">
              <div class="h-16 w-16 overflow-hidden rounded-full border-2 border-primary/10 shadow-sm shrink-0 bg-primary/5">
                <img src={leadershipLevel2.image} alt={leadershipLevel2.name} class="h-full w-full object-cover" />
              </div>
              <div>
                <h3 class="text-sm font-bold text-gray-900 dark:text-slate-100">{leadershipLevel2.name}</h3>
                <span class="inline-block rounded-full bg-primary/10 dark:bg-primary-light/20 px-2.5 py-0.5 text-[10px] font-semibold text-primary dark:text-primary-light mb-2">
                  {leadershipLevel2.role}
                </span>
                <p class="text-[11px] text-gray-600 dark:text-slate-300 leading-relaxed">
                  {leadershipLevel2.details}
                </p>
              </div>
            </div>
          </div>
        </div>

      </div>

      <!-- PANEL 2: Coordinación y Academia -->
      <div id="panel-academia" class="organigrama-panel hidden opacity-0 scale-95 transition-all duration-500 flex flex-col items-center gap-8">
        
        <!-- Coordinadoras Académicas -->
        <div class="grid md:grid-cols-2 gap-8 w-full max-w-4xl">
          {coordinators.map((c) => (
            <div class="group relative bg-white dark:bg-[#1b1145] rounded-3xl border border-slate-200 dark:border-slate-800 p-6 shadow-md transition-all duration-300 hover:-translate-y-1 flex gap-4 items-start">
              <div class="h-20 w-20 overflow-hidden rounded-full border-2 border-primary/10 shadow-sm shrink-0 bg-primary/5">
                <img src={c.image} alt={c.name} class="h-full w-full object-cover" />
              </div>
              <div>
                <h4 class="font-bold text-gray-900 dark:text-slate-100 text-sm">{c.name}</h4>
                <span class="inline-block rounded-full bg-primary/10 dark:bg-secondary/15 px-2.5 py-0.5 text-[10px] font-semibold text-primary dark:text-secondary mb-2">
                  {c.role}
                </span>
                <p class="text-xs text-gray-600 dark:text-slate-300 leading-relaxed">
                  {c.details}
                </p>
              </div>
            </div>
          ))}
        </div>

        <div class="w-full h-px bg-slate-200 dark:bg-white/10 max-w-3xl my-2"></div>

        <!-- Academic Structure (Primaria, Media, Control Estudio) -->
        <div class="grid md:grid-cols-3 gap-6 w-full max-w-4xl">
          <!-- Educación Primaria -->
          <div class="bg-white dark:bg-[#1b1145] rounded-3xl border border-slate-100 dark:border-slate-800/80 p-6 shadow-sm">
            <h4 class="font-bold text-gray-900 dark:text-white mb-3 text-sm border-b border-slate-100 dark:border-white/10 pb-2">🎒 Nivel Primaria</h4>
            <ul class="space-y-2 text-xs text-gray-600 dark:text-gray-300">
              <li class="flex justify-between py-1 border-b border-slate-100 dark:border-white/5"><span class="text-slate-500 dark:text-gray-400">Preescolar:</span> <span class="font-semibold text-slate-900 dark:text-white">X. Martínez, Y. Romero</span></li>
              <li class="flex justify-between py-1 border-b border-slate-100 dark:border-white/5"><span class="text-slate-500 dark:text-gray-400">1er Grado:</span> <span class="font-semibold text-slate-900 dark:text-white">M. Berrios</span></li>
              <li class="flex justify-between py-1 border-b border-slate-100 dark:border-white/5"><span class="text-slate-500 dark:text-gray-400">2do Grado:</span> <span class="font-semibold text-slate-900 dark:text-white">B. Hernández</span></li>
              <li class="flex justify-between py-1 border-b border-slate-100 dark:border-white/5"><span class="text-slate-500 dark:text-gray-400">3er Grado:</span> <span class="font-semibold text-slate-900 dark:text-white">N. Rodríguez</span></li>
              <li class="flex justify-between py-1 border-b border-slate-100 dark:border-white/5"><span class="text-slate-500 dark:text-gray-400">4to Grado:</span> <span class="font-semibold text-slate-900 dark:text-white">D. Guillen</span></li>
              <li class="flex justify-between py-1 border-b border-slate-100 dark:border-white/5"><span class="text-slate-500 dark:text-gray-400">5to Grado:</span> <span class="font-semibold text-slate-900 dark:text-white">Y. Pérez</span></li>
              <li class="flex justify-between py-1"><span class="text-slate-500 dark:text-gray-400">6to Grado:</span> <span class="font-semibold text-slate-900 dark:text-white">M. Santos</span></li>
            </ul>
          </div>

          <!-- Control de Estudios -->
          <div class="bg-white dark:bg-[#1b1145] rounded-3xl border border-slate-100 dark:border-slate-800/80 p-6 shadow-sm flex flex-col justify-between">
            <div>
              <h4 class="font-bold text-gray-900 dark:text-white mb-3 text-sm border-b border-slate-100 dark:border-white/10 pb-2">📊 Control de Estudio</h4>
              <p class="text-xs text-gray-600 dark:text-gray-300 leading-relaxed mb-4">
                Departamento encargado de la planificación, registro académico, expedientes estudiantiles, emisión de notas, títulos y enlace con el Ministerio de Educación.
              </p>
            </div>
            <div class="p-3 bg-primary/5 dark:bg-white/5 border border-primary/10 dark:border-white/5 rounded-2xl text-[10px] text-center text-primary dark:text-accent uppercase font-bold tracking-wider">
              Control e Historial Pedagógico
            </div>
          </div>

          <!-- Educación Media General -->
          <div class="bg-white dark:bg-[#1b1145] rounded-3xl border border-slate-100 dark:border-slate-800/80 p-6 shadow-sm">
            <h4 class="font-bold text-gray-900 dark:text-white mb-3 text-sm border-b border-slate-100 dark:border-white/10 pb-2">📚 Media General</h4>
            <ul class="space-y-2 text-xs text-gray-600 dark:text-gray-300">
              <li class="flex justify-between py-1 border-b border-slate-100 dark:border-white/5"><span class="text-slate-500 dark:text-gray-400">1er Año:</span> <span class="font-semibold text-slate-900 dark:text-white">Prof. José Vásquez</span></li>
              <li class="flex justify-between py-1 border-b border-slate-100 dark:border-white/5"><span class="text-slate-500 dark:text-gray-400">2do Año:</span> <span class="font-semibold text-slate-900 dark:text-white">Prof. Anele Palacios</span></li>
              <li class="flex justify-between py-1 border-b border-slate-100 dark:border-white/5"><span class="text-slate-500 dark:text-gray-400">3er Año:</span> <span class="font-semibold text-slate-900 dark:text-white">Prof. F. Cianflaglione</span></li>
              <li class="flex justify-between py-1 border-b border-slate-100 dark:border-white/5"><span class="text-slate-500 dark:text-gray-400">4to Año:</span> <span class="font-semibold text-slate-900 dark:text-white">Prof. Kelvin Tabata</span></li>
              <li class="flex justify-between py-1"><span class="text-slate-500 dark:text-gray-400">5to Año:</span> <span class="font-semibold text-slate-900 dark:text-white">Prof. Jorge Hernández</span></li>
            </ul>
          </div>
        </div>

      </div>

      <!-- PANEL 3: Secretaría y Obreros -->
      <div id="panel-servicios" class="organigrama-panel hidden opacity-0 scale-95 transition-all duration-500 flex flex-col gap-8">
        
        <!-- Administración / Secretaría -->
        <div>
          <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-4 border-l-4 border-primary dark:border-secondary pl-3">💼 Administración y Secretaría</h3>
          <div class="grid sm:grid-cols-3 gap-6">
            {secretaries.map((s) => (
              <div class="bg-white dark:bg-[#1b1145] p-5 rounded-2xl border border-slate-100 dark:border-primary/10 shadow-sm flex items-center gap-3">
                <span class="text-xl">📂</span>
                <div>
                  <h4 class="font-bold text-gray-900 dark:text-slate-100 text-xs">{s.name}</h4>
                  <span class="text-[10px] font-semibold text-primary dark:text-secondary uppercase tracking-wider">{s.role}</span>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Recursos Humanos / Obreros -->
        <div>
          <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-4 border-l-4 border-primary dark:border-accent pl-3">🧹 Recursos Humanos y Obreros</h3>
          <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-4">
            {staffObreros.map((o) => (
              <div class="bg-white dark:bg-[#1b1145] p-4 rounded-xl border border-slate-100 dark:border-white/5 flex justify-between items-center shadow-sm">
                <div>
                  <h4 class="font-semibold text-gray-900 dark:text-white text-xs">{o.name}</h4>
                  <p class="text-[10px] text-gray-500 dark:text-gray-400 italic mt-0.5">{o.role}</p>
                </div>
                <span class="text-xs px-2 py-0.5 rounded-full bg-primary/5 dark:bg-accent/10 text-primary dark:text-accent font-semibold">
                  {o.role === 'Mantenimiento' ? '🔧' : o.role === 'Portera' ? '🔑' : '✨'}
                </span>
              </div>
            ))}
          </div>
        </div>

      </div>

      <!-- PANEL 4: Consejo Educativo -->
      <div id="panel-consejo" class="organigrama-panel hidden opacity-0 scale-95 transition-all duration-500 flex flex-col gap-6">
        <div class="text-center max-w-2xl mx-auto mb-4">
          <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-2">👥 Comités del Consejo Educativo</h3>
          <p class="text-xs text-gray-500 dark:text-gray-400">
            Órganos participativos de la comunidad que garantizan el bienestar integral, la contraloría, los proyectos de aprendizaje y la vinculación social de la institución.
          </p>
        </div>
        
        <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-6">
          {educationalCommittees.map((c) => (
            <div class="group relative bg-white dark:bg-[#1b1145] border border-slate-100 dark:border-white/5 hover:border-primary/20 dark:hover:border-accent/20 p-5 rounded-2xl shadow-sm transition duration-300 hover:-translate-y-0.5 flex gap-3">
              <span class="text-2xl h-10 w-10 shrink-0 flex items-center justify-center rounded-xl bg-slate-50 dark:bg-white/5 border border-slate-100 dark:border-white/10">{c.icon}</span>
              <div>
                <h4 class="font-bold text-gray-900 dark:text-white text-xs mb-1.5 leading-snug group-hover:text-primary dark:group-hover:text-accent transition">{c.title}</h4>
                <p class="text-[11px] text-gray-500 dark:text-gray-400 leading-normal">{c.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- PANEL 5: Bienestar Estudiantil -->
      <div id="panel-bienestar" class="organigrama-panel hidden opacity-0 scale-95 transition-all duration-500 flex flex-col gap-6">
        <div class="text-center max-w-2xl mx-auto mb-4">
          <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-2">🌱 Bienestar Familiar y Estudiantil</h3>
          <p class="text-xs text-gray-500 dark:text-gray-400">
            Departamentos y programas dedicados a brindar soporte socio-emocional, psicopedagógico y pastoral tanto a estudiantes como a sus familias.
          </p>
        </div>

        <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-6 justify-center">
          {welfareDepartments.map((w) => (
            <div class="group bg-white dark:bg-[#1b1145] border border-slate-100 dark:border-primary/10 p-6 rounded-3xl shadow-sm transition hover:shadow-md hover:border-primary/20 dark:hover:border-secondary/20 flex flex-col justify-between min-h-[160px]">
              <div>
                <div class="flex items-center gap-3 mb-3">
                  <span class="text-xl flex h-10 w-10 items-center justify-center rounded-2xl bg-primary/5 dark:bg-secondary/10 text-primary dark:text-secondary border border-primary/10 dark:border-secondary/20">{w.icon}</span>
                  <h4 class="font-bold text-gray-900 dark:text-slate-100 text-xs">{w.title}</h4>
                </div>
                <p class="text-[11px] text-gray-600 dark:text-slate-300 leading-normal">{w.desc}</p>
              </div>
              <div class="text-[9px] uppercase font-semibold text-gray-400 dark:text-slate-500 tracking-wider text-right mt-4">
                Soporte Integral
              </div>
            </div>
          ))}
        </div>
      </div>

    </div>

  </div>
</section>

<script>
  function setupOrganigramaTabs() {
    const tabs = document.querySelectorAll('.organigrama-tab-btn');
    const panels = document.querySelectorAll('.organigrama-panel');

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const target = tab.getAttribute('data-target');

        // Toggle active tabs styling
        tabs.forEach((t) => {
          t.classList.remove('bg-primary', 'text-white', 'border-primary', 'dark:bg-accent', 'dark:text-primary', 'dark:border-accent');
          t.classList.add('text-gray-600', 'dark:text-slate-400', 'hover:bg-gray-100', 'dark:hover:bg-slate-800', 'hover:text-primary', 'dark:hover:text-accent');
        });
        tab.classList.add('bg-primary', 'text-white', 'border-primary', 'dark:bg-accent', 'dark:text-primary', 'dark:border-accent');
        tab.classList.remove('text-gray-600', 'dark:text-slate-400', 'hover:bg-gray-100', 'dark:hover:bg-slate-800', 'hover:text-primary', 'dark:hover:text-accent');

        // Toggle visibility of panels with transition
        panels.forEach((panel) => {
          const panelId = panel.getAttribute('id');
          if (panelId === `panel-${target}`) {
            panel.classList.remove('hidden');
            // Wait for display block before applying animation classes
            setTimeout(() => {
              panel.classList.remove('opacity-0', 'scale-95');
              panel.classList.add('opacity-100', 'scale-100');
            }, 50);
          } else {
            panel.classList.remove('opacity-100', 'scale-100');
            panel.classList.add('opacity-0', 'scale-95');
            // Wait for transition before hiding
            setTimeout(() => {
              panel.classList.add('hidden');
            }, 300);
          }
        });
      });
    });
  }

  // Initialize tabs when page loads
  document.addEventListener('astro:page-load', setupOrganigramaTabs);
</script>



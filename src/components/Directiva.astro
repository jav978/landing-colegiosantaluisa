  { title: 'Pastoral', icon: '⛪', desc: 'Coordinación de acciones litúrgicas, misiones de caridad y formación vicenciana.' },
  { title: 'Educ. de la Fe', icon: '📖', desc: 'Educación y formación doctrinal en valores cristianos y morales.' },
  { title: 'Servicio', icon: '🤝', desc: 'Acción social, voluntariado y apoyo solidario a comunidades vulnerables.' },
  { title: 'Vocacional', icon: '🧭', desc: 'Acompañamiento en el discernimiento del proyecto de vida y espiritual.' },
  { title: 'Defensores', icon: '🛡️', desc: 'Promoción y defensa de los derechos de los niños, niñas y adolescentes.' },

---
interface BoardMember {
  name: string;
  role: string;
  image?: string;
  details?: string;
}

const level1: BoardMember = {
  name: 'Sor Rosario Daza',
  role: 'Directora General',
  image: '/images/staff/director.png',
  details: 'Representante de la Congregación de las Hijas de la Caridad y responsable de la gestión general del plantel.'
};

const level2: BoardMember = {
  name: 'Prof. Carmen Silva',
  role: 'Subdirectora Académica',
  image: '/images/staff/teacher_2.png',
  details: 'Supervisora de la planificación pedagógica, calidad académica y desarrollo docente del colegio.'
};

const level3: BoardMember[] = [
  {
    name: 'Sor Isabel Sainz',
    role: 'Coordinadora de Pastoral',
    details: 'Responsable de la formación en valores evangélicos, carisma vicenciano y convivencias litúrgicas.'
  },
  {
    name: 'Prof. María Fernández',
    role: 'Coordinadora de Primaria',
    image: '/images/staff/teacher_1.png',
    details: 'Coordinadora del área pedagógica para estudiantes desde primer grado hasta sexto grado.'
  }
];
---

<section id="directiva" class="reveal-on-scroll section-padding bg-gradient-to-b from-[#140b37] to-white dark:from-[#0e072c] dark:to-[#140b37] overflow-hidden">
  <div class="container-custom">
    <div class="mb-16 text-center">
      <span class="mb-3 inline-block rounded-full bg-accent/10 px-4 py-1.5 text-xs font-semibold uppercase tracking-wider text-accent">
        Organización
      </span>
      <h2 class="text-3xl font-bold text-white dark:text-white sm:text-4xl">
        Junta <span class="text-accent">Directiva</span> y Liderazgo
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-gray-300 dark:text-slate-300">
        Equipo de gestión comprometido con la excelencia académica y los valores vicencianos de nuestra institución
      </p>
      <div class="mx-auto mt-4 h-1 w-20 rounded-full bg-accent"></div>
    </div>

    <!-- Hierarchy Tree Organigrama -->
    <div class="relative max-w-5xl mx-auto flex flex-col items-center gap-12">
      <!-- LEVEL 1: Director General -->
      <div class="relative flex flex-col items-center">
        <div class="group relative bg-white dark:bg-[#1b1145] rounded-3xl border-2 border-accent p-6 shadow-xl max-w-sm text-center transition-all duration-300 hover:-translate-y-1 hover:shadow-2xl">
          <div class="mx-auto mb-4 h-24 w-24 overflow-hidden rounded-full border-4 border-accent shadow-md relative">
            <img src={level1.image} alt={level1.name} class="h-full w-full object-cover transition duration-300 group-hover:scale-105" />
          </div>
          <h3 class="text-lg font-bold text-gray-900 dark:text-slate-100">{level1.name}</h3>
          <span class="inline-block rounded-full bg-accent/15 px-3 py-0.5 text-xs font-semibold text-accent mb-2">
            {level1.role}
          </span>
          <p class="text-xs text-gray-600 dark:text-slate-300 leading-relaxed">
            {level1.details}
          </p>
        </div>
        
        <!-- Connector line to level 2 -->
        <div class="h-12 w-0.5 bg-gradient-to-b from-accent to-primary dark:to-primary-light"></div>
      </div>

      <!-- LEVEL 2: Sub-director -->
      <div class="relative flex flex-col items-center w-full">
        <!-- Horizontal bar connecting to side elements if needed, otherwise vertical -->
        <div class="group relative bg-white dark:bg-[#1b1145] rounded-3xl border-2 border-primary/20 dark:border-slate-800 p-6 shadow-lg max-w-sm text-center transition-all duration-300 hover:-translate-y-1 hover:shadow-xl">
          <div class="mx-auto mb-4 h-20 w-20 overflow-hidden rounded-full border-2 border-primary/20 shadow-md relative">
            <img src={level2.image} alt={level2.name} class="h-full w-full object-cover transition duration-300 group-hover:scale-105" />
          </div>
          <h3 class="text-md font-bold text-gray-900 dark:text-slate-100">{level2.name}</h3>
          <span class="inline-block rounded-full bg-primary/10 dark:bg-primary-light/20 px-3 py-0.5 text-xs font-semibold text-primary dark:text-primary-light mb-2">
            {level2.role}
          </span>
          <p class="text-xs text-gray-600 dark:text-slate-300 leading-relaxed">
            {level2.details}
          </p>
        </div>

        <!-- Vertical connector line split path -->
        <div class="h-12 w-0.5 bg-gray-200 dark:bg-slate-800"></div>
        <div class="relative w-full max-w-3xl flex justify-between">
          <!-- Horizontal Split Bar -->
          <div class="absolute -top-0.5 left-1/4 right-1/4 h-0.5 bg-gray-200 dark:bg-slate-800"></div>
          <!-- Left branch down -->
          <div class="absolute -top-0.5 left-1/4 h-6 w-0.5 bg-gray-200 dark:bg-slate-800"></div>
          <!-- Right branch down -->
          <div class="absolute -top-0.5 right-1/4 h-6 w-0.5 bg-gray-200 dark:bg-slate-800"></div>
        </div>
      </div>

      <!-- LEVEL 3: Coordinators -->
      <div class="grid md:grid-cols-2 gap-8 w-full max-w-4xl mt-2 relative">
        {level3.map((m) => (
          <div class="group relative bg-white dark:bg-[#1b1145] rounded-3xl border border-primary/5 dark:border-slate-800/80 p-6 shadow-md transition-all duration-300 hover:-translate-y-1 hover:shadow-lg flex flex-col justify-between">
            <div class="flex gap-4 items-start">
              <div class="h-16 w-16 overflow-hidden rounded-full border-2 border-primary/10 shadow-sm shrink-0 bg-primary/5 flex items-center justify-center">
                {m.image ? (
                  <img src={m.image} alt={m.name} class="h-full w-full object-cover transition duration-300 group-hover:scale-105" />
                ) : (
                  <span class="text-2xl select-none">🙏</span>
                )}
              </div>
              <div>
                <h4 class="font-bold text-gray-900 dark:text-slate-100 text-sm">{m.name}</h4>
                <span class="inline-block rounded-full bg-secondary/15 px-2.5 py-0.5 text-[10px] font-semibold text-secondary mb-2">
                  {m.role}
                </span>
                <p class="text-xs text-gray-600 dark:text-slate-300 leading-relaxed">
                  {m.details}
                </p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

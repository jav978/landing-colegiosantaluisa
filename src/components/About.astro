<style is:global>
  /* Custom scrollbar for timelines and search results */
  .scrollbar-thin::-webkit-scrollbar {
    height: 4px;
    width: 4px;
  }
  .scrollbar-thin::-webkit-scrollbar-track {
    background: transparent;
  }
  .scrollbar-thin::-webkit-scrollbar-thumb {
    background: rgba(156, 163, 175, 0.2);
    border-radius: 2px;
  }
  .scrollbar-thin::-webkit-scrollbar-thumb:hover {
    background: rgba(156, 163, 175, 0.35);
  }

  /* Timeline navigation tab styling */
  .timeline-tab-btn {
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Default inactive node state */
  .timeline-tab-btn .timeline-node {
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Active Node State styling */
  .timeline-tab-btn.active {
    background-color: rgba(40, 20, 112, 0.04); /* bg-primary/4 */
    border-color: #f7c301; /* border-accent */
  }

  html.dark .timeline-tab-btn.active {
    background-color: rgba(62, 34, 156, 0.15); /* bg-primary-light/15 */
    border-color: #f7c301;
  }

  @media (min-width: 1024px) {
    .timeline-tab-btn.active {
      border-left-width: 4px;
      border-top-left-radius: 0;
      border-bottom-left-radius: 0;
      border-top-right-radius: 1rem;
      border-bottom-right-radius: 1rem;
    }
  }

  .timeline-tab-btn.active .timeline-node {
    background-color: #f7c301; /* bg-accent */
    border-color: #281470; /* border-primary */
    transform: scale(1.15);
    box-shadow: 0 4px 12px rgba(247, 195, 1, 0.35);
  }

  html.dark .timeline-tab-btn.active .timeline-node {
    background-color: #f7c301;
    border-color: #3e229c;
    box-shadow: 0 4px 12px rgba(247, 195, 1, 0.2);
  }

  .timeline-tab-btn.active .year-text {
    color: #281470; /* text-primary */
    font-weight: 800;
  }

  html.dark .timeline-tab-btn.active .year-text {
    color: #f7c301; /* text-accent */
  }

  .timeline-tab-btn.active .title-text {
    color: #111827; /* text-gray-900 */
    font-weight: 800;
  }

  html.dark .timeline-tab-btn.active .title-text {
    color: #ffffff;
  }
</style>

<script>
  function setupTimeline() {
    const tabs = document.querySelectorAll('.timeline-tab-btn');
    const panels = document.querySelectorAll('.timeline-panel');

    // Era timeline click handler
    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const targetIndex = tab.getAttribute('data-index');

        // Toggle active class on all tabs
        tabs.forEach((t) => {
          t.classList.remove('active');
        });
        tab.classList.add('active');

        // Toggle visibility and scale transitions on panels
        panels.forEach((panel, pIndex) => {
          if (pIndex.toString() === targetIndex) {
            panel.classList.remove('opacity-0', 'translate-y-8', 'pointer-events-none', 'z-0', 'scale-[0.98]');
            panel.classList.add('opacity-100', 'translate-y-0', 'pointer-events-auto', 'z-10', 'scale-100');
          } else {
            panel.classList.remove('opacity-100', 'translate-y-0', 'pointer-events-auto', 'z-10', 'scale-100');
            panel.classList.add('opacity-0', 'translate-y-8', 'pointer-events-none', 'z-0', 'scale-[0.98]');
          }
        });
      });
    });

    // Real-time Search input handler for historical sisters
    const searchInput = document.getElementById('sister-search-input') as HTMLInputElement | null;
    const sisterItems = document.querySelectorAll('.sister-item') as NodeListOf<HTMLElement>;

    if (searchInput) {
      searchInput.addEventListener('input', (e) => {
        const query = (e.target as HTMLInputElement).value.toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "");
        
        sisterItems.forEach((item) => {
          const sisterNameSpan = item.querySelector('.sister-name');
          if (sisterNameSpan) {
            const sisterName = sisterNameSpan.textContent?.toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "") || '';
            if (sisterName.includes(query)) {
              item.style.display = 'flex';
            } else {
              item.style.display = 'none';
            }
          }
        });
      });
    }
  }

  // Initialize interactive features on load and view change transitions
  document.addEventListener('astro:page-load', setupTimeline);
</script>

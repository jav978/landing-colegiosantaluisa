---
interface Milestone {
  year: string;
  title: string;
  subtitle?: string;
  description: string;
  details?: string[];
  icon: string;
}

interface Director {
  name: string;
  period: string;
  image?: string;
}

interface SisterServant {
  name: string;
  period: string;
}

interface HistoricalSister {
  name: string;
  period: string;
}

const milestones: Milestone[] = [
  {
    year: '1950',
    title: 'Llegada a Venezuela',
    subtitle: '18 de Octubre de 1950',
    description: 'Las Hijas de la Caridad llegan a Venezuela solicitadas por Monseñor Mariano José Parra para atender la misión vicenciana de cuidado y educación en Cumaná. Posteriormente, expandieron su labor fundando hogares, vicarías, centros sociales y ancianatos en todo el país.',
    details: ['Fundación de las primeras obras vicencianas en el territorio nacional.', 'Bases del carisma de amor, servicio y caridad.'],
    icon: '⛪'
  },
  {
    year: '1953',
    title: 'Fundación del Colegio',
    subtitle: '15 de Septiembre de 1953',
    description: 'El Señor Obispo de Caracas, Monseñor Lucas Guillermo Castillo, manifiesta la necesidad de una escuela parroquial. Los Padres Paúles elevan la petición a Sor María Luisa Courbín (Visitadora de Cali, Colombia), quien envía a cinco hermanas para iniciar la escuela de niñas con 150 alumnas de Preescolar a 4° Grado en casitas alquiladas de la Calle La Saleya.',
    details: [
      'Primeras maestras: Sor Mª Libia Echeverri, Sor Carmen Rosa López, Sor María Dolly Ocampo, Sor Ana Derly Silva y Sor Pilar López.',
      'Satisfecho con su labor, el Ministerio de Educación autoriza implantar la Primaria completa al finalizar el primer año escolar.'
    ],
    icon: '🏫'
  },
  {
    year: '1954',
    title: 'Traslado a Prado de María',
    subtitle: 'Nueva Sede y Expansión',
    description: 'Las estrechas casitas de la Calle La Saleya son reemplazadas por el local que ocupaba la Escuela José María España en la Calle Real del Prado de María, junto a la Iglesia La Milagrosa (sede actual). Se abre la Escuela de Comercio para otorgar la Credencial de Taquimecanografía en 2 años, y se establece un internado para unas 30 niñas huérfanas.',
    details: ['Mudanza a la sede histórica de Prado de María.', 'Inauguración de la Escuela de Comercio e internado social.'],
    icon: '📍'
  },
  {
    year: '1957',
    title: 'Ciclo Básico y Nivel Medio',
    subtitle: 'Crecimiento Pedagógico',
    description: 'Se implanta oficialmente el Primer Año del Ciclo Básico y, de forma progresiva, se añaden los dos años restantes. De forma paralela, funcionaba una escuela nocturna para facilitar la educación de adultos de la comunidad, la cual prestó servicios hasta el año 1966.',
    details: ['Evolución hacia la educación básica e integral.', 'Apertura de la escuela nocturna para la formación de adultos.'],
    icon: '📚'
  },
  {
    year: '1964',
    title: 'Edificación del Plantel Actual',
    subtitle: '1 de Marzo de 1964',
    description: 'La Provincia de Cali (cuna de la comunidad en Venezuela) dona 300.000 Bs. para adquirir los terrenos contiguos e iniciar la construcción. Se coloca la Primera Piedra y, tras siete años de arduos trabajos, préstamos bancarios y muchos sacrificios de la comunidad, se erige el moderno edificio que disfrutamos hoy en día.',
    details: ['Colocación de la primera piedra el 1° de marzo de 1964.', 'Proceso de edificación que duró 7 años de esfuerzo colectivo.'],
    icon: '🏗️'
  },
  {
    year: '1980',
    title: 'Enfoque en Educación Básica',
    subtitle: 'Curso 1980-1981',
    description: 'Tras egresar la primera y única promoción de Bachillerato completo (Curso 1980-1981), el Consejo Provincial decide concentrar los esfuerzos en la Educación Primaria. Se determina que la educación secundaria sea transferida al Colegio San Vicente (regentado por los Padres de la Misión), garantizando que las familias de menores recursos de la zona puedan costear los estudios de sus hijos.',
    details: ['Consolidación del enfoque social y de servicio vicenciano.', 'Alianza estratégica de estudios con el Colegio San Vicente.'],
    icon: '🤝'
  },
  {
    year: '1982',
    title: 'Casa Provincial y Expansión',
    subtitle: 'Traslado de la Sede Principal',
    description: 'El Consejo Provincial de las Hijas de la Caridad decide trasladar su sede principal (Casa Provincial) desde Vista Alegre al edificio del Colegio Santa Luisa, tras realizar adaptaciones arquitectónicas y unificando ambas comunidades bajo una misma sede de espiritualidad.',
    details: ['La sede del colegio se convierte en el epicentro provincial de la Congregación.', 'Consolidación comunitaria y pastoral.'],
    icon: '🏠'
  },
  {
    year: '1990',
    title: 'Convenio AVEC',
    subtitle: 'Sostenibilidad Educativa',
    description: 'El 13 de enero de 1990 se firma el histórico convenio entre la Asociación Venezolana de Educación Católica (AVEC) y el Poder Ejecutivo de la Nación. Gracias a este convenio de financiamiento y subsidios de personal, el colegio consolida su gratuidad y calidad de enseñanza para sus alumnos.',
    details: ['Firma del convenio AVEC el 13 de enero de 1990.', 'Garantía de financiamiento para el mantenimiento y personal docente.'],
    icon: '📝'
  },
  {
    year: '1994',
    title: 'Reinicio de la 3ª Etapa',
    subtitle: 'Curso 1994-1995',
    description: 'Se reinicia oficialmente la 3ª Etapa de Educación Básica (7°, 8° y 9° grado, equivalente al antiguo Ciclo Básico), expandiendo de nuevo la oferta educativa para responder al desarrollo curricular oficial. Se atienden a más de 400 alumnos con educación en clave de evangelización e integración familiar.',
    details: ['Egreso de múltiples promociones de Educación Básica de 9 años.', 'Integración activa de la Escuela de Padres y Convivencias en la Parroquia.'],
    icon: '🌟'
  }
];

const directors: Director[] = [
  { name: 'Sor Libia Echeverri', period: 'Fundación (1953) - 1957' },
  { name: 'Sor Ana Derly Silva', period: '1957 – 1968 y 1983 – 1993', image: '/images/directoras/soranaderlysilva.webp' },
  { name: 'Sor Lilia Acevedo', period: '1968 – 1979', image: '/images/directoras/sorliliaacevedo.webp' },
  { name: 'Sor Dolores Amaya', period: '1979 – 1982', image: '/images/directoras/sordoloresamaya.webp' },

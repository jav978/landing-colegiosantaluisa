function getDirectorInitial(name: string) {
  const cleanName = name.replace(/^Sor\s+/i, '');
  return cleanName.charAt(0).toUpperCase();
}
---

<section id="nosotros" class="reveal-on-scroll section-padding bg-gradient-to-b from-white to-stone-50 dark:from-[#0e072c] dark:to-[#140b37] min-w-0 w-full overflow-hidden">
  <div class="container-custom min-w-0 w-full">
    <div class="mb-16 text-center">
      <span class="mb-3 inline-block rounded-full bg-primary/10 dark:bg-primary-light/20 px-4 py-1.5 text-xs font-semibold uppercase tracking-wider text-primary dark:text-primary-light">
        Nuestra Historia
      </span>
      <h2 class="text-3xl font-bold text-gray-900 dark:text-white sm:text-4xl">
        Más de <span class="text-primary dark:text-accent">70 años</span> de labor vicenciana
      </h2>
      <div class="mx-auto mt-4 h-1 w-20 rounded-full bg-accent"></div>
    </div>

    <!-- Interactive Timeline -->
    <div class="mb-24 grid gap-8 lg:grid-cols-12 min-w-0 w-full">
      <!-- Timeline Navigation (Left on desktop, top on mobile) -->
      <div class="lg:col-span-4 relative min-w-0 w-full">
        <!-- Scroll Indicators / Fade overlays (Only on mobile/tablet) -->
        <div class="absolute left-0 top-0 bottom-4 w-8 bg-gradient-to-r from-white dark:from-[#0e072c] to-transparent pointer-events-none z-20 lg:hidden"></div>
        <div class="absolute right-0 top-0 bottom-4 w-8 bg-gradient-to-l from-white/95 dark:from-[#0e072c]/95 to-transparent pointer-events-none z-20 lg:hidden"></div>

        <!-- Background Timeline Connector Line -->
        <!-- Mobile: horizontal line across the middle of nodes -->
        <div class="absolute left-8 right-8 top-[32px] h-0.5 bg-gray-200 dark:bg-slate-800 lg:hidden z-0"></div>
        <!-- Desktop: vertical line down the nodes -->
        <div class="absolute left-8 top-8 bottom-8 w-0.5 bg-gray-200 dark:bg-slate-800 hidden lg:block z-0"></div>

        <div class="flex flex-row lg:flex-col overflow-x-auto lg:overflow-x-visible pb-4 lg:pb-0 gap-3 scrollbar-thin px-4 lg:px-0 relative z-10 min-w-0 w-full">
          {milestones.map((m, index) => (
            <button
              class={`timeline-tab-btn group relative flex flex-col lg:flex-row items-center gap-3 p-3 rounded-2xl transition-all duration-300 cursor-pointer focus:outline-none shrink-0 text-left ${
                index === 0 ? 'active' : ''
              }`}
              data-index={index}
            >
              <!-- The Node Dot -->
              <div class="timeline-node flex h-10 w-10 shrink-0 items-center justify-center rounded-full border-2 bg-white dark:bg-[#150b3d] text-base transition-all duration-300 border-gray-300 dark:border-slate-700 shadow-sm group-hover:scale-110">
                {m.icon}
              </div>
              
              <!-- Text -->
              <div class="text-center lg:text-left">
                <span class="year-text block text-xs font-bold tracking-wider font-mono text-gray-400 dark:text-slate-500 transition-colors duration-300">
                  {m.year}
                </span>
                <span class="title-text block text-xs font-semibold text-gray-700 dark:text-slate-300 transition-colors duration-300 line-clamp-1 max-w-[120px] lg:max-w-none">
                  {m.title}
                </span>
              </div>
            </button>
          ))}
          <!-- Scroll offset end spacer for mobile -->
          <div class="w-8 shrink-0 lg:hidden"></div>
        </div>
      </div>
 
      <!-- Timeline Details Display Panel -->
      <div class="lg:col-span-8 grid grid-cols-1 grid-rows-1 w-full relative min-w-0">
        {milestones.map((m, index) => (
          <div
            class={`timeline-panel col-start-1 row-start-1 w-full min-w-0 bg-white dark:bg-[#1b1145]/60 border border-primary/10 dark:border-slate-800/80 p-6 sm:p-10 rounded-3xl backdrop-blur-md shadow-lg transition-all duration-500 flex flex-col justify-between ${
              index === 0 ? 'opacity-100 translate-y-0 pointer-events-auto z-10 scale-100' : 'opacity-0 translate-y-8 pointer-events-none z-0 scale-[0.98]'
            }`}
            id={`timeline-panel-${index}`}
          >
            <!-- Large year backdrop in panel -->
            <span class="text-8xl sm:text-[10rem] font-black text-primary/[0.03] dark:text-accent/[0.03] select-none absolute right-8 bottom-6 z-0 pointer-events-none font-mono">
              {m.year}
            </span>

            <div class="relative z-10">
              <div class="flex items-center gap-3.5 mb-3">
                <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-accent/10 dark:bg-accent/20 border border-accent/20 dark:border-accent/30 text-xl shadow-inner">
                  {m.icon}
                </span>
                <div>
                  <h3 class="text-2xl sm:text-3xl font-extrabold text-gray-900 dark:text-white tracking-tight leading-tight">{m.title}</h3>
                  {m.subtitle && (
                    <span class="block text-[11px] font-bold text-accent uppercase tracking-widest mt-1">{m.subtitle}</span>
                  )}
                </div>
              </div>
              
              <p class="text-sm sm:text-base leading-relaxed text-gray-600 dark:text-slate-200 mt-6 mb-8 max-w-3xl font-normal">
                {m.description}
              </p>
            </div>

            {m.details && m.details.length > 0 && (
              <div class="relative z-10 border-t border-gray-100 dark:border-slate-800/80 pt-6 mt-auto">
                <h4 class="text-xs font-bold uppercase tracking-wider text-gray-400 dark:text-slate-400 mb-3">Hechos destacados</h4>
                <ul class="grid sm:grid-cols-2 gap-4">
                  {m.details.map((detail) => (
                    <li class="flex items-start gap-3 text-xs text-gray-600 dark:text-slate-300 leading-relaxed group">
                      <span class="text-accent flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-accent/10 border border-accent/20 font-bold transition-all duration-300 group-hover:bg-accent group-hover:text-primary">
                        ✦
                      </span>
                      <span>{detail}</span>
                    </li>
                  ))}
                </ul>
              </div>
            )}
          </div>
        ))}
      </div>
    </div>

    <!-- Fundadores Section -->
    <div class="mb-24">
      <div class="mb-12 text-center">
        <h3 class="text-2xl font-bold text-gray-900 dark:text-white sm:text-3xl">
          Nuestros Fundadores Vicencianos
        </h3>
        <p class="mt-2 text-sm text-gray-600 dark:text-slate-400">
          Inspiradores del carisma de servicio, amor y educación
        </p>
        <div class="mx-auto mt-3 h-0.5 w-16 rounded-full bg-accent"></div>
      </div>

      <div class="grid gap-8 md:grid-cols-2">
        <!-- San Vicente de Paúl -->
        <div class="flex flex-col sm:flex-row items-center sm:items-start gap-6 rounded-2xl border border-primary/10 dark:border-slate-800 bg-gradient-to-br from-white to-gray-50/50 dark:from-[#1b1145]/40 dark:to-[#0e072c]/40 p-6 backdrop-blur-sm shadow-sm transition-all duration-300 hover:-translate-y-1.5 hover:shadow-md hover:border-primary/20 dark:hover:border-accent/30">
          <div class="h-28 w-28 sm:h-32 sm:w-32 shrink-0 overflow-hidden rounded-2xl shadow-md border-2 border-primary/10">
            <img src="/images/sanvicente.png" alt="Retrato de San Vicente de Paúl" class="h-full w-full object-cover animate-fade-in" />
          </div>
          <div>
            <h4 class="text-lg font-bold text-primary dark:text-accent-light">San Vicente de Paúl</h4>
            <span class="text-xs font-semibold text-accent uppercase tracking-wider block mb-1">1581 - 1660</span>
            <p class="text-xs leading-relaxed text-gray-600 dark:text-slate-300">
              Conocido como el <strong>"Apóstol de la Caridad"</strong>. Dedicó su vida a la atención de los más necesitados y marginados en la Francia del siglo XVII. Fundó la Congregación de la Misión (Padres Vicencianos) y, junto a Santa Luisa de Marillac, cofundó la Compañía de las Hijas de la Caridad. Su carisma nos inspira a ver el servicio y la solidaridad como pilares de nuestra formación.
            </p>
          </div>
        </div>

        <!-- Santa Luisa de Marillac -->
        <div class="flex flex-col sm:flex-row items-center sm:items-start gap-6 rounded-2xl border border-primary/10 dark:border-slate-800 bg-gradient-to-br from-white to-gray-50/50 dark:from-[#1b1145]/40 dark:to-[#0e072c]/40 p-6 backdrop-blur-sm shadow-sm transition-all duration-300 hover:-translate-y-1.5 hover:shadow-md hover:border-primary/20 dark:hover:border-accent/30">
          <div class="h-28 w-28 sm:h-32 sm:w-32 shrink-0 overflow-hidden rounded-2xl shadow-md border-2 border-primary/10">
            <img src="/images/santaluisa.png" alt="Retrato de Santa Luisa de Marillac" class="h-full w-full object-cover animate-fade-in" />
          </div>
          <div>
            <h4 class="text-lg font-bold text-primary dark:text-accent-light">Santa Luisa de Marillac</h4>
            <span class="text-xs font-semibold text-accent uppercase tracking-wider block mb-1">1591 - 1660</span>
            <p class="text-xs leading-relaxed text-gray-600 dark:text-slate-300">
              Cofundadora de las Hijas de la Caridad y <strong>Patrona de los Asistentes Sociales</strong>. Mujer de profunda fe, dotada de una visión audaz y un gran talento organizativo. Estableció las bases de la educación popular para niñas de familias vulnerables en Francia. Su pedagogía del amor, respeto y sencillez guía la filosofía de nuestro colegio.
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- Interactive History Personnel Lists -->
    <div class="mb-24">
      <div class="mb-12 text-center">
        <h3 class="text-2xl font-bold text-gray-900 dark:text-white sm:text-3xl">
          Galeria de Directoras Históricas
        </h3>
        <p class="mt-2 text-sm text-gray-600 dark:text-slate-400">
          Galería de las líderes educativas que han conducido nuestra institución
        </p>
        <div class="mx-auto mt-3 h-0.5 w-16 rounded-full bg-accent"></div>
      </div>

      <div class="grid gap-6 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-6 mb-16">
        {directors.map((d) => (
          <div class="group relative overflow-hidden rounded-2xl border border-primary/5 dark:border-slate-800 bg-white/50 dark:bg-[#1b1145]/40 p-4 backdrop-blur-sm shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-md hover:border-primary/10 text-center">
            <div class="mx-auto mb-4 h-24 w-24 overflow-hidden rounded-full border-2 border-primary/10 dark:border-slate-700/60 shadow-sm relative bg-primary/5 flex items-center justify-center group-hover:border-accent transition duration-300">
              {d.image ? (
                <img
                  src={d.image}
                  alt={d.name}
                  class="h-full w-full object-cover transition duration-300 group-hover:scale-110"
                  loading="lazy"
                />
              ) : (
                <div class="flex items-center justify-center h-full w-full bg-gradient-to-br from-primary/10 to-primary/20 dark:from-primary-light/20 dark:to-primary-light/10 text-primary dark:text-accent font-bold text-xl">
                  {getDirectorInitial(d.name)}
                </div>
              )}
            </div>
            <h4 class="text-sm font-bold text-gray-800 dark:text-slate-200 line-clamp-1">{d.name}</h4>
            <span class="mt-1 block text-xs font-semibold text-accent dark:text-accent-light">{d.period}</span>
          </div>
        ))}
      </div>

      <div class="mb-12 text-center">
        <h3 class="text-2xl font-bold text-gray-900 dark:text-white sm:text-3xl">
          Legado y Comunidad Histórica
        </h3>
        <p class="mt-2 text-sm text-gray-600 dark:text-slate-400">
          Hermanas que han guiado nuestro camino de fe y enseñanza
        </p>
        <div class="mx-auto mt-3 h-0.5 w-16 rounded-full bg-accent"></div>
      </div>

      <div class="grid gap-8 md:grid-cols-2">
        <!-- Sister Servants List Card -->
        <div class="bg-white/80 dark:bg-[#1b1145]/50 backdrop-blur-md rounded-3xl border border-primary/10 dark:border-slate-800/80 p-6 shadow-sm flex flex-col justify-between">
          <div>
            <div class="flex items-center gap-3 mb-4">
              <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-primary/5 dark:bg-primary-light/20 text-xl border border-primary/10 dark:border-primary-light/10">🙏</span>
              <h4 class="text-lg font-bold text-gray-900 dark:text-slate-100">Hermanas Sirvientes</h4>
            </div>
            <p class="text-xs text-gray-500 dark:text-slate-400 mb-4">Hermanas Superiores a cargo de la Obra y Comunidad Vicenciana.</p>
            <div class="space-y-4 max-h-[300px] overflow-y-auto pr-2 scrollbar-thin">
              {sisterServants.map((s) => (
                <div class="flex flex-col border-l-2 border-primary dark:border-accent pl-3 py-1 group transition-all duration-300 hover:bg-primary/[0.02] dark:hover:bg-primary-light/5 rounded-r-lg">
                  <span class="text-sm font-bold text-gray-800 dark:text-slate-200 group-hover:text-primary dark:group-hover:text-accent transition duration-155">{s.name}</span>
                  <span class="text-xs text-gray-500 dark:text-slate-400">{s.period}</span>
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- Serving Sisters Full Searchable Panel -->
        <div class="bg-white/80 dark:bg-[#1b1145]/50 backdrop-blur-md rounded-3xl border border-primary/10 dark:border-slate-800/80 p-6 shadow-sm flex flex-col justify-between">

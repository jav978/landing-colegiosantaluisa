---
import { supabase } from '../lib/db';

const { data: anuncios } = await supabase
  .from('posts')
  .select('id, title, slug, excerpt, image_url, category, created_at')
  .eq('type', 'anuncio')
  .eq('published', true)
  .order('created_at', { ascending: false })
  .limit(3);
function getFirstImage(imageUrl: string | null | undefined): string | null {
  if (!imageUrl) return null;
  if (imageUrl.startsWith('[')) {
    try {
      const arr = JSON.parse(imageUrl);
      return Array.isArray(arr) && arr.length > 0 ? arr[0] : null;
    } catch (e) {
      return imageUrl;
    }
  }
  return imageUrl;
}
---

{anuncios && anuncios.length > 0 && (
  <section class="reveal-on-scroll section-padding bg-gradient-to-b from-primary/5 to-white dark:from-[#1b1145]/30 dark:to-[#0e072c]">
    <div class="container-custom">
      <div class="mb-12 text-center">
        <span class="mb-3 inline-block rounded-full bg-accent/10 px-4 py-1.5 text-xs font-semibold uppercase tracking-wider text-accent">
          Anuncios
        </span>
        <h2 class="text-3xl font-bold text-gray-900 dark:text-white sm:text-4xl">
          Últimos <span class="text-accent">Avisos</span>
        </h2>
        <div class="mx-auto mt-4 h-1 w-20 rounded-full bg-accent"></div>
      </div>

      <div class="grid gap-6 md:grid-cols-3">
        {anuncios.map((a) => {
          const coverImg = getFirstImage(a.image_url);
          return (
            <a
              href={`/blog/${a.slug}`}
              class="group relative overflow-hidden rounded-2xl border border-amber-100 dark:border-slate-800 bg-white dark:bg-[#1b1145] shadow-sm transition hover:shadow-lg"
            >
              {coverImg && (
                <div class="aspect-video overflow-hidden">
                  <img
                    src={coverImg}
                    alt={a.title}
                    class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
                    loading="lazy"
                  />
                </div>
              )}
            <div class="p-5">
              <div class="mb-3 flex items-center gap-2">
                <span class="rounded-full bg-accent/10 px-2.5 py-0.5 text-xs font-medium text-accent">
                  {a.category || 'Anuncio'}
                </span>
                <span class="text-xs text-gray-400">
                  {new Date(a.created_at).toLocaleDateString('es-VE')}
                </span>
              </div>
              <h3 class="mb-2 text-base font-bold text-gray-900 dark:text-slate-100 group-hover:text-accent transition">
                {a.title}
              </h3>
              {a.excerpt && (
                <p class="text-sm leading-relaxed text-gray-600 dark:text-slate-300 line-clamp-2">{a.excerpt}</p>
              )}
              <span class="mt-3 inline-flex items-center gap-1 text-xs font-medium text-accent">
                Leer más →
              </span>
            </div>
          </a>
          );
        })}
      </div>
    </div>
  </section>
)}

---
interface HeroSlide {
  src: string;
  title: string;
  phrase: string;
}

const slides: HeroSlide[] = [
  {
    src: '/images/hero/hero1.jpg',
    title: 'Excelencia Académica',
    phrase: 'Un espacio diseñado para crecer, aprender y convivir en armonía y fraternidad vicenciana.'
  },
  {
    src: '/images/hero/hero2.jpg',
    title: 'Valores Vicencianos',
    phrase: 'Sembrando la semilla de la sencillez, el respeto cívico y el amor al prójimo.'
  },
  {
    src: '/images/hero/hero3.jpg',
    title: 'Desarrollo Integral',
    phrase: 'El juego, la recreación y el deporte son pilares fundamentales para el crecimiento sano.'
  },
  {
    src: '/images/hero/hero4.jpg',
    title: 'Liderazgo y Pensamiento',
    phrase: 'Formamos mentes reflexivas a través del aprendizaje colaborativo y el amor por el saber.'
  },
  {
    src: '/images/hero/hero5.jpg',
    title: 'Fe y Solidaridad',
    phrase: 'Educamos el corazón para servir con generosidad y compromiso social a los más necesitados.'
  }
];
---

<section id="inicio" class="relative flex min-h-screen items-center justify-center overflow-hidden [perspective:1000px] [transform-style:preserve-3d]">
  
  <!-- Carousel Background (Super Flow fragments) -->
  <div class="absolute inset-0 z-0">
    {slides.map((slide, index) => (
      <div
        class={`hero-slide absolute inset-0 z-0 ${
          index === 0 ? 'visible' : 'invisible'
        }`}
        data-slide-index={index}
        data-active={index === 0 ? 'true' : 'false'}
      >
        <!-- Base Background Image to prevent subpixel clip-path gaps/lines -->
        <div 
          class="hero-base-bg absolute inset-0 bg-cover bg-center bg-no-repeat opacity-0 transition-opacity duration-700 pointer-events-none"
          style={`background-image: url('${slide.src}');`}
        ></div>

        <!-- Fragment 1: Top Triangle -->
        <div 
          class="hero-fragment absolute inset-0 bg-cover bg-center bg-no-repeat transition-all duration-1400 ease-out transform"
          style={`background-image: url('${slide.src}'); clip-path: polygon(0 0, 100% 0, 50% 50%);`}
          data-fragment="top"
        ></div>
        <!-- Fragment 2: Right Triangle -->
        <div 
          class="hero-fragment absolute inset-0 bg-cover bg-center bg-no-repeat transition-all duration-1400 ease-out transform"
          style={`background-image: url('${slide.src}'); clip-path: polygon(100% 0, 100% 100%, 50% 50%);`}
          data-fragment="right"
        ></div>
        <!-- Fragment 3: Bottom Triangle -->
        <div 
          class="hero-fragment absolute inset-0 bg-cover bg-center bg-no-repeat transition-all duration-1400 ease-out transform"
          style={`background-image: url('${slide.src}'); clip-path: polygon(100% 100%, 0 100%, 50% 50%);`}
          data-fragment="bottom"
        ></div>
        <!-- Fragment 4: Left Triangle -->
        <div 
          class="hero-fragment absolute inset-0 bg-cover bg-center bg-no-repeat transition-all duration-1400 ease-out transform"
          style={`background-image: url('${slide.src}'); clip-path: polygon(0 100%, 0 0, 50% 50%);`}
          data-fragment="left"
        ></div>

        <!-- More Transparent Gradient Overlay (gives more opacity and visibility to the images) -->
        <div class="absolute inset-0 bg-gradient-to-r from-primary/50 via-primary/30 to-primary/50 dark:from-[#0e072c]/70 dark:via-[#0e072c]/45 dark:to-[#0e072c]/70 pointer-events-none"></div>
      </div>
    ))}
  </div>

  <!-- Content (Foreground) -->
  <div class="relative z-10 mx-auto max-w-4xl px-12 text-center sm:px-6 [transform:translateZ(15px)] [transform-style:preserve-3d]">
    <div class="mb-6 inline-flex items-center gap-2 rounded-full bg-white/15 px-4 py-1.5 text-sm text-white backdrop-blur-sm">
      <span class="flex h-2 w-2 rounded-full bg-accent"></span>
      Hijas de la Caridad — Venezuela
    </div>

    <!-- Grid container for dynamic text blocks - auto-adapts height to content to prevent overlaps -->
    <div class="grid grid-cols-1 grid-rows-1 w-full mb-8 sm:mb-10 select-none [transform-style:preserve-3d]">
      {slides.map((slide, index) => {
        const words = slide.title.split(' ');
        const firstWord = words[0];
        const restWords = words.slice(1).join(' ');
        
        return (
          <div
            class={`hero-text-block col-start-1 row-start-1 flex flex-col items-center justify-center text-center px-2 transition-all duration-1200 ease-in-out transform [transform-style:preserve-3d] ${
              index === 0 ? 'opacity-100 translate-y-0 scale-100 z-10' : 'opacity-0 translate-y-6 scale-95 z-0 pointer-events-none'
            }`}
            data-text-index={index}
          >
            <h1 class="mb-4 text-3xl xs:text-4xl sm:text-5xl md:text-5.5xl lg:text-6.2xl xl:text-7xl font-extrabold leading-tight text-white tracking-tight select-none drop-shadow-md">
              {firstWord} <span class="text-accent">{restWords}</span>
            </h1>

            <p class="mx-auto max-w-2xl text-sm xs:text-base sm:text-lg md:text-xl font-medium italic drop-shadow-md leading-relaxed text-white/95 mt-2 sm:mt-4">
              "{slide.phrase}"
            </p>
          </div>
        );
      })}
    </div>

    <div class="flex flex-col items-center gap-3 sm:flex-row sm:justify-center w-full max-w-sm xs:max-w-none mx-auto [transform:translateZ(5px)]">
      <a
        href="#nosotros"
        class="w-full xs:w-auto inline-flex items-center justify-center gap-2 rounded-xl bg-accent px-6 py-3 text-sm sm:px-8 sm:py-3.5 sm:text-base font-bold text-white shadow-lg transition hover:bg-accent-light hover:shadow-xl hover:-translate-y-0.5 active:translate-y-0"
      >
        Conócenos
        <svg class="h-5 w-5 animate-pulse" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
        </svg>
      </a>
      <a
        href="#contacto"
        class="w-full xs:w-auto inline-flex items-center justify-center gap-2 rounded-xl border-2 border-white/40 px-6 py-3 text-sm sm:px-8 sm:py-3.5 sm:text-base font-semibold text-white transition hover:bg-white/10 hover:border-white/60 hover:-translate-y-0.5 active:translate-y-0"
      >
        Contáctanos
      </a>
    </div>
  </div>

  <!-- Navigation Controls -->
  <button
    id="prev-slide"
    class="absolute left-2 md:left-6 z-20 flex h-9 w-9 md:h-12 md:w-12 items-center justify-center rounded-full bg-white/15 text-white backdrop-blur-md transition border border-white/10 hover:bg-white/30 hover:scale-105 active:scale-95 cursor-pointer shadow-md"
    aria-label="Previous slide"
  >
    <svg class="h-5 w-5 md:h-6 md:w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
    </svg>
  </button>
  <button
    id="next-slide"
    class="absolute right-2 md:right-6 z-20 flex h-9 w-9 md:h-12 md:w-12 items-center justify-center rounded-full bg-white/15 text-white backdrop-blur-md transition border border-white/10 hover:bg-white/30 hover:scale-105 active:scale-95 cursor-pointer shadow-md"
    aria-label="Next slide"
  >
    <svg class="h-5 w-5 md:h-6 md:w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
    </svg>
  </button>

  <!-- Slide Indicators (Moved up to prevent overlap with scroll arrow) -->
  <div class="absolute bottom-14 md:bottom-16 left-1/2 z-20 flex -translate-x-1/2 gap-2.5">
    {slides.map((_, index) => (
      <button
        class={`slide-indicator h-2.5 rounded-full transition-all duration-300 cursor-pointer ${index === 0 ? 'bg-accent w-8 shadow-sm' : 'bg-white/45 w-2.5 hover:bg-white/70'}`}
        data-index={index}
        aria-label={`Go to slide ${index + 1}`}
      ></button>
    ))}
  </div>

  <!-- Down scroll chevron (Bottom) -->
  <div class="absolute bottom-4 md:bottom-8 left-1/2 -translate-x-1/2 animate-bounce z-10">
    <svg class="h-7 w-7 text-white/75 drop-shadow-sm" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7"/>
    </svg>
  </div>
</section>

<style is:global>
  /* Base background transitions to cover subpixel gap lines */
  .hero-slide[data-active="true"] .hero-base-bg {
    opacity: 1;
    transition-delay: 1400ms;
  }
  .hero-slide[data-active="false"] .hero-base-bg {
    opacity: 0;
    transition-delay: 0ms;
  }

  /* Base state for all fragments */
  .hero-fragment {
    transition: transform 1.4s cubic-bezier(0.25, 1, 0.5, 1), opacity 1.4s ease-in-out;
    opacity: 0;
  }

  /* Specific initial displacements for transitions when data-active="false" */
  .hero-slide[data-active="false"] [data-fragment="top"] {
    transform: translateY(-45px) scale(1.08);
    opacity: 0;
  }
  .hero-slide[data-active="false"] [data-fragment="right"] {
    transform: translateX(45px) scale(1.08);
    opacity: 0;
  }
  .hero-slide[data-active="false"] [data-fragment="bottom"] {
    transform: translateY(45px) scale(1.08);
    opacity: 0;
  }
  .hero-slide[data-active="false"] [data-fragment="left"] {
    transform: translateX(-45px) scale(1.08);
    opacity: 0;
  }

  /* Active states with staggered delays to replicate "Super Flow" */
  .hero-slide[data-active="true"] .hero-fragment {
    transform: translate(0) scale(1);
    opacity: 1;
  }

  /* Staggered transition delays for assembling */
  .hero-slide[data-active="true"] [data-fragment="top"] {
    transition-delay: 0ms;
  }
  .hero-slide[data-active="true"] [data-fragment="right"] {
    transition-delay: 120ms;
  }
  .hero-slide[data-active="true"] [data-fragment="bottom"] {
    transition-delay: 240ms;
  }
  .hero-slide[data-active="true"] [data-fragment="left"] {
    transition-delay: 360ms;
  }

  /* Optimización para pantallas con poca altura vertical (como laptops o navegadores con muchas barras de herramientas) */
  @media (max-height: 780px) {
    #inicio {
      padding-top: 80px; /* Compensar la altura del Header fijo */
    }
    
    #inicio .relative.z-10 {
      padding-left: 1rem;
      padding-right: 1rem;
    }

    #inicio .inline-flex.items-center.gap-2 {
      margin-bottom: 0.5rem !important; /* Reducir margen del badge */
      font-size: 0.75rem !important;
      padding-top: 0.25rem !important;
      padding-bottom: 0.25rem !important;
    }

    #inicio h1 {
      font-size: 2.25rem !important; /* ~text-4xl */
      margin-bottom: 0.35rem !important;
      line-height: 1.15 !important;
    }
    
    @media (min-width: 640px) {
      #inicio h1 {
        font-size: 3rem !important; /* ~text-5xl */
      }
    }
    
    @media (min-width: 1024px) {
      #inicio h1 {
        font-size: 3.5rem !important; /* ~text-6xl */
      }
    }

    #inicio p {
      font-size: 0.875rem !important; /* ~text-sm */
      margin-top: 0.25rem !important;
      line-height: 1.4 !important;
    }

    #inicio .grid {
      margin-bottom: 1rem !important; /* Reducir espacio entre textos y botones */
    }

    #inicio .flex-col.items-center.gap-3 {
      gap: 0.5rem !important;
    }

    #inicio .slide-indicator {
      bottom: 4rem !important; /* Subir o ajustar la posición de los indicadores */
    }
  }
</style>

<script>
  function setupHeroCarousel() {
    const heroSection = document.getElementById('inicio');
    if (!heroSection || heroSection.hasAttribute('data-carousel-initialized')) return;
    heroSection.setAttribute('data-carousel-initialized', 'true');

    const slides = document.querySelectorAll('.hero-slide');
    const prevBtn = document.getElementById('prev-slide');
    const nextBtn = document.getElementById('next-slide');
    const indicators = document.querySelectorAll('.slide-indicator');
    
    if (slides.length === 0) return;

    let currentIndex = 0;
    let autoplayTimer: any = null;
    const intervalTime = 6000; // 6 seconds auto rotation

    function showSlide(index: number) {
      if (index >= slides.length) index = 0;
      if (index < 0) index = slides.length - 1;

      // Update slide attributes for CSS transitions
      slides.forEach((slide, i) => {
        if (i === index) {
          slide.setAttribute('data-active', 'true');
          slide.classList.remove('invisible');
          slide.classList.add('visible');
        } else {
          slide.setAttribute('data-active', 'false');
          // Wait for transition to complete before setting invisible to prevent sudden clipping
          setTimeout(() => {
            if (slide.getAttribute('data-active') === 'false') {
              slide.classList.remove('visible');
              slide.classList.add('invisible');
            }
          }, 1400);
        }
      });

      // Update dynamic text blocks
      const textBlocks = document.querySelectorAll('.hero-text-block');
      textBlocks.forEach((block, i) => {
        if (i === index) {
          block.classList.remove('opacity-0', 'translate-y-6', 'scale-95', 'pointer-events-none', 'z-0');
          block.classList.add('opacity-100', 'translate-y-0', 'scale-100', 'z-10');
        } else {
          block.classList.remove('opacity-100', 'translate-y-0', 'scale-100', 'z-10');
          block.classList.add('opacity-0', 'translate-y-6', 'scale-95', 'pointer-events-none', 'z-0');
        }
      });

      // Update indicator dots shape/color
      indicators.forEach((indicator, i) => {
        if (i === index) {
          indicator.classList.remove('bg-white/45', 'w-2.5');
          indicator.classList.add('bg-accent', 'w-8');
        } else {
          indicator.classList.remove('bg-accent', 'w-8');
          indicator.classList.add('bg-white/45', 'w-2.5');
        }
      });

      currentIndex = index;
    }

    function nextSlide() {
      showSlide(currentIndex + 1);
    }

    function prevSlide() {
      showSlide(currentIndex - 1);
    }

    function startAutoplay() {
      stopAutoplay();
      autoplayTimer = setInterval(nextSlide, intervalTime);
    }

    function stopAutoplay() {
      if (autoplayTimer) {
        clearInterval(autoplayTimer);
      }
    }

    // Attach event listeners
    if (nextBtn) {
      nextBtn.addEventListener('click', () => {
        nextSlide();
        startAutoplay(); // Reset autoplay timer
      });
    }

    if (prevBtn) {
      prevBtn.addEventListener('click', () => {
        prevSlide();
        startAutoplay(); // Reset autoplay timer
      });
    }

    indicators.forEach((indicator) => {
      indicator.addEventListener('click', () => {
        const idx = Number(indicator.getAttribute('data-index'));
        if (!isNaN(idx)) {
          showSlide(idx);
          startAutoplay(); // Reset autoplay timer
        }
      });
    });

    // Start auto transition
    startAutoplay();
  }

  // Initialize carousel on DOM load and Astro transitions
  document.addEventListener('DOMContentLoaded', setupHeroCarousel);
  document.addEventListener('astro:page-load', setupHeroCarousel);
</script>

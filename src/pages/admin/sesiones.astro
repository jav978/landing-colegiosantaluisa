---
import AdminLayout from '../../components/admin/AdminLayout.astro';
import { getSessionToken, validateSession } from '../../lib/auth';
import { supabase } from '../../lib/db';

const token = getSessionToken(Astro.request);
const session = token ? await validateSession(token) : null;

if (!session) {
  return Astro.redirect('/admin/login');
}

if (session.rol !== 'admin') {
  return Astro.redirect('/admin/dashboard');
}

// Obtener las sesiones activas directamente en el servidor
const { data: sesionesData } = await supabase
  .from('sesiones')
  .select(`
    id, user_id, token, ip_address, user_agent, created_at, expires_at, last_active, deleted_at,
    usuarios ( email, nombre )
  `)
  .is('deleted_at', null)
  .order('last_active', { ascending: false });

const sesiones = sesionesData || [];
---

<AdminLayout
  title="Sesiones Activas"
  userNombre={session.nombre}
  userEmail={session.email}
  userRol={session.rol}
  currentPath={Astro.url.pathname}
>
  <div class="rounded-xl border border-gray-150 bg-white shadow-sm dark:bg-slate-900 dark:border-slate-800">
    <div class="overflow-x-auto">
      <table class="w-full text-left text-sm">
        <thead>
          <tr class="border-b border-gray-150 bg-gray-50 dark:bg-slate-800/50 dark:border-slate-800">
            <th class="px-5 py-3 font-semibold text-gray-600 dark:text-slate-300">Usuario</th>
            <th class="px-5 py-3 font-semibold text-gray-600 dark:text-slate-300">Email</th>
            <th class="px-5 py-3 font-semibold text-gray-600 dark:text-slate-300 max-md:hidden">IP</th>
            <th class="px-5 py-3 font-semibold text-gray-600 dark:text-slate-300 max-lg:hidden">User-Agent</th>
            <th class="px-5 py-3 font-semibold text-gray-600 dark:text-slate-300">Última actividad</th>
            <th class="px-5 py-3 font-semibold text-gray-600 dark:text-slate-300">Expira</th>
            <th class="px-5 py-3 font-semibold text-gray-600 dark:text-slate-300">Acción</th>
          </tr>
        </thead>
        <tbody id="sesiones-table-body">
          {sesiones.length === 0 ? (
            <tr><td colspan="7" class="px-5 py-10 text-center text-gray-400 dark:text-slate-500">No hay sesiones activas</td></tr>
          ) : (
            sesiones.map((s) => {
              const expiresAt = new Date(s.expires_at);
              const lastActive = new Date(s.last_active);
              const isExpired = expiresAt < new Date();
              return (
                <tr class={`border-b border-gray-100 last:border-0 hover:bg-gray-50 dark:border-slate-800 dark:hover:bg-slate-800/40 transition duration-150 ${isExpired ? 'opacity-50' : ''}`}>
                  <td class="px-5 py-4 font-medium text-gray-900 dark:text-white">{s.usuarios?.nombre || '—'}</td>
                  <td class="px-5 py-4 text-gray-600 dark:text-slate-200">{s.usuarios?.email || '—'}</td>
                  <td class="px-5 py-4 font-mono text-xs text-gray-500 dark:text-slate-400 max-md:hidden">{s.ip_address || '—'}</td>
                  <td class="max-w-xs truncate px-5 py-4 text-xs text-gray-500 dark:text-slate-400 max-lg:hidden" title={s.user_agent || ''}>{s.user_agent || '—'}</td>
                  <td class="px-5 py-4 text-gray-600 dark:text-slate-300">{lastActive.toLocaleString('es-VE')}</td>
                  <td class="px-5 py-4 text-gray-600 dark:text-slate-300">{expiresAt.toLocaleString('es-VE')}</td>
                  <td class="px-5 py-4">
                    <button
                      data-id={s.id}
                      class="cerrar-sesion-btn rounded-lg bg-red-50 px-3 py-1.5 text-xs font-medium text-red-600 transition hover:bg-red-100 dark:bg-rose-950/30 dark:text-rose-400 dark:hover:bg-rose-900/40 cursor-pointer"
                    >
                      Cerrar
                    </button>
                  </td>
                </tr>
              );
            })
          )}
        </tbody>
      </table>
    </div>
  </div>
</AdminLayout>

<script>
  import { navigate } from 'astro:transitions/client';

  async function cerrarSesion(id: number) {
    const confirmed = await (window as any).showConfirm(
      '¿Cerrar esta sesión?',
      'Se desconectará al usuario seleccionado.',
      'Cerrar Sesión'
    );
    if (!confirmed) return;

    const res = await fetch(`/api/sesiones/${id}`, { method: 'DELETE' });
    if (res.ok) {
      (window as any).showToast('Sesión cerrada con éxito');
      setTimeout(() => {
        navigate(window.location.pathname);
      }, 1000);
    } else {
      (window as any).showToast('Error al cerrar sesión', 'error');
    }
  }

  function setupSesiones() {
    const buttons = document.querySelectorAll('.cerrar-sesion-btn');
    buttons.forEach((btn) => {
      btn.addEventListener('click', async () => {
        const id = Number(btn.getAttribute('data-id'));
        if (isNaN(id)) return;
        await cerrarSesion(id);
      });
    });
  }

  // Inicializar en la carga inicial y después de cada cambio de página
  document.addEventListener('astro:page-load', () => {
    if (document.getElementById('sesiones-table-body')) {
      setupSesiones();
    }
  });
</script>

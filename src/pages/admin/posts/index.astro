---
import AdminLayout from '../../../components/admin/AdminLayout.astro';
import { getSessionToken, validateSession } from '../../../lib/auth';
import { supabase } from '../../../lib/db';

const token = getSessionToken(Astro.request);
const session = token ? await validateSession(token) : null;

if (!session) {
  return Astro.redirect('/admin/login');
}

// Obtener los posts directamente en el servidor
const { data: postsData } = await supabase
  .from('posts')
  .select(`
    id, title, slug, excerpt, image_url, type, category, published, created_at, updated_at,
    usuarios ( email, nombre )
  `)
  .order('created_at', { ascending: false });

const posts = postsData || [];
---

<AdminLayout
  title="Posts y Anuncios"
  userNombre={session.nombre}
  userEmail={session.email}
  userRol={session.rol}
  currentPath={Astro.url.pathname}
>
  <div class="mb-6 flex items-center justify-between">
    <div class="flex gap-2">
      <button class="filter-btn active rounded-lg border px-3 py-1.5 text-xs font-medium transition bg-primary text-white border-primary" data-filter="">Todos</button>
      <button class="filter-btn rounded-lg border px-3 py-1.5 text-xs font-medium transition text-gray-600 border-gray-200" data-filter="blog">Blog</button>
      <button class="filter-btn rounded-lg border px-3 py-1.5 text-xs font-medium transition text-gray-600 border-gray-200" data-filter="anuncio">Anuncios</button>
    </div>
    <a href="/admin/posts/new" data-astro-prefetch class="rounded-lg bg-primary px-4 py-2 text-sm font-semibold text-white transition hover:bg-primary/90">
      + Nuevo
    </a>
  </div>

  <div class="rounded-xl border bg-white shadow-sm">
    <div class="overflow-x-auto">
      <table class="w-full text-left text-sm">
        <thead>
          <tr class="border-b bg-gray-50">
            <th class="px-5 py-3 font-semibold text-gray-600">Título</th>
            <th class="px-5 py-3 font-semibold text-gray-600">Tipo</th>
            <th class="px-5 py-3 font-semibold text-gray-600 max-md:hidden">Autor</th>
            <th class="px-5 py-3 font-semibold text-gray-600">Estado</th>
            <th class="px-5 py-3 font-semibold text-gray-600 max-md:hidden">Fecha</th>
            <th class="px-5 py-3 font-semibold text-gray-600">Acción</th>
          </tr>
        </thead>
        <tbody id="posts-table-body">
          {posts.length === 0 ? (
            <tr><td colspan="6" class="px-5 py-10 text-center text-gray-400">No hay contenido</td></tr>
          ) : (
            posts.map((p) => {
              const typeLabel = p.type === 'anuncio' ? 'Anuncio' : 'Blog';
              const typeClass = p.type === 'anuncio' ? 'bg-amber-50 text-amber-700' : 'bg-blue-50 text-blue-700';
              const statusLabel = p.published ? 'Publicado' : 'Borrador';
              const statusClass = p.published ? 'bg-emerald-50 text-emerald-700' : 'bg-gray-100 text-gray-600';
              const date = p.created_at ? new Date(p.created_at).toLocaleDateString('es-VE') : '—';
              return (
                <tr class="border-b last:border-0 hover:bg-gray-50 transition duration-150" data-type={p.type} data-post-row>
                  <td class="max-w-xs truncate px-5 py-4 font-medium text-gray-900" title={p.title}>{p.title}</td>
                  <td class="px-5 py-4">
                    <span class={`rounded-full ${typeClass} px-2.5 py-0.5 text-xs font-medium`}>{typeLabel}</span>
                  </td>
                  <td class="px-5 py-4 text-gray-600 max-md:hidden">{p.usuarios?.nombre || '—'}</td>
                  <td class="px-5 py-4">
                    <span class={`rounded-full ${statusClass} px-2.5 py-0.5 text-xs font-medium`}>{statusLabel}</span>
                  </td>
                  <td class="px-5 py-4 text-gray-500 max-md:hidden">{date}</td>
                  <td class="px-5 py-4">
                    <a href={`/admin/posts/${p.id}/edit`} data-astro-prefetch class="rounded-lg bg-gray-50 px-3 py-1.5 text-xs font-medium text-gray-700 transition hover:bg-gray-100">
                      Editar
                    </a>
                  </td>
                </tr>
              );
            })
          )}
        </tbody>
      </table>
    </div>
  </div>
</AdminLayout>

<script>
  function setupFiltering() {
    const buttons = document.querySelectorAll('.filter-btn');
    const rows = document.querySelectorAll('[data-post-row]');

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const filter = (btn as HTMLButtonElement).dataset.filter || '';

        // Actualizar estados visuales de los botones
        buttons.forEach((b) => {
          const isTarget = (b as HTMLButtonElement).dataset.filter === filter;
          b.classList.toggle('active', isTarget);
          b.classList.toggle('bg-primary', isTarget);
          b.classList.toggle('text-white', isTarget);
          b.classList.toggle('border-primary', isTarget);
          b.classList.toggle('text-gray-600', !isTarget);
          b.classList.toggle('border-gray-200', !isTarget);
        });

        // Mostrar / Ocultar filas correspondientes
        rows.forEach((row) => {
          const type = (row as HTMLElement).dataset.type || '';
          if (filter === '' || type === filter) {
            row.classList.remove('hidden');
          } else {
            row.classList.add('hidden');
          }
        });
      });
    });
  }

  // Inicializar en la carga inicial y después de cada navegación SPA de Astro
  document.addEventListener('astro:page-load', () => {
    if (document.querySelector('.filter-btn')) {
      setupFiltering();
    }
  });
</script>

---
import AdminLayout from '../../../../components/admin/AdminLayout.astro';
import { getSessionToken, validateSession } from '../../../../lib/auth';
import { supabase } from '../../../../lib/db';

const token = getSessionToken(Astro.request);
const session = token ? await validateSession(token) : null;

if (!session) {
  return Astro.redirect('/admin/login');
}

const id = Number(Astro.params.id);

const { data: post } = await supabase
  .from('posts')
  .select('*')
  .eq('id', id)
  .single();

if (!post) {
  return Astro.redirect('/admin/posts');
}
---

<AdminLayout
  title="Editar Post"
  userNombre={session.nombre}
  userEmail={session.email}
  userRol={session.rol}
  currentPath={Astro.url.pathname}
>
  <div class="mx-auto max-w-3xl">
    <div class="rounded-xl border border-gray-150 bg-white p-6 shadow-sm dark:bg-slate-900 dark:border-slate-800">
      <form id="post-form" data-id={post.id} class="space-y-5">
        <div class="flex gap-4">
          <div class="flex-1">
            <label for="type" class="mb-1.5 block text-sm font-medium text-gray-700 dark:text-slate-300">Tipo</label>
            <select id="type" name="type" class="w-full rounded-xl border border-gray-200 bg-white px-4 py-3 text-sm outline-none transition focus:border-primary focus:ring-2 focus:ring-primary/20 dark:border-slate-700 dark:bg-slate-800 dark:text-white dark:focus:border-indigo-500 dark:focus:ring-indigo-500/20">
              <option value="blog" selected={post.type === 'blog'}>Blog</option>
              <option value="anuncio" selected={post.type === 'anuncio'}>Anuncio</option>
            </select>
          </div>
          <div class="flex-1">
            <label for="category" class="mb-1.5 block text-sm font-medium text-gray-700 dark:text-slate-300">Categoría</label>
            <input type="text" id="category" name="category" value={post.category || ''} class="w-full rounded-xl border border-gray-200 bg-white px-4 py-3 text-sm outline-none transition focus:border-primary focus:ring-2 focus:ring-primary/20 dark:border-slate-700 dark:bg-slate-800 dark:text-white dark:focus:border-indigo-500 dark:focus:ring-indigo-500/20" placeholder="Ej: Académico, Evento" />
          </div>
        </div>

        <div>
          <label for="title" class="mb-1.5 block text-sm font-medium text-gray-700 dark:text-slate-300">Título</label>
          <input type="text" id="title" name="title" required value={post.title} class="w-full rounded-xl border border-gray-200 bg-white px-4 py-3 text-sm outline-none transition focus:border-primary focus:ring-2 focus:ring-primary/20 dark:border-slate-700 dark:bg-slate-800 dark:text-white dark:focus:border-indigo-500 dark:focus:ring-indigo-500/20" />
        </div>

        <div>
          <label for="excerpt" class="mb-1.5 block text-sm font-medium text-gray-700 dark:text-slate-300">Extracto / Resumen</label>
          <textarea id="excerpt" name="excerpt" rows="2" class="w-full rounded-xl border border-gray-200 bg-white px-4 py-3 text-sm outline-none transition focus:border-primary focus:ring-2 focus:ring-primary/20 dark:border-slate-700 dark:bg-slate-800 dark:text-white dark:focus:border-indigo-500 dark:focus:ring-indigo-500/20">{post.excerpt || ''}</textarea>
        </div>

        <div>
          <label for="content" class="mb-1.5 block text-sm font-medium text-gray-700 dark:text-slate-300">Contenido</label>
          <textarea id="content" name="content" required rows="12" class="w-full rounded-xl border border-gray-200 bg-white px-4 py-3 text-sm outline-none transition focus:border-primary focus:ring-2 focus:ring-primary/20 font-mono dark:border-slate-700 dark:bg-slate-800 dark:text-white dark:focus:border-indigo-500 dark:focus:ring-indigo-500/20">{post.content}</textarea>
        </div>

        <div>
          <label class="mb-2 block text-sm font-medium text-gray-700 dark:text-slate-300">Imágenes destacadas (Máx. 10) <span class="text-red-500">*</span></label>
          <p class="text-xs text-gray-400 dark:text-slate-400 mb-3">Sube hasta 10 imágenes. Cada archivo debe pesar menos de 1MB.</p>
          
          <!-- Botones de pestaña / Toggle de opciones -->
          <div class="mb-4 flex rounded-xl bg-gray-100 p-1 border border-gray-200/80 dark:bg-slate-955 dark:bg-slate-950 dark:border-slate-800">
            <button type="button" id="tab-upload" class="flex-1 rounded-lg py-2 text-center text-xs font-semibold transition duration-200 bg-white text-gray-800 shadow-sm border border-gray-100 dark:bg-slate-800 dark:text-white dark:border-slate-700">
              Subir Archivos
            </button>
            <button type="button" id="tab-url" class="flex-1 rounded-lg py-2 text-center text-xs font-semibold transition duration-200 text-gray-500 hover:text-gray-800 dark:text-slate-400 dark:hover:text-white">
              Agregar Direcciones URL
            </button>
          </div>

          <!-- Opción 1: Carga Manual -->
          <div id="upload-container" class="space-y-3">
            <div class="flex items-center justify-center w-full">
              <label for="image_file" class="flex flex-col items-center justify-center w-full h-36 border-2 border-gray-200 border-dashed rounded-xl cursor-pointer bg-gray-50 hover:bg-gray-100 hover:border-primary/50 transition duration-300 dark:bg-slate-955 dark:bg-slate-950 dark:border-slate-800 dark:hover:bg-slate-900/40">
                <div class="flex flex-col items-center justify-center pt-4 pb-4">
                  <span class="text-2xl mb-1.5">📸</span>
                  <p class="mb-1 text-sm text-gray-500 dark:text-slate-400 font-medium">Haz clic para buscar imágenes</p>
                  <p class="text-xs text-gray-400 dark:text-slate-550">Puedes seleccionar varios archivos (máx. 10)</p>
                </div>
                <input type="file" id="image_file" accept="image/*" multiple class="hidden" />
              </label>
            </div>
          </div>

          <!-- Opción 2: URL de Imagen -->
          <div id="url-container" class="hidden space-y-2">
            <div class="flex gap-2">
              <input type="url" id="image_url_input" class="flex-1 rounded-xl border border-gray-200 bg-white px-4 py-2.5 text-sm outline-none transition focus:border-primary focus:ring-2 focus:ring-primary/20 dark:border-slate-700 dark:bg-slate-800 dark:text-white dark:focus:border-indigo-500 dark:focus:ring-indigo-500/20" placeholder="https://ejemplo.com/imagen.jpg" />
              <button type="button" id="add-url-btn" class="rounded-xl bg-gray-900 px-4 py-2.5 text-sm font-semibold text-white hover:bg-gray-800 transition dark:bg-slate-800 dark:hover:bg-slate-700">
                Añadir
              </button>
            </div>
          </div>

          <!-- Campo oculto donde guardaremos el JSON final de las imágenes -->
          <input type="hidden" id="image_url" name="image_url" value={post.image_url || ''} />

          <!-- Vista previa de las imágenes en cuadrícula -->
          <div id="image-preview-container" class="hidden mt-4">
            <p class="text-xs font-semibold text-gray-500 dark:text-slate-400 mb-2">Imágenes seleccionadas (<span id="image-count">0</span>/10):</p>
            <div id="image-preview-grid" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-3">
              <!-- Los elementos se agregarán dinámicamente aquí -->
            </div>
          </div>
        </div>

        <div class="flex items-center gap-2">
          <input type="checkbox" id="published" name="published" value="true" checked={post.published} class="h-4 w-4 rounded border-gray-300 text-primary focus:ring-primary dark:bg-slate-800 dark:border-slate-700" />
          <label for="published" class="text-sm text-gray-700 dark:text-slate-300">Publicado</label>
        </div>

        <div id="error-msg" class="hidden rounded-lg bg-red-50 px-4 py-3 text-sm text-red-600 dark:bg-rose-950/30 dark:text-rose-400"></div>

        <div class="flex items-center gap-3">
          <button type="submit" id="submit-btn" class="rounded-lg bg-primary px-6 py-2.5 text-sm font-semibold text-white transition hover:bg-primary/90 cursor-pointer">
            Guardar cambios
          </button>
          <a href="/admin/posts" class="rounded-lg border border-gray-200 bg-white px-6 py-2.5 text-sm font-semibold text-gray-700 transition hover:bg-gray-50 dark:bg-slate-800 dark:border-slate-700 dark:text-slate-200 dark:hover:bg-slate-700/80">
            Cancelar
          </a>
          <button type="button" id="delete-btn" class="ml-auto rounded-lg bg-red-50 px-4 py-2.5 text-sm font-medium text-red-600 transition hover:bg-red-100 dark:bg-rose-950/30 dark:text-rose-400 dark:hover:bg-rose-900/40 cursor-pointer">
            Eliminar
          </button>
        </div>
      </form>
    </div>
  </div>
</AdminLayout>

<script>
  import { navigate } from 'astro:transitions/client';

  function compressImage(file: File, maxWidth = 1000, maxHeight = 1000, quality = 0.75): Promise<string> {
    return new Promise((resolve, reject) => {
      if (!file.type.startsWith('image/')) {
        reject(new Error('El archivo no es una imagen.'));
        return;
      }

      const reader = new FileReader();
      reader.readAsDataURL(file);
      reader.onload = (event) => {
        const img = new Image();
        img.src = event.target?.result as string;
        img.onload = () => {
          const canvas = document.createElement('canvas');
          let width = img.width;
          let height = img.height;

          if (width > height) {
            if (width > maxWidth) {
              height = Math.round((height * maxWidth) / width);
              width = maxWidth;
            }
          } else {
            if (height > maxHeight) {
              width = Math.round((width * maxHeight) / height);
              height = maxHeight;
            }
          }

          canvas.width = width;
          canvas.height = height;

          const ctx = canvas.getContext('2d');
          if (!ctx) {
            resolve(event.target?.result as string);
            return;
          }

          ctx.drawImage(img, 0, 0, width, height);
          const compressedDataUrl = canvas.toDataURL('image/jpeg', quality);
          resolve(compressedDataUrl);
        };
        img.onerror = (err) => reject(err);
      };
      reader.onerror = (err) => reject(err);
    });
  }

  function setupEditPost() {
    const form = document.getElementById('post-form') as HTMLFormElement | null;
    if (!form) return;

    const tabUpload = document.getElementById('tab-upload');
    const tabUrl = document.getElementById('tab-url');
    const uploadContainer = document.getElementById('upload-container');
    const urlContainer = document.getElementById('url-container');
    
    const imageFile = document.getElementById('image_file') as HTMLInputElement | null;
    const imageUrlInput = document.getElementById('image_url_input') as HTMLInputElement | null;
    const addUrlBtn = document.getElementById('add-url-btn');
    const imageUrlHidden = document.getElementById('image_url') as HTMLInputElement | null;
    
    const previewContainer = document.getElementById('image-preview-container');
    const previewGrid = document.getElementById('image-preview-grid');
    const countEl = document.getElementById('image-count');

    let imagesList: string[] = [];
    let currentMode = 'upload';

    function setMode(mode: 'upload' | 'url') {
      currentMode = mode;
      if (mode === 'upload') {
        tabUpload?.classList.add('bg-white', 'text-gray-800', 'shadow-sm', 'border', 'border-gray-100');
        tabUpload?.classList.remove('text-gray-500', 'hover:text-gray-800');
        tabUrl?.classList.add('text-gray-500', 'hover:text-gray-800');
        tabUrl?.classList.remove('bg-white', 'text-gray-800', 'shadow-sm', 'border', 'border-gray-100');
        
        uploadContainer?.classList.remove('hidden');
        urlContainer?.classList.add('hidden');
      } else {
        tabUrl?.classList.add('bg-white', 'text-gray-800', 'shadow-sm', 'border', 'border-gray-100');
        tabUrl?.classList.remove('text-gray-500', 'hover:text-gray-800');
        tabUpload?.classList.add('text-gray-500', 'hover:text-gray-800');
        tabUpload?.classList.remove('bg-white', 'text-gray-800', 'shadow-sm', 'border', 'border-gray-100');
        
        urlContainer?.classList.remove('hidden');
        uploadContainer?.classList.add('hidden');
      }
    }

    tabUpload?.addEventListener('click', () => setMode('upload'));
    tabUrl?.addEventListener('click', () => setMode('url'));

    function renderImages() {
      if (!previewGrid || !countEl || !previewContainer || !imageUrlHidden) return;

      countEl.textContent = String(imagesList.length);
      previewGrid.innerHTML = '';

      if (imagesList.length === 0) {
        previewContainer.classList.add('hidden');
        imageUrlHidden.value = '';
        return;
      }

      previewContainer.classList.remove('hidden');
      imageUrlHidden.value = JSON.stringify(imagesList);

      imagesList.forEach((src, idx) => {
        const wrapper = document.createElement('div');
        wrapper.className = 'relative group aspect-square rounded-lg overflow-hidden border border-gray-200 bg-gray-50 p-1 dark:border-slate-800 dark:bg-slate-950';

        const img = document.createElement('img');
        img.src = src;
        img.className = 'w-full h-full object-cover rounded-md';

        const delBtn = document.createElement('button');
        delBtn.type = 'button';
        delBtn.className = 'absolute top-1.5 right-1.5 bg-red-600 hover:bg-red-700 text-white w-6 h-6 rounded-full shadow-md transition duration-200 text-xs font-bold flex items-center justify-center';
        delBtn.innerHTML = '✕';
        delBtn.addEventListener('click', () => {
          imagesList.splice(idx, 1);
          renderImages();
        });

        wrapper.appendChild(img);
        wrapper.appendChild(delBtn);
        previewGrid.appendChild(wrapper);
      });
    }

    // Inicializar lista de imágenes existentes (Soporta JSON array y formato string legacy)
    const initialVal = imageUrlHidden?.value || '';
    if (initialVal.startsWith('[')) {
      try {
        imagesList = JSON.parse(initialVal);
      } catch (e) {
        if (initialVal) imagesList = [initialVal];
      }
    } else if (initialVal) {
      imagesList = [initialVal];
    }

    // Inicializar el modo de visualización de pestaña
    if (imagesList.length > 0 && !imagesList[0].startsWith('data:')) {
      setMode('url');
    } else {
      setMode('upload');
    }
    
    renderImages();

    // Carga de archivos múltiples con validación de tamaño < 1MB
    imageFile?.addEventListener('change', async () => {
      const files = imageFile.files;
      if (!files) return;

      for (let i = 0; i < files.length; i++) {
        const file = files[i];
        
        if (imagesList.length >= 10) {
          (window as any).showToast('Has alcanzado el límite máximo de 10 imágenes.', 'warning');
          break;
        }

        // Validación de tamaño (menos de 1MB)
        if (file.size >= 1024 * 1024) {
          (window as any).showToast(`El archivo "${file.name}" supera el límite de 1MB. Selecciona una imagen de menor tamaño.`, 'warning');
          continue;
        }

        try {
          const base64 = await compressImage(file);
          imagesList.push(base64);
        } catch (err) {
          console.error('Error al procesar archivo:', err);
          const base64 = await new Promise<string>((resolve) => {
            const reader = new FileReader();
            reader.onload = (event) => resolve(event.target?.result as string);
            reader.readAsDataURL(file);
          });
          imagesList.push(base64);
        }
      }

      imageFile.value = '';
      renderImages();
    });

    // Agregar URL dinámica
    addUrlBtn?.addEventListener('click', () => {
      if (!imageUrlInput) return;
      const url = imageUrlInput.value.trim();
      
      if (!url) return;

      if (imagesList.length >= 10) {
        (window as any).showToast('Has alcanzado el límite máximo de 10 imágenes.', 'warning');
        return;
      }

      imagesList.push(url);
      imageUrlInput.value = '';
      renderImages();
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const errorMsg = document.getElementById('error-msg');
      const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;
      if (!errorMsg || !submitBtn) return;

      errorMsg.classList.add('hidden');
      
      if (imagesList.length === 0) {
        errorMsg.textContent = 'La imagen destacada es requerida (debes subir o agregar al menos una).';
        errorMsg.classList.remove('hidden');
        return;
      }

      submitBtn.disabled = true;
      submitBtn.textContent = 'Guardando...';

      const postId = form.dataset.id;
      const formData = new FormData(form);

      const res = await fetch(`/api/posts/${postId}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          title: formData.get('title'),
          content: formData.get('content'),
          excerpt: formData.get('excerpt'),
          image_url: JSON.stringify(imagesList), // Guardar como cadena JSON en la base de datos
          type: formData.get('type'),
          category: formData.get('category'),
          published: formData.get('published') === 'true',
        }),
      });

      const data = await res.json();

      if (res.ok) {
        sessionStorage.setItem('flash_message', JSON.stringify({ title: 'Post actualizado con éxito', icon: 'success' }));
        navigate('/admin/posts');
      } else {
        errorMsg.textContent = data.error || 'Error al guardar';
        errorMsg.classList.remove('hidden');
        submitBtn.disabled = false;
        submitBtn.textContent = 'Guardar cambios';
      }
    });

    if (deleteBtn) {
      const newDeleteBtn = deleteBtn.cloneNode(true);
      deleteBtn.parentNode?.replaceChild(newDeleteBtn, deleteBtn);

      newDeleteBtn.addEventListener('click', async () => {
        const confirmed = await (window as any).showConfirm(
          '¿Eliminar post?',
          '¿Eliminar este post definitivamente?',
          'Eliminar'
        );
        if (!confirmed) return;

        const postId = form.dataset.id;
        const res = await fetch(`/api/posts/${postId}`, { method: 'DELETE' });

        if (res.ok) {
          sessionStorage.setItem('flash_message', JSON.stringify({ title: 'Post eliminado con éxito', icon: 'success' }));
          navigate('/admin/posts');
        } else {
          (window as any).showToast('Error al eliminar', 'error');
        }
      });
    }
  }

  // Inicializar en la carga inicial y después de cada cambio de página
  document.addEventListener('astro:page-load', () => {
    if (document.getElementById('post-form')) {
      setupEditPost();
    }
  });
</script>

---
import AdminLayout from '../../../../components/admin/AdminLayout.astro';
import { getSessionToken, validateSession } from '../../../../lib/auth';
import { supabase } from '../../../../lib/db';

const token = getSessionToken(Astro.request);
const session = token ? await validateSession(token) : null;

if (!session) {
  return Astro.redirect('/admin/login');
}

const id = Number(Astro.params.id);

const { data: post } = await supabase
  .from('posts')
  .select('*')
  .eq('id', id)
  .single();

if (!post) {
  return Astro.redirect('/admin/posts');
}
---

<AdminLayout
  title="Editar Post"
  userNombre={session.nombre}
  userEmail={session.email}
  userRol={session.rol}
  currentPath={Astro.url.pathname}
>
  <div class="mx-auto max-w-3xl">
    <div class="rounded-xl border bg-white p-6 shadow-sm">
      <form id="post-form" class="space-y-5">
        <div class="flex gap-4">
          <div class="flex-1">
            <label for="type" class="mb-1.5 block text-sm font-medium text-gray-700">Tipo</label>
            <select id="type" name="type" class="w-full rounded-xl border border-gray-200 px-4 py-3 text-sm outline-none transition focus:border-primary focus:ring-2 focus:ring-primary/20">
              <option value="blog" {post.type === 'blog' ? 'selected' : ''}>Blog</option>
              <option value="anuncio" {post.type === 'anuncio' ? 'selected' : ''}>Anuncio</option>
            </select>
          </div>
          <div class="flex-1">
            <label for="category" class="mb-1.5 block text-sm font-medium text-gray-700">Categoría</label>
            <input type="text" id="category" name="category" value={post.category || ''} class="w-full rounded-xl border border-gray-200 px-4 py-3 text-sm outline-none transition focus:border-primary focus:ring-2 focus:ring-primary/20" placeholder="Ej: Académico, Evento" />
          </div>
        </div>

        <div>
          <label for="title" class="mb-1.5 block text-sm font-medium text-gray-700">Título</label>
          <input type="text" id="title" name="title" required value={post.title} class="w-full rounded-xl border border-gray-200 px-4 py-3 text-sm outline-none transition focus:border-primary focus:ring-2 focus:ring-primary/20" />
        </div>

        <div>
          <label for="excerpt" class="mb-1.5 block text-sm font-medium text-gray-700">Extracto / Resumen</label>
          <textarea id="excerpt" name="excerpt" rows="2" class="w-full rounded-xl border border-gray-200 px-4 py-3 text-sm outline-none transition focus:border-primary focus:ring-2 focus:ring-primary/20">{post.excerpt || ''}</textarea>
        </div>

        <div>
          <label for="content" class="mb-1.5 block text-sm font-medium text-gray-700">Contenido</label>
          <textarea id="content" name="content" required rows="12" class="w-full rounded-xl border border-gray-200 px-4 py-3 text-sm outline-none transition focus:border-primary focus:ring-2 focus:ring-primary/20 font-mono">{post.content}</textarea>
        </div>

        <div>
          <label class="mb-2 block text-sm font-medium text-gray-700">Imagen destacada <span class="text-red-500">*</span></label>
          
          <!-- Botones de pestaña / Toggle de opciones -->
          <div class="mb-4 flex rounded-xl bg-gray-100 p-1 border border-gray-200/80">
            <button type="button" id="tab-upload" class="flex-1 rounded-lg py-2 text-center text-xs font-semibold transition duration-200 text-gray-500 hover:text-gray-800">
              Subir Archivo
            </button>
            <button type="button" id="tab-url" class="flex-1 rounded-lg py-2 text-center text-xs font-semibold transition duration-200 text-gray-500 hover:text-gray-800">
              Dirección URL
            </button>
          </div>

          <!-- Opción 1: Carga Manual -->
          <div id="upload-container" class="space-y-3">
            <div class="flex items-center justify-center w-full">
              <label for="image_file" class="flex flex-col items-center justify-center w-full h-36 border-2 border-gray-200 border-dashed rounded-xl cursor-pointer bg-gray-50 hover:bg-gray-100 hover:border-primary/50 transition duration-300">
                <div class="flex flex-col items-center justify-center pt-4 pb-4">
                  <span class="text-2xl mb-1.5">📸</span>
                  <p class="mb-1 text-sm text-gray-500 font-medium">Haz clic para buscar imagen</p>
                  <p class="text-xs text-gray-400">PNG, JPG, JPEG o WEBP</p>
                </div>
                <input type="file" id="image_file" accept="image/*" class="hidden" />
              </label>
            </div>
          </div>

          <!-- Opción 2: URL de Imagen -->
          <div id="url-container" class="hidden">
            <input type="url" id="image_url_input" value={post.image_url && !post.image_url.startsWith('data:') ? post.image_url : ''} class="w-full rounded-xl border border-gray-200 px-4 py-3 text-sm outline-none transition focus:border-primary focus:ring-2 focus:ring-primary/20" placeholder="https://ejemplo.com/imagen.jpg" />
          </div>

          <!-- Campo oculto donde guardaremos el Base64 o la URL final -->
          <input type="hidden" id="image_url" name="image_url" value={post.image_url || ''} />

          <!-- Vista previa de la imagen -->
          <div id="image-preview-container" class={post.image_url ? "mt-4 relative rounded-xl overflow-hidden border border-gray-200 bg-gray-50 p-2" : "hidden mt-4 relative rounded-xl overflow-hidden border border-gray-200 bg-gray-50 p-2"}>
            <img id="image-preview" src={post.image_url || '#'} alt="Vista previa" class="max-h-48 w-full object-cover rounded-lg" />
            <button type="button" id="remove-image-btn" class="absolute top-4 right-4 bg-red-600 hover:bg-red-700 text-white px-3 py-1.5 rounded-lg shadow-lg transition duration-200 text-xs font-semibold flex items-center gap-1.5">
              <span>✕</span> Quitar
            </button>
          </div>
        </div>

        <div class="flex items-center gap-2">
          <input type="checkbox" id="published" name="published" value="true" {post.published ? 'checked' : ''} class="h-4 w-4 rounded border-gray-300 text-primary focus:ring-primary" />
          <label for="published" class="text-sm text-gray-700">Publicado</label>
        </div>

        <div id="error-msg" class="hidden rounded-lg bg-red-50 px-4 py-3 text-sm text-red-600"></div>

        <div class="flex items-center gap-3">
          <button type="submit" id="submit-btn" class="rounded-lg bg-primary px-6 py-2.5 text-sm font-semibold text-white transition hover:bg-primary/90">
            Guardar cambios
          </button>
          <a href="/admin/posts" class="rounded-lg border border-gray-200 px-6 py-2.5 text-sm font-semibold text-gray-700 transition hover:bg-gray-50">
            Cancelar
          </a>
          <button type="button" id="delete-btn" class="ml-auto rounded-lg bg-red-50 px-4 py-2.5 text-sm font-medium text-red-600 transition hover:bg-red-100">
            Eliminar
          </button>
        </div>
      </form>
    </div>
  </div>
</AdminLayout>

<script>
  import { navigate } from 'astro:transitions/client';

  function setupEditPost() {
    const form = document.getElementById('post-form') as HTMLFormElement | null;
    if (!form) return;

    const tabUpload = document.getElementById('tab-upload');
    const tabUrl = document.getElementById('tab-url');
    const uploadContainer = document.getElementById('upload-container');
    const urlContainer = document.getElementById('url-container');
    
    const imageFile = document.getElementById('image_file') as HTMLInputElement | null;
    const imageUrlInput = document.getElementById('image_url_input') as HTMLInputElement | null;
    const imageUrlHidden = document.getElementById('image_url') as HTMLInputElement | null;
    
    const previewContainer = document.getElementById('image-preview-container');
    const previewImage = document.getElementById('image-preview') as HTMLImageElement | null;
    const removeBtn = document.getElementById('remove-image-btn');

    let currentMode = 'upload';

    function setMode(mode: 'upload' | 'url') {
      currentMode = mode;
      if (mode === 'upload') {
        tabUpload?.classList.add('bg-white', 'text-gray-800', 'shadow-sm', 'border', 'border-gray-100');
        tabUpload?.classList.remove('text-gray-500', 'hover:text-gray-800');
        tabUrl?.classList.add('text-gray-500', 'hover:text-gray-800');
        tabUrl?.classList.remove('bg-white', 'text-gray-800', 'shadow-sm', 'border', 'border-gray-100');
        
        uploadContainer?.classList.remove('hidden');
        urlContainer?.classList.add('hidden');
      } else {
        tabUrl?.classList.add('bg-white', 'text-gray-800', 'shadow-sm', 'border', 'border-gray-100');
        tabUrl?.classList.remove('text-gray-500', 'hover:text-gray-800');
        tabUpload?.classList.add('text-gray-500', 'hover:text-gray-800');
        tabUpload?.classList.remove('bg-white', 'text-gray-800', 'shadow-sm', 'border', 'border-gray-100');
        
        urlContainer?.classList.remove('hidden');
        uploadContainer?.classList.add('hidden');
      }
    }

    // Inicializar modo según la imagen existente
    const initialVal = imageUrlHidden?.value || '';
    if (initialVal.startsWith('data:')) {
      setMode('upload');
    } else if (initialVal) {
      setMode('url');
    } else {
      setMode('upload');
    }

    tabUpload?.addEventListener('click', () => setMode('upload'));
    tabUrl?.addEventListener('click', () => setMode('url'));

    // Carga de archivo
    imageFile?.addEventListener('change', () => {
      const file = imageFile.files?.[0];
      if (file) {
        const reader = new FileReader();
        reader.onload = (event) => {
          const base64 = event.target?.result as string;
          if (imageUrlHidden) imageUrlHidden.value = base64;
          if (previewImage) previewImage.src = base64;
          previewContainer?.classList.remove('hidden');
        };
        reader.readAsDataURL(file);
      }
    });

    // Cambios en input de URL
    imageUrlInput?.addEventListener('input', () => {
      const val = imageUrlInput.value.trim();
      if (val) {
        if (imageUrlHidden) imageUrlHidden.value = val;
        if (previewImage) previewImage.src = val;
        previewContainer?.classList.remove('hidden');
      } else {
        if (imageUrlHidden) imageUrlHidden.value = '';
        previewContainer?.classList.add('hidden');
      }
    });

    // Quitar imagen
    removeBtn?.addEventListener('click', () => {
      if (imageFile) imageFile.value = '';
      if (imageUrlInput) imageUrlInput.value = '';
      if (imageUrlHidden) imageUrlHidden.value = '';
      if (previewImage) previewImage.src = '#';
      previewContainer?.classList.add('hidden');
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const errorMsg = document.getElementById('error-msg');
      const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;
      if (!errorMsg || !submitBtn) return;

      errorMsg.classList.add('hidden');
      
      const imageUrlValue = imageUrlHidden?.value || '';
      if (!imageUrlValue) {
        errorMsg.textContent = 'La imagen destacada es requerida.';
        errorMsg.classList.remove('hidden');
        return;
      }

      submitBtn.disabled = true;
      submitBtn.textContent = 'Guardando...';

      const postId = window.location.pathname.split('/').filter(Boolean).pop();
      const formData = new FormData(form);

      const res = await fetch(`/api/posts/${postId}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          title: formData.get('title'),
          content: formData.get('content'),
          excerpt: formData.get('excerpt'),
          image_url: imageUrlValue,
          type: formData.get('type'),
          category: formData.get('category'),
          published: formData.get('published') === 'true',
        }),
      });

      const data = await res.json();

      if (res.ok) {
        navigate('/admin/posts');
      } else {
        errorMsg.textContent = data.error || 'Error al guardar';
        errorMsg.classList.remove('hidden');
        submitBtn.disabled = false;
        submitBtn.textContent = 'Guardar cambios';
      }
    });

    const deleteBtn = document.getElementById('delete-btn');
    if (deleteBtn) {
      const newDeleteBtn = deleteBtn.cloneNode(true);
      deleteBtn.parentNode?.replaceChild(newDeleteBtn, deleteBtn);

      newDeleteBtn.addEventListener('click', async () => {
        if (!confirm('¿Eliminar este post definitivamente?')) return;

        const postId = window.location.pathname.split('/').filter(Boolean).pop();
        const res = await fetch(`/api/posts/${postId}`, { method: 'DELETE' });

        if (res.ok) {
          navigate('/admin/posts');
        } else {
          alert('Error al eliminar');
        }
      });
    }
  }

  // Inicializar en la carga inicial y después de cada cambio de página
  document.addEventListener('astro:page-load', () => {
    if (document.getElementById('post-form')) {
      setupEditPost();
    }
  });
</script>

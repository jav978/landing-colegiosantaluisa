---
import AdminLayout from '../../../components/admin/AdminLayout.astro';
import { getSessionToken, validateSession } from '../../../lib/auth';
import { supabase } from '../../../lib/db';

const token = getSessionToken(Astro.request);
const session = token ? await validateSession(token) : null;

if (!session) {
  return Astro.redirect('/admin/login');
}

// Fetch gallery albums from database
const { data: dbAlbums } = await supabase
  .from('gallery_albums')
  .select('*')
  .order('created_at', { ascending: false });

const albums = dbAlbums || [];
---

<AdminLayout
  title="Galería de Fotos"
  userNombre={session.nombre}
  userEmail={session.email}
  userRol={session.rol}
  currentPath="/admin/galeria"
>
  <div class="mb-6 flex items-center justify-between">
    <div>
      <h2 class="text-lg font-bold text-gray-900">Álbumes Registrados</h2>
      <p class="text-xs text-gray-500">Administra los eventos y fotos que se muestran en la sección de la Galería pública</p>
    </div>
    <a href="/admin/galeria/new" data-astro-prefetch class="rounded-lg bg-primary px-4 py-2 text-sm font-semibold text-white transition hover:bg-primary/90">
      + Nuevo Álbum
    </a>
  </div>

  <div class="rounded-xl border bg-white shadow-sm">
    <div class="overflow-x-auto">
      <table class="w-full text-left text-sm">
        <thead>
          <tr class="border-b bg-gray-50">
            <th class="px-5 py-3 font-semibold text-gray-600">Portada</th>
            <th class="px-5 py-3 font-semibold text-gray-600">Título</th>
            <th class="px-5 py-3 font-semibold text-gray-600 max-md:hidden">Descripción</th>
            <th class="px-5 py-3 font-semibold text-gray-600">N° Fotos</th>
            <th class="px-5 py-3 font-semibold text-gray-600 max-md:hidden">Creado</th>
            <th class="px-5 py-3 font-semibold text-gray-600">Acción</th>
          </tr>
        </thead>
        <tbody>
          {albums.length === 0 ? (
            <tr><td colspan="6" class="px-5 py-10 text-center text-gray-400">No hay álbumes registrados en la galería. Crea uno nuevo.</td></tr>
          ) : (
            albums.map((al) => {
              const cover = al.images && al.images[0] ? al.images[0] : '';
              const date = new Date(al.created_at).toLocaleDateString('es-VE', {
                year: 'numeric',
                month: 'short',
                day: 'numeric'
              });
              return (
                <tr class="border-b last:border-0 hover:bg-gray-50 transition duration-150">
                  <td class="px-5 py-3">
                    {cover ? (
                      <img src={cover} alt={al.title} class="h-12 w-16 rounded-lg object-cover border bg-gray-50 shadow-sm" />
                    ) : (
                      <div class="flex h-12 w-16 items-center justify-center rounded-lg bg-gray-100 text-gray-400 text-xs font-semibold">
                        Sin foto
                      </div>
                    )}
                  </td>
                  <td class="px-5 py-3 font-semibold text-gray-900">{al.title}</td>
                  <td class="px-5 py-3 text-gray-500 max-md:hidden max-w-sm truncate" title={al.description || ''}>
                    {al.description || <em class="text-gray-300">Sin descripción</em>}
                  </td>
                  <td class="px-5 py-3 text-gray-700 font-bold">
                    <span class="inline-flex items-center gap-1 rounded-full bg-primary/5 px-2.5 py-0.5 text-xs text-primary">
                      📷 {al.images ? al.images.length : 0}
                    </span>
                  </td>
                  <td class="px-5 py-3 text-gray-500 max-md:hidden">{date}</td>
                  <td class="px-5 py-3">
                    <div class="flex items-center gap-2">
                      <a
                        href={`/admin/galeria/${al.id}/edit`}
                        data-astro-prefetch
                        class="inline-flex h-8 w-8 items-center justify-center rounded-lg bg-slate-50 text-slate-700 border border-slate-200 transition hover:bg-slate-100 hover:text-slate-900"
                        title="Editar"
                      >
                        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
                        </svg>
                      </a>
                      <button 
                        class="delete-btn inline-flex h-8 w-8 items-center justify-center rounded-lg bg-rose-50 text-rose-700 border border-rose-100 transition hover:bg-rose-100 hover:text-rose-900 cursor-pointer"
                        data-id={al.id}
                        data-title={al.title}
                        title="Eliminar"
                      >
                        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                        </svg>
                      </button>
                    </div>
                  </td>
                </tr>
              );
            })
          )}
        </tbody>
      </table>
    </div>
  </div>
</AdminLayout>

<script>
  function setupDeletion() {
    const deleteBtns = document.querySelectorAll('.delete-btn');
    deleteBtns.forEach((btn) => {
      btn.addEventListener('click', async () => {
        const id = (btn as HTMLElement).dataset.id;
        const title = (btn as HTMLElement).dataset.title;

        if (!id || !confirm(`¿Estás seguro de que deseas eliminar el álbum de fotos "${title}"?`)) return;

        try {
          const res = await fetch(`/api/admin/gallery/${id}`, {
            method: 'DELETE',
          });
          
          if (res.ok) {
            window.location.reload();
          } else {
            const data = await res.json();
            alert(`Error: ${data.error || 'No se pudo eliminar el álbum'}`);
          }
        } catch (err) {
          console.error(err);
          alert('Error de conexión al eliminar');
        }
      });
    });
  }

  document.addEventListener('astro:page-load', () => {
    if (document.querySelector('.delete-btn')) {
      setupDeletion();
    }
  });
</script>

---
import AdminLayout from '../../../../components/admin/AdminLayout.astro';
import { getSessionToken, validateSession } from '../../../../lib/auth';
import { supabase } from '../../../../lib/db';

const token = getSessionToken(Astro.request);
const session = token ? await validateSession(token) : null;

if (!session) {
  return Astro.redirect('/admin/login');
}

if (session.rol !== 'admin') {
  return Astro.redirect('/admin/dashboard');
}

const id = Number(Astro.params.id);
if (isNaN(id)) {
  return Astro.redirect('/admin/testimonios');
}

const { data: testimonio } = await supabase
  .from('testimonios')
  .select('*')
  .eq('id', id)
  .single();

if (!testimonio) {
  return Astro.redirect('/admin/testimonios');
}
---

<AdminLayout
  title="Editar Testimonio"
  userNombre={session.nombre}
  userEmail={session.email}
  userRol={session.rol}
  currentPath={Astro.url.pathname}
>
  <div class="mx-auto max-w-3xl">
    <div class="rounded-xl border border-gray-150 bg-white p-6 shadow-sm dark:bg-slate-900 dark:border-slate-800">
      <form id="testimonio-form" data-id={testimonio.id} class="space-y-5">
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
          <div>
            <label for="autor" class="mb-1.5 block text-sm font-medium text-gray-700 dark:text-slate-300">Autor <span class="text-red-500">*</span></label>
            <input
              type="text"
              id="autor"
              name="autor"
              required
              value={testimonio.autor}
              class="w-full rounded-xl border border-gray-200 bg-white px-4 py-3 text-sm outline-none transition focus:border-primary focus:ring-2 focus:ring-primary/20 dark:border-slate-700 dark:bg-slate-800 dark:text-white dark:focus:border-indigo-500 dark:focus:ring-indigo-500/20"
            />
          </div>
          <div>
            <label for="rol" class="mb-1.5 block text-sm font-medium text-gray-700 dark:text-slate-300">Rol <span class="text-red-500">*</span></label>
            <input
              type="text"
              id="rol"
              name="rol"
              required
              value={testimonio.rol}
              class="w-full rounded-xl border border-gray-200 bg-white px-4 py-3 text-sm outline-none transition focus:border-primary focus:ring-2 focus:ring-primary/20 dark:border-slate-700 dark:bg-slate-800 dark:text-white dark:focus:border-indigo-500 dark:focus:ring-indigo-500/20"
            />
          </div>
        </div>

        <div>
          <label for="texto" class="mb-1.5 block text-sm font-medium text-gray-700 dark:text-slate-300">Testimonio <span class="text-red-500">*</span></label>
          <textarea
            id="texto"
            name="texto"
            required
            rows="4"
            class="w-full rounded-xl border border-gray-200 bg-white px-4 py-3 text-sm outline-none transition focus:border-primary focus:ring-2 focus:ring-primary/20 dark:border-slate-700 dark:bg-slate-800 dark:text-white dark:focus:border-indigo-500 dark:focus:ring-indigo-500/20"
          >{testimonio.texto}</textarea>
        </div>

        <div>
          <label class="mb-2 block text-sm font-medium text-gray-700 dark:text-slate-300">Foto de perfil (Opcional)</label>
          <p class="text-xs text-gray-400 dark:text-slate-400 mb-3">Sube una foto de perfil o ingresa una dirección URL. Si se deja en blanco, se generará un avatar con iniciales.</p>

          <!-- Toggle tabs -->
          <div class="mb-4 flex rounded-xl bg-gray-100 p-1 border border-gray-200/80 dark:bg-slate-955 dark:bg-slate-950 dark:border-slate-800">
            <button type="button" id="tab-upload" class="flex-1 rounded-lg py-2 text-center text-xs font-semibold transition duration-200 bg-white text-gray-800 shadow-sm border border-gray-100 dark:bg-slate-800 dark:text-white dark:border-slate-700">
              Subir Foto
            </button>
            <button type="button" id="tab-url" class="flex-1 rounded-lg py-2 text-center text-xs font-semibold transition duration-200 text-gray-500 hover:text-gray-800 dark:text-slate-400 dark:hover:text-white">
              Dirección URL
            </button>
          </div>

          <!-- Upload manual -->
          <div id="upload-container" class="space-y-3">
            <div class="flex items-center justify-center w-full">
              <label for="image_file" class="flex flex-col items-center justify-center w-full h-32 border-2 border-gray-200 border-dashed rounded-xl cursor-pointer bg-gray-50 hover:bg-gray-100 hover:border-primary/50 transition duration-300 dark:bg-slate-950 dark:border-slate-800 dark:hover:bg-slate-900/40">
                <div class="flex flex-col items-center justify-center pt-4 pb-4">
                  <span class="text-2xl mb-1.5">📸</span>
                  <p class="mb-1 text-sm text-gray-500 dark:text-slate-400 font-medium">Haz clic para buscar imagen</p>
                  <p class="text-xs text-gray-400 dark:text-slate-550">Máx. 1MB</p>
                </div>
                <input type="file" id="image_file" accept="image/*" class="hidden" />
              </label>
            </div>
          </div>

          <!-- URL input -->
          <div id="url-container" class="hidden space-y-2">
            <div class="flex gap-2">
              <input
                type="url"
                id="image_url_input"
                class="flex-1 rounded-xl border border-gray-200 bg-white px-4 py-2.5 text-sm outline-none transition focus:border-primary focus:ring-2 focus:ring-primary/20 dark:border-slate-700 dark:bg-slate-800 dark:text-white dark:focus:border-indigo-500 dark:focus:ring-indigo-500/20"
                placeholder="https://ejemplo.com/foto.jpg"
              />
              <button type="button" id="add-url-btn" class="rounded-xl bg-gray-900 px-4 py-2.5 text-sm font-semibold text-white hover:bg-gray-800 transition dark:bg-slate-800 dark:hover:bg-slate-700">
                Usar URL
              </button>
            </div>
          </div>

          <!-- Hidden Input for actual value to send -->
          <input type="hidden" id="image_url" name="image_url" value={testimonio.image_url || ''} />

          <!-- Preview -->
          <div id="image-preview-container" class="hidden mt-4">
            <p class="text-xs font-semibold text-gray-500 dark:text-slate-400 mb-2">Vista previa de la foto:</p>
            <div class="relative w-24 h-24 rounded-full overflow-hidden border-2 border-primary/20 dark:border-primary/40 group">
              <img id="preview-img" src={testimonio.image_url || ''} class="w-full h-full object-cover" alt="Vista previa de perfil" />
              <button
                type="button"
                id="del-preview-btn"
                class="absolute inset-0 bg-black/55 opacity-0 group-hover:opacity-100 transition duration-200 text-white text-xs font-bold flex items-center justify-center cursor-pointer"
              >
                Eliminar
              </button>
            </div>
          </div>
        </div>

        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
          <div>
            <label for="orden" class="mb-1.5 block text-sm font-medium text-gray-700 dark:text-slate-300">Orden de visualización</label>
            <input
              type="number"
              id="orden"
              name="orden"
              value={testimonio.orden}
              min="0"
              class="w-full rounded-xl border border-gray-200 bg-white px-4 py-3 text-sm outline-none transition focus:border-primary focus:ring-2 focus:ring-primary/20 dark:border-slate-700 dark:bg-slate-800 dark:text-white dark:focus:border-indigo-500 dark:focus:ring-indigo-500/20"
            />
            <p class="text-xs text-gray-400 dark:text-slate-550 mt-1">Los testimonios se muestran ordenados de menor a mayor valor.</p>
          </div>
          <div class="flex items-center pt-6">
            <label class="relative inline-flex items-center cursor-pointer">
              <input type="checkbox" id="published" name="published" value="true" checked={testimonio.published} class="sr-only peer" />
              <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-primary/20 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary dark:bg-slate-800"></div>
              <span class="ml-3 text-sm font-medium text-gray-700 dark:text-slate-300">Publicado</span>
            </label>
          </div>
        </div>

        <div id="error-msg" class="hidden rounded-lg bg-red-50 px-4 py-3 text-sm text-red-600 dark:bg-rose-950/30 dark:text-rose-400"></div>

        <div class="flex items-center gap-3 pt-2">
          <button type="submit" id="submit-btn" class="rounded-lg bg-primary px-6 py-2.5 text-sm font-semibold text-white transition hover:bg-primary/90 cursor-pointer">
            Guardar Cambios
          </button>
          <a href="/admin/testimonios" class="rounded-lg border border-gray-200 bg-white px-6 py-2.5 text-sm font-semibold text-gray-700 transition hover:bg-gray-50 dark:bg-slate-800 dark:border-slate-700 dark:text-slate-200 dark:hover:bg-slate-700/80">
            Cancelar
          </a>
          <button type="button" id="delete-btn" class="ml-auto rounded-lg bg-red-50 px-4 py-2.5 text-sm font-medium text-red-600 transition hover:bg-red-100 dark:bg-rose-950/30 dark:text-rose-400 dark:hover:bg-rose-900/40 cursor-pointer">
            Eliminar
          </button>
        </div>
      </form>
    </div>
  </div>
</AdminLayout>

<script>
  import { navigate } from 'astro:transitions/client';

  function compressImage(file: File, maxWidth = 400, maxHeight = 400, quality = 0.8): Promise<string> {
    return new Promise((resolve, reject) => {
      if (!file.type.startsWith('image/')) {
        reject(new Error('El archivo no es una imagen.'));
        return;
      }

      const reader = new FileReader();
      reader.readAsDataURL(file);
      reader.onload = (event) => {
        const img = new Image();
        img.src = event.target?.result as string;
        img.onload = () => {
          const canvas = document.createElement('canvas');
          let width = img.width;
          let height = img.height;

          // Crop or resize to square for avatar
          const size = Math.min(width, height);
          const startX = (width - size) / 2;
          const startY = (height - size) / 2;

          canvas.width = maxWidth;
          canvas.height = maxHeight;

          const ctx = canvas.getContext('2d');
          if (!ctx) {
            resolve(event.target?.result as string);
            return;
          }

          ctx.drawImage(img, startX, startY, size, size, 0, 0, maxWidth, maxHeight);
          const compressedDataUrl = canvas.toDataURL('image/jpeg', quality);
          resolve(compressedDataUrl);
        };
        img.onerror = (err) => reject(err);
      };
      reader.onerror = (err) => reject(err);
    });
  }

  function setupEditTestimonio() {
    const form = document.getElementById('testimonio-form') as HTMLFormElement | null;
    if (!form) return;

    const tabUpload = document.getElementById('tab-upload');
    const tabUrl = document.getElementById('tab-url');
    const uploadContainer = document.getElementById('upload-container');
    const urlContainer = document.getElementById('url-container');
    
    const imageFile = document.getElementById('image_file') as HTMLInputElement | null;
    const imageUrlInput = document.getElementById('image_url_input') as HTMLInputElement | null;
    const addUrlBtn = document.getElementById('add-url-btn');
    const imageUrlHidden = document.getElementById('image_url') as HTMLInputElement | null;
    
    const previewContainer = document.getElementById('image-preview-container');
    const previewImg = document.getElementById('preview-img') as HTMLImageElement | null;
    const delPreviewBtn = document.getElementById('del-preview-btn');

    let currentImageUrl = imageUrlHidden?.value || '';

    function setMode(mode: 'upload' | 'url') {
      if (mode === 'upload') {
        tabUpload?.classList.add('bg-white', 'text-gray-800', 'shadow-sm', 'border', 'border-gray-100');
        tabUpload?.classList.remove('text-gray-500', 'hover:text-gray-800');
        tabUrl?.classList.add('text-gray-500', 'hover:text-gray-800');
        tabUrl?.classList.remove('bg-white', 'text-gray-800', 'shadow-sm', 'border', 'border-gray-100');
        
        uploadContainer?.classList.remove('hidden');
        urlContainer?.classList.add('hidden');
      } else {
        tabUrl?.classList.add('bg-white', 'text-gray-800', 'shadow-sm', 'border', 'border-gray-100');
        tabUrl?.classList.remove('text-gray-500', 'hover:text-gray-800');
        tabUpload?.classList.add('text-gray-500', 'hover:text-gray-800');
        tabUpload?.classList.remove('bg-white', 'text-gray-800', 'shadow-sm', 'border', 'border-gray-100');
        
        urlContainer?.classList.remove('hidden');
        uploadContainer?.classList.add('hidden');
      }
    }

    tabUpload?.addEventListener('click', () => setMode('upload'));
    tabUrl?.addEventListener('click', () => setMode('url'));

    function renderImagePreview(src: string) {
      currentImageUrl = src;
      if (imageUrlHidden) imageUrlHidden.value = src;
      if (previewImg) previewImg.src = src;

      if (src) {
        previewContainer?.classList.remove('hidden');
      } else {
        previewContainer?.classList.add('hidden');
      }
    }

    // Initialize display state
    if (currentImageUrl) {
      renderImagePreview(currentImageUrl);
      if (!currentImageUrl.startsWith('data:')) {
        setMode('url');
      } else {
        setMode('upload');
      }
    } else {
      setMode('upload');
    }

    // Manual upload
    imageFile?.addEventListener('change', async () => {
      const file = imageFile.files?.[0];
      if (!file) return;

      if (file.size >= 1024 * 1024) {
        (window as any).showToast('La foto supera el límite de 1MB. Selecciona un archivo más pequeño.', 'error');
        imageFile.value = '';
        return;
      }

      try {
        const base64 = await compressImage(file);
        renderImagePreview(base64);
      } catch (err) {
        console.error('Error al procesar foto:', err);
        const reader = new FileReader();
        reader.onload = (e) => {
          renderImagePreview(e.target?.result as string || '');
        };
        reader.readAsDataURL(file);
      }
      imageFile.value = '';
    });

    // Add URL
    addUrlBtn?.addEventListener('click', () => {
      if (!imageUrlInput) return;
      const url = imageUrlInput.value.trim();
      if (!url) return;
      renderImagePreview(url);
      imageUrlInput.value = '';
    });

    // Delete preview
    delPreviewBtn?.addEventListener('click', () => {
      renderImagePreview('');
    });

    // Save changes submit
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const errorMsg = document.getElementById('error-msg');
      const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;
      if (!errorMsg || !submitBtn) return;

      errorMsg.classList.add('hidden');
      submitBtn.disabled = true;
      submitBtn.textContent = 'Guardando...';

      const testimonioId = form.dataset.id;
      const formData = new FormData(form);
      const isPublished = (document.getElementById('published') as HTMLInputElement)?.checked;

      const res = await fetch(`/api/testimonios/${testimonioId}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          autor: formData.get('autor'),
          rol: formData.get('rol'),
          texto: formData.get('texto'),
          image_url: currentImageUrl || null,
          orden: Number(formData.get('orden')) || 0,
          published: isPublished,
        }),
      });

      const data = await res.json();

      if (res.ok) {
        sessionStorage.setItem('flash_message', JSON.stringify({ title: 'Testimonio actualizado con éxito', icon: 'success' }));
        navigate('/admin/testimonios');
      } else {
        errorMsg.textContent = data.error || 'Error al actualizar el testimonio';
        errorMsg.classList.remove('hidden');
        submitBtn.disabled = false;
        submitBtn.textContent = 'Guardar Cambios';
      }
    });

    // Delete button click
    const deleteBtn = document.getElementById('delete-btn');
    if (deleteBtn) {
      // Avoid duplicate event listener registers in SPA navigation
      const newDeleteBtn = deleteBtn.cloneNode(true);
      deleteBtn.parentNode?.replaceChild(newDeleteBtn, deleteBtn);

      newDeleteBtn.addEventListener('click', async () => {
        const authorName = (document.getElementById('autor') as HTMLInputElement)?.value || 'este testimonio';
        const confirmed = await (window as any).showConfirm(
          '¿Eliminar testimonio?',
          `¿Eliminar el testimonio de "${authorName}" definitivamente?`,
          'Eliminar'
        );
        if (!confirmed) return;

        const testimonioId = form.dataset.id;
        const res = await fetch(`/api/testimonios/${testimonioId}`, { method: 'DELETE' });

        if (res.ok) {
          sessionStorage.setItem('flash_message', JSON.stringify({ title: 'Testimonio eliminado con éxito', icon: 'success' }));
          navigate('/admin/testimonios');
        } else {
          (window as any).showToast('Error al eliminar testimonio', 'error');
        }
      });
    }
  }

  document.addEventListener('astro:page-load', () => {
    if (document.getElementById('testimonio-form')) {
      setupEditTestimonio();
    }
  });
</script>

---
import AdminLayout from '../../../components/admin/AdminLayout.astro';
import { getSessionToken, validateSession } from '../../../lib/auth';
import { supabase } from '../../../lib/db';

const token = getSessionToken(Astro.request);
const session = token ? await validateSession(token) : null;

if (!session) {
  return Astro.redirect('/admin/login');
}

if (session.rol !== 'admin') {
  return Astro.redirect('/admin/dashboard');
}

const statusFilter = Astro.url.searchParams.get('status') || '';

let preRegistrations = [];
let queryError = null;

try {
  let query = supabase.from('pre_registrations').select('id, student_name, grade_requested, parent_name, parent_phone, status, created_at').order('created_at', { ascending: false });
  
  if (statusFilter) {
    query = query.eq('status', statusFilter);
  }
  
  const { data, error } = await query;
  if (error) throw error;
  preRegistrations = data || [];
} catch (err: any) {
  queryError = err;
  console.error('Error fetching pre-registrations:', err);
}

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString('es-VE', {
    day: '2-digit',
    month: '2-digit',
    year: 'numeric',
  });
}
---

<AdminLayout
  title="Pre-inscripciones"
  userNombre={session.nombre}
  userEmail={session.email}
  userRol={session.rol}
  currentPath={Astro.url.pathname}
>
  <!-- Description and Filter Row -->
  <div class="mb-6 flex flex-col justify-between gap-4 sm:flex-row sm:items-center">
    <p class="text-sm text-gray-500 dark:text-slate-400">Control y seguimiento escolar de postulaciones online</p>

    <!-- Filters Badges -->
    <div class="flex flex-wrap gap-2 text-xs font-semibold">
      <a href="/admin/pre-inscripciones" class={`rounded-lg px-3 py-1.5 transition duration-150 ${!statusFilter ? 'bg-primary text-white shadow-sm' : 'bg-white text-gray-600 border border-gray-200 hover:bg-gray-50 dark:bg-slate-900 dark:text-slate-350 dark:border-slate-800 dark:hover:bg-slate-800'}`}>
        Todos
      </a>
      <a href="/admin/pre-inscripciones?status=pending" class={`rounded-lg px-3 py-1.5 transition duration-150 ${statusFilter === 'pending' ? 'bg-amber-500 text-white shadow-sm' : 'bg-white text-gray-600 border border-gray-200 hover:bg-gray-50 dark:bg-slate-900 dark:text-slate-350 dark:border-slate-800 dark:hover:bg-slate-800'}`}>
        Pendientes
      </a>
      <a href="/admin/pre-inscripciones?status=contacted" class={`rounded-lg px-3 py-1.5 transition duration-150 ${statusFilter === 'contacted' ? 'bg-blue-600 text-white shadow-sm' : 'bg-white text-gray-600 border border-gray-200 hover:bg-gray-50 dark:bg-slate-900 dark:text-slate-350 dark:border-slate-800 dark:hover:bg-slate-800'}`}>
        Contactados
      </a>
      <a href="/admin/pre-inscripciones?status=scheduled_interview" class={`rounded-lg px-3 py-1.5 transition duration-150 ${statusFilter === 'scheduled_interview' ? 'bg-purple-600 text-white shadow-sm' : 'bg-white text-gray-600 border border-gray-200 hover:bg-gray-50 dark:bg-slate-900 dark:text-slate-350 dark:border-slate-800 dark:hover:bg-slate-800'}`}>
        Entrevista
      </a>
      <a href="/admin/pre-inscripciones?status=accepted" class={`rounded-lg px-3 py-1.5 transition duration-150 ${statusFilter === 'accepted' ? 'bg-green-600 text-white shadow-sm' : 'bg-white text-gray-600 border border-gray-200 hover:bg-gray-50 dark:bg-slate-900 dark:text-slate-350 dark:border-slate-800 dark:hover:bg-slate-800'}`}>
        Aceptados
      </a>
      <a href="/admin/pre-inscripciones?status=rejected" class={`rounded-lg px-3 py-1.5 transition duration-150 ${statusFilter === 'rejected' ? 'bg-rose-600 text-white shadow-sm' : 'bg-white text-gray-600 border border-gray-200 hover:bg-gray-50 dark:bg-slate-900 dark:text-slate-350 dark:border-slate-800 dark:hover:bg-slate-800'}`}>
        Rechazados
      </a>
    </div>
  </div>

  <!-- Main Table -->
  <div class="rounded-xl border border-gray-150 bg-white shadow-sm overflow-hidden dark:bg-slate-900 dark:border-slate-800">
    {queryError ? (
      <div class="p-8 text-center text-rose-600 dark:text-rose-400">
        <p class="font-semibold">Error al cargar postulaciones</p>
        <p class="text-xs mt-1 text-gray-500 dark:text-slate-400">Asegúrate de haber ejecutado los scripts de base de datos en Supabase.</p>
      </div>
    ) : (
      <div class="overflow-x-auto">
        <table class="w-full text-left text-sm">
          <thead>
            <tr class="border-b bg-gray-50 border-gray-150 dark:bg-slate-800/50 dark:border-slate-800">
              <th class="px-5 py-3.5 font-semibold text-gray-600 dark:text-slate-300">Estudiante</th>
              <th class="px-5 py-3.5 font-semibold text-gray-600 dark:text-slate-300">Grado</th>
              <th class="px-5 py-3.5 font-semibold text-gray-600 dark:text-slate-300">Representante</th>
              <th class="px-5 py-3.5 font-semibold text-gray-600 dark:text-slate-300">Estado</th>
              <th class="px-5 py-3.5 font-semibold text-gray-600 dark:text-slate-300 max-md:hidden">Registro</th>
              <th class="px-5 py-3.5 font-semibold text-gray-600 dark:text-slate-300 text-right">Acción</th>
            </tr>
          </thead>
          <tbody id="pre-reg-table-body">
            {preRegistrations.length === 0 ? (
              <tr>
                <td colspan="6" class="px-5 py-12 text-center text-gray-400 dark:text-slate-500">
                  No hay solicitudes registradas {statusFilter && `con el estado "${statusFilter}"`}
                </td>
              </tr>
            ) : (
              preRegistrations.map((p) => {
                const statusBadge = p.status === 'pending'
                  ? 'bg-amber-50 text-amber-700 border border-amber-100 dark:bg-amber-950/30 dark:text-amber-350 dark:border-amber-900/30'
                  : p.status === 'contacted'
                  ? 'bg-blue-50 text-blue-700 border border-blue-100 dark:bg-blue-900/30 dark:text-blue-300 dark:border-blue-900/30'
                  : p.status === 'scheduled_interview'
                  ? 'bg-purple-50 text-purple-700 border border-purple-100 dark:bg-purple-950/30 dark:text-purple-350 dark:border-purple-900/30'
                  : p.status === 'accepted'
                  ? 'bg-green-50 text-green-700 border border-green-100 dark:bg-green-950/30 dark:text-green-350 dark:border-green-900/30'
                  : 'bg-rose-50 text-rose-700 border border-rose-100 dark:bg-rose-950/30 dark:text-rose-350 dark:border-rose-900/30';

                const statusLabels = {
                  pending: 'Pendiente',
                  contacted: 'Contactado',
                  scheduled_interview: 'Entrevista',
                  accepted: 'Aceptado',
                  rejected: 'Rechazado'
                };

                return (
                  <tr class="border-b border-gray-100 last:border-0 hover:bg-gray-50/50 dark:border-slate-800 dark:hover:bg-slate-800/40 transition duration-150">
                    <td class="px-5 py-4 font-semibold text-gray-900 dark:text-white truncate max-w-[150px]" title={p.student_name}>
                      {p.student_name}
                    </td>
                    <td class="px-5 py-4 font-medium text-gray-700 dark:text-slate-300">
                      {p.grade_requested}
                    </td>
                    <td class="px-5 py-4">
                      <div class="text-gray-800 dark:text-slate-200 font-medium truncate max-w-[150px]">{p.parent_name}</div>
                      <div class="text-xs text-gray-500 dark:text-slate-400">{p.parent_phone}</div>
                    </td>
                    <td class="px-5 py-4">
                      <span class={`rounded-full px-2.5 py-0.5 text-xs font-medium ${statusBadge}`}>
                        {statusLabels[p.status as keyof typeof statusLabels] || p.status}
                      </span>
                    </td>
                    <td class="px-5 py-4 text-gray-500 dark:text-slate-400 max-md:hidden text-xs">
                      {formatDate(p.created_at)}
                    </td>
                    <td class="px-5 py-4 text-right">
                      <div class="flex items-center justify-end gap-2">
                        <a
                          href={`/admin/pre-inscripciones/${p.id}`}
                          class="inline-flex h-8 w-8 items-center justify-center rounded-lg bg-slate-50 text-slate-700 border border-slate-200 dark:bg-slate-800 dark:text-slate-350 dark:border-slate-700 transition hover:bg-slate-100 hover:text-slate-900 dark:hover:bg-slate-700 dark:hover:text-white"
                          title="Detalle"
                        >
                          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                            <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                          </svg>
                        </a>
                        {session.rol === 'admin' && (
                          <button
                            data-id={p.id}
                            data-name={p.student_name}
                            class="eliminar-prereg-btn inline-flex h-8 w-8 items-center justify-center rounded-lg bg-rose-50 text-rose-700 border border-rose-100 dark:bg-rose-950/30 dark:text-rose-400 dark:border-rose-900/30 transition hover:bg-rose-100 hover:text-rose-900 dark:hover:bg-rose-900/40 dark:hover:text-rose-350 cursor-pointer"
                            title="Eliminar"
                          >
                            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                              <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                            </svg>
                          </button>
                        )}
                      </div>
                    </td>
                  </tr>
                );
              })
            )}
          </tbody>
        </table>
      </div>
    )}
  </div>
</AdminLayout>

<script>
  import { navigate } from 'astro:transitions/client';

  async function deletePreReg(id: number, name: string) {
    if (!confirm(`¿Eliminar la solicitud de pre-inscripción del alumno "${name}"?`)) return;

    try {
      const res = await fetch(`/api/pre-inscripciones/${id}`, { method: 'DELETE' });
      if (res.ok) {
        navigate(window.location.pathname + window.location.search);
      } else {
        const data = await res.json();
        alert(data.error || 'Error al eliminar la postulación');
      }
    } catch (err) {
      console.error('Delete error:', err);
      alert('Error de red al intentar eliminar la postulación.');
    }
  }

  function setupPreReg() {
    const buttons = document.querySelectorAll('.eliminar-prereg-btn');
    buttons.forEach((btn) => {
      btn.addEventListener('click', async () => {
        const id = Number(btn.getAttribute('data-id'));
        const name = btn.getAttribute('data-name');
        if (isNaN(id) || !name) return;
        await deletePreReg(id, name);
      });
    });
  }

  document.addEventListener('astro:page-load', () => {
    if (document.getElementById('pre-reg-table-body')) {
      setupPreReg();
    }
  });
</script>

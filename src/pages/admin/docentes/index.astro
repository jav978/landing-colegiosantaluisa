---
import AdminLayout from '../../../components/admin/AdminLayout.astro';
import { getSessionToken, validateSession } from '../../../lib/auth';
import { supabase } from '../../../lib/db';

const token = getSessionToken(Astro.request);
const session = token ? await validateSession(token) : null;

if (!session) {
  return Astro.redirect('/admin/login');
}

// Fetch all teachers ordered by order weight and created date
const { data: dbDocentes } = await supabase
  .from('docentes')
  .select('*')
  .order('orden', { ascending: true })
  .order('created_at', { ascending: false });

const docentes = dbDocentes || [];

const categoryLabels: Record<string, string> = {
  inicial: 'Ed. Inicial',
  primaria: 'Ed. Primaria',
  media: 'Media General',
  coordinacion: 'Liderazgo / Coord.',
};
---

<AdminLayout
  title="Docentes"
  userNombre={session.nombre}
  userEmail={session.email}
  userRol={session.rol}
  currentPath={Astro.url.pathname}
>
  <div class="mb-6 flex flex-wrap gap-4 items-center justify-between">
    <div class="flex flex-wrap gap-1.5">
      <button class="filter-btn active rounded-lg border px-3 py-1.5 text-xs font-medium transition bg-primary text-white border-primary cursor-pointer" data-filter="">Todos</button>
      <button class="filter-btn rounded-lg border px-3 py-1.5 text-xs font-medium transition text-gray-600 border-gray-200 cursor-pointer" data-filter="coordinacion">Coordinación</button>
      <button class="filter-btn rounded-lg border px-3 py-1.5 text-xs font-medium transition text-gray-600 border-gray-200 cursor-pointer" data-filter="inicial">Inicial</button>
      <button class="filter-btn rounded-lg border px-3 py-1.5 text-xs font-medium transition text-gray-600 border-gray-200 cursor-pointer" data-filter="primaria">Primaria</button>
      <button class="filter-btn rounded-lg border px-3 py-1.5 text-xs font-medium transition text-gray-600 border-gray-200 cursor-pointer" data-filter="media">Media General</button>
    </div>
    <a href="/admin/docentes/new" data-astro-prefetch class="rounded-lg bg-primary px-4 py-2 text-sm font-semibold text-white transition hover:bg-primary/90">
      + Nuevo Docente
    </a>
  </div>

  <div class="rounded-xl border bg-white shadow-sm">
    <div class="overflow-x-auto">
      <table class="w-full text-left text-sm">
        <thead>
          <tr class="border-b bg-gray-50">
            <th class="px-5 py-3 font-semibold text-gray-600">Nombre</th>
            <th class="px-5 py-3 font-semibold text-gray-600">Cargo / Rol</th>
            <th class="px-5 py-3 font-semibold text-gray-600">Categoría</th>
            <th class="px-5 py-3 font-semibold text-gray-600 max-md:hidden">Cátedra / Grado</th>
            <th class="px-5 py-3 font-semibold text-gray-600 text-center max-md:hidden">Orden</th>
            <th class="px-5 py-3 font-semibold text-gray-600">Acción</th>
          </tr>
        </thead>
        <tbody id="docentes-table-body">
          {docentes.length === 0 ? (
            <tr><td colspan="6" class="px-5 py-10 text-center text-gray-400">No hay docentes registrados en la base de datos</td></tr>
          ) : (
            docentes.map((d) => {
              const categoryName = categoryLabels[d.category] || d.category;
              return (
                <tr class="border-b last:border-0 hover:bg-gray-50 transition duration-150" data-category={d.category} data-row>
                  <td class="px-5 py-4 font-medium text-gray-900 flex items-center gap-3">
                    {d.image_url ? (
                      <img src={d.image_url} alt={d.name} class="h-9 w-9 rounded-full object-cover border" />
                    ) : (
                      <div class="flex h-9 w-9 items-center justify-center rounded-full bg-gray-200 text-gray-500 font-bold text-xs">
                        {d.name.charAt(0).toUpperCase()}
                      </div>
                    )}
                    <span>{d.name}</span>
                  </td>
                  <td class="px-5 py-4 text-gray-700">{d.role}</td>
                  <td class="px-5 py-4">
                    <span class="rounded-full bg-slate-100 text-slate-700 px-2.5 py-0.5 text-xs font-medium border border-slate-200/50">{categoryName}</span>
                  </td>
                  <td class="px-5 py-4 text-gray-500 max-md:hidden">{d.grade}</td>
                  <td class="px-5 py-4 text-gray-600 text-center max-md:hidden font-mono">{d.orden}</td>
                  <td class="px-5 py-4">
                    <div class="flex items-center gap-2">
                      <a href={`/admin/docentes/${d.id}/edit`} data-astro-prefetch class="rounded-lg bg-gray-50 px-3 py-1.5 text-xs font-medium text-gray-700 transition hover:bg-gray-100">
                        Editar
                      </a>
                      <button 
                        class="delete-btn rounded-lg bg-rose-50 px-3 py-1.5 text-xs font-medium text-rose-700 transition hover:bg-rose-100 cursor-pointer"
                        data-id={d.id}
                        data-name={d.name}
                      >
                        Eliminar
                      </button>
                    </div>
                  </td>
                </tr>
              );
            })
          )}
        </tbody>
      </table>
    </div>
  </div>
</AdminLayout>

<script>
  function setupFiltering() {
    const buttons = document.querySelectorAll('.filter-btn');
    const rows = document.querySelectorAll('[data-row]');

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const filter = (btn as HTMLButtonElement).dataset.filter || '';

        // Update active class on filter buttons
        buttons.forEach((b) => {
          const isTarget = (b as HTMLButtonElement).dataset.filter === filter;
          b.classList.toggle('active', isTarget);
          b.classList.toggle('bg-primary', isTarget);
          b.classList.toggle('text-white', isTarget);
          b.classList.toggle('border-primary', isTarget);
          b.classList.toggle('text-gray-600', !isTarget);
          b.classList.toggle('border-gray-200', !isTarget);
        });

        // Hide/Show rows depending on the category match
        rows.forEach((row) => {
          const category = (row as HTMLElement).dataset.category;
          if (filter === '' || category === filter) {
            row.classList.remove('hidden');
          } else {
            row.classList.add('hidden');
          }
        });
      });
    });
  }

  function setupDeletion() {
    const deleteBtns = document.querySelectorAll('.delete-btn');
    deleteBtns.forEach((btn) => {
      btn.addEventListener('click', async () => {
        const id = (btn as HTMLElement).dataset.id;
        const name = (btn as HTMLElement).dataset.name;

        if (!id || !confirm(`¿Estás seguro de que deseas eliminar al docente "${name}" de la lista?`)) return;

        try {
          const res = await fetch(`/api/docentes/${id}`, {
            method: 'DELETE',
          });
          
          if (res.ok) {
            window.location.reload();
          } else {
            const data = await res.json();
            alert(`Error: ${data.error || 'No se pudo eliminar el registro'}`);
          }
        } catch (err) {
          console.error(err);
          alert('Error de conexión al intentar eliminar');
        }
      });
    });
  }

  document.addEventListener('astro:page-load', () => {
    if (document.querySelector('.filter-btn')) {
      setupFiltering();
      setupDeletion();
    }
  });
</script>

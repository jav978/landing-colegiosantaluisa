---
import AdminLayout from '../../components/admin/AdminLayout.astro';
import { getSessionToken, validateSession } from '../../lib/auth';

const token = getSessionToken(Astro.request);
const session = token ? await validateSession(token) : null;

if (!session) {
  return Astro.redirect('/admin/login');
}

const { supabase } = await import('../../lib/db');

const { count: totalUsuarios } = await supabase.from('usuarios').select('*', { count: 'exact', head: true });
const { count: totalPosts } = await supabase.from('posts').select('*', { count: 'exact', head: true });
const { count: totalAnuncios } = await supabase.from('posts').select('*', { count: 'exact', head: true }).eq('type', 'anuncio');

let unreadMessages = 0;
let pendingPreRegs = 0;
let recentMessages = [];
let recentPreRegs = [];

try {
  const { count } = await supabase.from('contact_messages').select('*', { count: 'exact', head: true }).eq('status', 'unread');
  unreadMessages = count ?? 0;
  
  const { data } = await supabase.from('contact_messages').select('id, name, email, created_at, status').order('created_at', { ascending: false }).limit(5);
  recentMessages = data || [];
} catch (e) {
  console.warn('Could not load contact messages:', e);
}

try {
  const { count } = await supabase.from('pre_registrations').select('*', { count: 'exact', head: true }).eq('status', 'pending');
  pendingPreRegs = count ?? 0;

  const { data } = await supabase.from('pre_registrations').select('id, student_name, grade_requested, created_at, status').order('created_at', { ascending: false }).limit(5);
  recentPreRegs = data || [];
} catch (e) {
  console.warn('Could not load pre-registrations:', e);
}

const stats = [
  { label: 'Mensajes sin leer', value: unreadMessages, icon: '✉️', color: 'bg-rose-500', href: '/admin/mensajes' },
  { label: 'Pre-inscripciones pend.', value: pendingPreRegs, icon: '🎓', color: 'bg-indigo-500', href: '/admin/pre-inscripciones' },
  { label: 'Posts (Blog)', value: (totalPosts ?? 0) - (totalAnuncios ?? 0), icon: '📝', color: 'bg-emerald-500', href: '/admin/posts' },
  { label: 'Usuarios', value: totalUsuarios ?? 0, icon: '👥', color: 'bg-blue-500', href: '/admin/usuarios' },
];

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString('es-VE', {
    day: '2-digit',
    month: '2-digit',
    year: '2-digit',
    hour: '2-digit',
    minute: '2-digit',
  });
}
---

<AdminLayout
  title="Dashboard"
  userNombre={session.nombre}
  userEmail={session.email}
  userRol={session.rol}
  currentPath={Astro.url.pathname}
>
  <!-- Stats Grid -->
  <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
    {stats.map((s) => (
      <a href={s.href} class="block rounded-xl border bg-white p-6 shadow-sm transition hover:shadow-md hover:border-primary/20">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm font-medium text-gray-500">{s.label}</p>
            <p class="mt-1 text-3xl font-bold text-gray-900">{s.value}</p>
          </div>
          <div class={`flex h-12 w-12 items-center justify-center rounded-xl ${s.color} text-xl text-white shadow-sm`}>
            {s.icon}
          </div>
        </div>
      </a>
    ))}
  </div>

  <!-- Welcome Alert -->
  <div class="mt-8 rounded-xl border bg-white p-6 shadow-sm">
    <h2 class="text-lg font-semibold text-gray-900">Bienvenido, {session.nombre}</h2>
    <p class="mt-2 text-sm leading-relaxed text-gray-600">
      Este es el panel CRM del Colegio Santa Luisa. Desde aquí puedes gestionar los mensajes de contacto, las solicitudes de pre-inscripción, los posts del blog, los usuarios y monitorear el estado general del sitio.
    </p>
    <div class="mt-4 flex flex-wrap gap-3">
      <a href="/admin/mensajes" class="rounded-lg bg-primary px-4 py-2 text-sm font-semibold text-white transition hover:bg-primary-light">
        Ver Mensajes
      </a>
      <a href="/admin/pre-inscripciones" class="rounded-lg border border-gray-200 bg-white px-4 py-2 text-sm font-semibold text-gray-700 transition hover:bg-gray-50">
        Ver Pre-inscripciones
      </a>
    </div>
  </div>

  <!-- CRM Activity Tables -->
  <div class="mt-8 grid gap-8 lg:grid-cols-2">
    <!-- Recent Messages -->
    <div class="rounded-xl border bg-white p-6 shadow-sm">
      <div class="mb-4 flex items-center justify-between">
        <h3 class="text-md font-bold text-gray-900">Mensajes Recientes</h3>
        <a href="/admin/mensajes" class="text-xs font-semibold text-primary hover:underline">Ver todos</a>
      </div>
      
      {recentMessages.length === 0 ? (
        <p class="text-sm text-gray-500 py-4 text-center">No hay mensajes registrados o las tablas aún no se han creado.</p>
      ) : (
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-150">
            <thead>
              <tr class="text-left text-xs font-semibold text-gray-500">
                <th class="pb-3">Nombre</th>
                <th class="pb-3">Fecha</th>
                <th class="pb-3">Estado</th>
                <th class="pb-3 text-right">Acción</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100 text-sm text-gray-600">
              {recentMessages.map((m) => (
                <tr>
                  <td class="py-3 font-medium text-gray-900 truncate max-w-[120px]" title={m.name}>{m.name}</td>
                  <td class="py-3 text-xs">{formatDate(m.created_at)}</td>
                  <td class="py-3">
                    <span class={`inline-block rounded-full px-2 py-0.5 text-xs font-medium ${
                      m.status === 'unread' 
                        ? 'bg-rose-50 text-rose-700' 
                        : m.status === 'in_progress'
                        ? 'bg-amber-50 text-amber-700'
                        : 'bg-green-50 text-green-700'
                    }`}>
                      {m.status === 'unread' ? 'Sin leer' : m.status === 'in_progress' ? 'En proceso' : 'Resuelto'}
                    </span>
                  </td>
                  <td class="py-3 text-right">
                    <a href={`/admin/mensajes/${m.id}`} class="text-xs font-bold text-primary hover:text-primary-light">Detalle</a>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
    </div>

    <!-- Recent Pre-Registrations -->
    <div class="rounded-xl border bg-white p-6 shadow-sm">
      <div class="mb-4 flex items-center justify-between">
        <h3 class="text-md font-bold text-gray-900">Pre-inscripciones Recientes</h3>
        <a href="/admin/pre-inscripciones" class="text-xs font-semibold text-primary hover:underline">Ver todas</a>
      </div>

      {recentPreRegs.length === 0 ? (
        <p class="text-sm text-gray-500 py-4 text-center">No hay solicitudes registradas o las tablas aún no se han creado.</p>
      ) : (
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-150">
            <thead>
              <tr class="text-left text-xs font-semibold text-gray-500">
                <th class="pb-3">Estudiante</th>
                <th class="pb-3">Grado</th>
                <th class="pb-3">Estado</th>
                <th class="pb-3 text-right">Acción</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100 text-sm text-gray-600">
              {recentPreRegs.map((r) => (
                <tr>
                  <td class="py-3 font-medium text-gray-900 truncate max-w-[120px]" title={r.student_name}>{r.student_name}</td>
                  <td class="py-3 text-xs">{r.grade_requested}</td>
                  <td class="py-3">
                    <span class={`inline-block rounded-full px-2 py-0.5 text-xs font-medium ${
                      r.status === 'pending' 
                        ? 'bg-amber-50 text-amber-700' 
                        : r.status === 'contacted'
                        ? 'bg-blue-50 text-blue-700'
                        : r.status === 'accepted'
                        ? 'bg-green-50 text-green-700'
                        : r.status === 'scheduled_interview'
                        ? 'bg-purple-50 text-purple-700'
                        : 'bg-rose-50 text-rose-700'
                    }`}>
                      {r.status === 'pending' 
                        ? 'Pendiente' 
                        : r.status === 'contacted' 
                        ? 'Contactado' 
                        : r.status === 'scheduled_interview'
                        ? 'Entrevista'
                        : r.status === 'accepted'
                        ? 'Aceptado'
                        : 'Rechazado'}
                    </span>
                  </td>
                  <td class="py-3 text-right">
                    <a href={`/admin/pre-inscripciones/${r.id}`} class="text-xs font-bold text-primary hover:text-primary-light">Detalle</a>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
    </div>
  </div>
</AdminLayout>

